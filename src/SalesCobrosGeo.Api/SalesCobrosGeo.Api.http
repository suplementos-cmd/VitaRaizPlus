@SalesCobrosGeo.Api_HostAddress = http://localhost:5207
@AdminToken = REPLACE_ADMIN_TOKEN
@SellerToken = REPLACE_SELLER_TOKEN
@SupervisorToken = REPLACE_SUPERVISOR_TOKEN
@CollectorToken = REPLACE_COLLECTOR_TOKEN

### Login admin
POST {{SalesCobrosGeo.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userName": "admin.demo",
  "password": "demo123"
}

### Login seller
POST {{SalesCobrosGeo.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userName": "vendedor.demo",
  "password": "demo123"
}

### Login collector
POST {{SalesCobrosGeo.Api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "userName": "cobrador.demo",
  "password": "demo123"
}

### Block 2 - Catalog snapshot
GET {{SalesCobrosGeo.Api_HostAddress}}/api/catalogs/snapshot
Authorization: Bearer {{AdminToken}}

### Block 3 - Create client
POST {{SalesCobrosGeo.Api_HostAddress}}/api/clients
Authorization: Bearer {{SellerToken}}
Content-Type: application/json

{
  "fullName": "Cliente Demo Uno",
  "mobile": "77712345",
  "phone": "22115544",
  "zoneCode": "CENTRO",
  "collectionDay": "Lunes",
  "address": "Av. Principal 123",
  "isActive": true
}

### Block 3 - Create sale
POST {{SalesCobrosGeo.Api_HostAddress}}/api/sales
Authorization: Bearer {{SellerToken}}
Content-Type: application/json

{
  "clientId": 1,
  "paymentMethodCode": "CREDITO",
  "collectionDay": "Lunes",
  "collectorUserName": "cobrador.demo",
  "sellerCommissionPercent": 8,
  "collectable": true,
  "notes": "Venta inicial",
  "isDraft": false,
  "items": [
    {
      "productId": 1,
      "quantity": 2,
      "unitPrice": 120
    }
  ],
  "evidence": {
    "primaryCoordinates": "-16.5000,-68.1500",
    "secondaryCoordinates": "-16.5002,-68.1502",
    "locationUrl": "https://maps.google.com/?q=-16.5000,-68.1500",
    "photoUrls": ["https://example.com/photo1.jpg"]
  }
}

### Block 4 - Approve sale
POST {{SalesCobrosGeo.Api_HostAddress}}/api/sales/1/review
Authorization: Bearer {{SupervisorToken}}
Content-Type: application/json

{
  "action": "approve",
  "reason": "Documentacion valida"
}

### Block 5 - Portfolio assigned to collector
GET {{SalesCobrosGeo.Api_HostAddress}}/api/collections/assigned
Authorization: Bearer {{CollectorToken}}

### Block 5 - Register payment
POST {{SalesCobrosGeo.Api_HostAddress}}/api/collections/register
Authorization: Bearer {{CollectorToken}}
Content-Type: application/json

{
  "saleId": 1,
  "amount": 150,
  "coordinates": "-16.5001,-68.1502",
  "notes": "Abono parcial",
  "collectedAtUtc": "2026-03-10T16:45:00Z"
}

### Block 6 - Reassign portfolio
POST {{SalesCobrosGeo.Api_HostAddress}}/api/collections/reassign
Authorization: Bearer {{SupervisorToken}}
Content-Type: application/json

{
  "fromCollector": "cobrador.demo",
  "toCollector": "supcobranza.demo",
  "saleIds": [1],
  "reason": "Ajuste de carga"
}

### Block 7 - Mobile sync pull
GET {{SalesCobrosGeo.Api_HostAddress}}/api/sync/pull
Authorization: Bearer {{CollectorToken}}

### Block 7 - Mobile sync push
POST {{SalesCobrosGeo.Api_HostAddress}}/api/sync/push
Authorization: Bearer {{CollectorToken}}
Content-Type: application/json

{
  "collections": [
    {
      "saleId": 1,
      "amount": 50,
      "coordinates": "-16.5001,-68.1502",
      "notes": "Segundo abono",
      "collectedAtUtc": "2026-03-10T17:00:00Z"
    }
  ],
  "saleUpdates": []
}

### Block 8 - Dashboard summary
GET {{SalesCobrosGeo.Api_HostAddress}}/api/dashboard/summary
Authorization: Bearer {{AdminToken}}
