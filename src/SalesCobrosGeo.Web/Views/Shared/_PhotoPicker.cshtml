@model (string InputId, string Label, string? CurrentValue)
<div class="photo-picker" data-photo-key="@Model.InputId">
    <div class="photo-head">
        <div class="photo-label">@Model.Label</div>
        <span class="photo-hint">Vista previa</span>
    </div>
    <div class="photo-preview-wrap">
        <img id="@Model.InputId@("_preview")" class="photo-preview image-previewable" data-previewable="true" src="https://placehold.co/320x200?text=Sin+foto" alt="@Model.Label" loading="lazy" decoding="async" />
        <div class="photo-empty-state">Sin foto</div>
        <div class="photo-loading-state" aria-hidden="true">Procesando...</div>
        <div class="photo-overlay-actions">
            <label class="photo-fab photo-fab-primary" title="Tomar o cargar">
                <span class="photo-fab-icon">CAM</span>
                <span class="photo-fab-text">Cargar</span>
                <input id="@Model.InputId@("_file")" type="file" accept="image/*" capture="environment" hidden />
            </label>
            <button id="@Model.InputId@("_remove")" type="button" class="photo-fab photo-fab-danger" title="Quitar">
                <span class="photo-fab-icon">X</span>
            </button>
        </div>
    </div>
</div>
