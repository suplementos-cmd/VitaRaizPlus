@using SalesCobrosGeo.Web.Models.Shared
@using SalesCobrosGeo.Web.Security
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var rawTheme = isAuthenticated ? User.GetTheme() : "public";
    var theme = rawTheme == "root"
        ? (isAuthenticated && User.HasPermission(AppPermissions.AdministrationView)
            ? "graphite"
            : isAuthenticated && User.HasPermission(AppPermissions.CollectionsView) && !User.HasPermission(AppPermissions.SalesView)
                ? "collections"
                : isAuthenticated && User.HasPermission(AppPermissions.SalesView) && !User.HasPermission(AppPermissions.CollectionsView)
                    ? "sales"
                    : "graphite")
        : rawTheme;
    var themeColor = theme switch
    {
        "sales" => "#2f7dff",
        "forest" => "#1f8a63",
        "sunset" => "#c64d83",
        "collections" => "#6d4fd5",
        "graphite" => "#516176",
        _ => "#203a72"
    };
    var displayName = isAuthenticated ? User.GetDisplayName() : "Invitado";
    var displayRole = isAuthenticated ? User.GetDisplayRole() : "Acceso publico";
    var canDashboard = isAuthenticated && User.HasPermission(AppPermissions.DashboardView);
    var canSales = isAuthenticated && User.HasPermission(AppPermissions.SalesView);
    var canCollections = isAuthenticated && User.HasPermission(AppPermissions.CollectionsView);
    var canMaintenance = isAuthenticated && User.HasPermission(AppPermissions.MaintenanceView);
    var canAdministration = isAuthenticated && User.HasPermission(AppPermissions.AdministrationView);
    var landingController = canAdministration ? "Dashboard" : canSales && !canCollections ? "Sales" : canCollections && !canSales ? "Cobros" : canDashboard ? "Dashboard" : "Account";
    var landingAction = "Index";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    var mobileContextBar = ViewData["MobileContextBar"] as MobileContextBarModel;
    var mobileViewTitle = mobileContextBar?.Title ?? ViewData["Title"]?.ToString() ?? "VitaRaiz";
    var mobileSearchAction = mobileContextBar?.Actions?.FirstOrDefault(x => string.Equals(x.DataAction, "toggle-sales-search", StringComparison.OrdinalIgnoreCase)
        || string.Equals(x.DataAction, "toggle-cobros-search", StringComparison.OrdinalIgnoreCase)
        || string.Equals(x.Icon, "search", StringComparison.OrdinalIgnoreCase));
    var toastMessage = TempData["AppToastMessage"] as string
        ?? TempData["SalesMessage"] as string
        ?? TempData["CobroMessage"] as string
        ?? TempData["AdminSecurityMessage"] as string
        ?? TempData["MaintenanceMessage"] as string;
    var toastTone = TempData["AppToastTone"] as string ?? "success";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiForgeryToken" />
    <meta name="theme-color" content="@themeColor" />
    <title>@ViewData["Title"] - VitaRaizPlus</title>
    <script type="importmap"></script>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    @* Theme System v3.0 - Nuevo Sistema de Diseño Robusto *@
    <link rel="stylesheet" href="~/css/theme/theme-core.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/theme-variants.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/theme-typography.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/theme-buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/theme-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme/theme-utilities.css" asp-append-version="true" />
    
    @* Legacy Design System - Mantener retrocompatibilidad *@
    <link rel="stylesheet" href="~/css/core/design-tokens-enhanced.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/core/utilities.css" asp-append-version="true" />
    
    @* Layout & Responsive *@
    <link rel="stylesheet" href="~/css/layout/responsive-layouts.css" asp-append-version="true" />
    <environment include="Development">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    </environment>
    <link rel="stylesheet" href="~/css/modules/layout.css" asp-append-version="true" />
    
    @* Components *@
    <link rel="stylesheet" href="~/css/components/mobile-components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/ui-ux.css" asp-append-version="true" />
    
    @* Feature Modules *@
    <link rel="stylesheet" href="~/css/modules/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/dashboard-extended.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/sales.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/collections.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/maintenance.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/administration.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/security.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SalesCobrosGeo.Web.styles.css" asp-append-version="true" />
</head>
<body data-role-theme="@theme" data-authenticated="@(isAuthenticated ? "true" : "false")" data-controller="@currentController.ToLowerInvariant()" data-action="@currentAction.ToLowerInvariant()">
    <div class="app-shell">
        <header class="app-header-shell">
            <nav class="navbar navbar-expand-lg navbar-dark app-topbar">
                <div class="container-fluid app-topbar-inner">
                    @if (isAuthenticated)
                    {
                        <div class="app-mobile-masterbar d-lg-none">
                            @if (!string.IsNullOrWhiteSpace(mobileContextBar?.BackUrl))
                            {
                                <a class="app-mobile-backbtn" href="@mobileContextBar.BackUrl" aria-label="Volver">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M15 18l-6-6 6-6"></path>
                                    </svg>
                                </a>
                            }
                            else
                            {
                                @* Navigation buttons using browser history *@
                                <div class="app-nav-controls">
                                    <button type="button" class="app-nav-btn app-nav-back" onclick="window.history.back()" aria-label="Atrás" title="Atrás">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/>
                                        </svg>
                                    </button>
                                    <button type="button" class="app-nav-btn app-nav-forward" onclick="window.history.forward()" aria-label="Adelante" title="Adelante">
                                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                                        </svg>
                                    </button>
                                </div>
                            }
                            <a class="app-mobile-brand" asp-area="" asp-controller="@landingController" asp-action="@landingAction">
                                <span class="app-mobile-brandmark" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M12 22V12"/><path d="M12 12C12 7 17 3 22 3c0 5-4 9-10 9z"/><path d="M12 12C12 7 7 3 2 3c0 5 4 9 10 9z"/></svg>
                            </span>
                                <span class="app-mobile-brandtext">VitaRaiz</span>
                            </a>
                            <div class="app-mobile-viewtitle">@mobileViewTitle</div>
                            <div class="app-mobile-headeractions">
                                @if (mobileSearchAction is not null)
                                {
                                    if (!string.IsNullOrWhiteSpace(mobileSearchAction.Url))
                                    {
                                        <a class="app-mobile-headerbtn" href="@mobileSearchAction.Url" aria-label="@(mobileSearchAction.AriaLabel ?? mobileSearchAction.Label)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <circle cx="11" cy="11" r="7"></circle>
                                                <path d="m20 20-3.5-3.5"></path>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" class="app-mobile-headerbtn" data-context-action="@mobileSearchAction.DataAction" aria-label="@(mobileSearchAction.AriaLabel ?? mobileSearchAction.Label)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <circle cx="11" cy="11" r="7"></circle>
                                                <path d="m20 20-3.5-3.5"></path>
                                            </svg>
                                        </button>
                                    }
                                }

                                <button class="app-mobile-headerbtn" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMoreMenu" aria-controls="mobileMoreMenu" aria-label="Abrir menu">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M4 7h16"></path>
                                        <path d="M4 12h16"></path>
                                        <path d="M4 17h16"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }

            <a class="navbar-brand" asp-area="" asp-controller="@landingController" asp-action="@landingAction">
                    <span class="navbar-brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M12 22V12"/><path d="M12 12C12 7 17 3 22 3c0 5-4 9-10 9z"/><path d="M12 12C12 7 7 3 2 3c0 5 4 9 10 9z"/></svg>
                    </span>
                    <span class="navbar-brand-text">VitaRaizPlus</span>
                </a>

                    @* Desktop navigation controls *@
                    @if (isAuthenticated)
                    {
                        <div class="app-desktop-nav-controls d-none d-lg-flex">
                            <button type="button" class="app-desktop-nav-btn app-nav-back" onclick="window.history.back()" aria-label="Atrás" title="Atrás">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                            <button type="button" class="app-desktop-nav-btn app-nav-forward" onclick="window.history.forward()" aria-label="Adelante" title="Adelante">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                                </svg>
                            </button>
                        </div>

                        <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMoreMenu" aria-controls="mobileMoreMenu" aria-label="Abrir menu">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                    }

                    <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                        @if (isAuthenticated)
                        {
                            <ul class="navbar-nav app-main-nav">
                                @if (canDashboard)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Dashboard" asp-action="Index">
                                        <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
                                        <span class="nav-label">Dashboard</span></a>
                                    </li>
                                }
                                @if (canSales)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Sales" ? "active" : string.Empty)" asp-area="" asp-controller="Sales" asp-action="Index">
                                        <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 2H4a1 1 0 00-1 1v18l3-2 3 2 3-2 3 2 3-2V3a1 1 0 00-1-1h-5"/><path d="M9 2v4a1 1 0 001 1h5"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
                                        <span class="nav-label">Ventas</span></a>
                                    </li>
                                }
                                @if (canCollections)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Cobros" ? "active" : string.Empty)" asp-area="" asp-controller="Cobros" asp-action="Index">
                                        <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6z"/><path d="M3 10h18"/><circle cx="16" cy="15" r="1.5" fill="currentColor" stroke="none"/></svg>
                                        <span class="nav-label">Cobros</span></a>
                                    </li>
                                }
                                @if (canMaintenance)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Maintenance" ? "active" : string.Empty)" asp-area="" asp-controller="Maintenance" asp-action="Index">
                                        <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91A6 6 0 0114.7 6.3z"/></svg>
                                        <span class="nav-label">Mantenimiento</span></a>
                                    </li>
                                }
                                @if (canAdministration)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Administration" ? "active" : string.Empty)" asp-area="" asp-controller="Administration" asp-action="Users">
                                        <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                                        <span class="nav-label">Usuarios</span></a>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="app-user-panel">
                            @if (isAuthenticated)
                            {
                                <div class="app-user-chip">
                                    <strong>@displayName</strong>
                                    <small>@displayRole</small>
                                </div>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="app-logout-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                        Salir
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-light" asp-controller="Account" asp-action="Login">Ingresar</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>

            @if (mobileContextBar is not null)
            {
                @await Html.PartialAsync("_MobileContextBar", mobileContextBar)
            }
        </header>

        @if (isAuthenticated)
        {
            <div class="offcanvas offcanvas-end mobile-more-menu" tabindex="-1" id="mobileMoreMenu" aria-labelledby="mobileMoreMenuLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="mobileMoreMenuLabel">Mas accesos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
                </div>
                <div class="offcanvas-body">
                    <div class="mobile-more-links">
                        @if (canMaintenance)
                        {
                        <a class="mobile-more-link" asp-controller="Maintenance" asp-action="Index">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91A6 6 0 0114.7 6.3z"/></svg>
                            <span class="nav-label">Mantenimiento</span></a>
                        }
                        @if (canAdministration)
                        {
                            <a class="mobile-more-link" asp-controller="Administration" asp-action="Users">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                            <span class="nav-label">Usuarios y permisos</span></a>
                        }
                        @if (canDashboard)
                        {
                            <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Sales">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                            <span class="nav-label">Resumen ventas</span></a>
                            <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Collections">
                            <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.21 15.89A10 10 0 118 2.83"/><path d="M22 12A10 10 0 0012 2v10z"/></svg>
                            <span class="nav-label">Resumen cobros</span></a>
                        }
                    </div>
                    <div class="mobile-more-footer">
                        <div class="mobile-more-userchip">
                            <strong>@displayName</strong>
                            <small>@displayRole</small>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="mobile-more-logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="mobile-more-logout">
                                <svg class="nav-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                <span class="nav-label">Salir</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(toastMessage))
        {
            <div class="app-toast-host" aria-live="polite" aria-atomic="true">
                <div class="app-toast app-toast-@toastTone" data-auto-toast="true">@toastMessage</div>
            </div>
        }

        <div class="container-fluid app-content app-frame">
            <main role="main" class="pb-3 page-enter app-main">
                @RenderBody()
            </main>
        </div>

        @if (isAuthenticated)
        {
            <nav class="mobile-bottom-nav" aria-label="Menu principal movil">
                @if (canDashboard)
                {
                    <a class="mobile-bottom-link @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
                        </span>
                        <span class="mobile-bottom-text">Panel</span>
                    </a>
                }
                @if (canSales)
                {
                    <a class="mobile-bottom-link @(currentController == "Sales" ? "active" : string.Empty)" asp-controller="Sales" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2H4a1 1 0 00-1 1v18l3-2 3 2 3-2 3 2 3-2V3a1 1 0 00-1-1h-5"/><path d="M9 2v4a1 1 0 001 1h5"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
                        </span>
                        <span class="mobile-bottom-text">Ventas</span>
                    </a>
                }
                @if (canCollections)
                {
                    <a class="mobile-bottom-link @(currentController == "Cobros" ? "active" : string.Empty)" asp-controller="Cobros" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6a2 2 0 012-2h14a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6z"/><path d="M3 10h18"/><circle cx="16" cy="15" r="1.5" fill="currentColor" stroke="none"/></svg>
                        </span>
                        <span class="mobile-bottom-text">Cobros</span>
                    </a>
                }
            </nav>
        }

        <footer class="border-top footer text-muted">
