@using SalesCobrosGeo.Web.Models.Shared
@using SalesCobrosGeo.Web.Security
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var rawTheme = isAuthenticated ? User.GetTheme() : "public";
    var theme = rawTheme == "root"
        ? (isAuthenticated && User.HasPermission(AppPermissions.AdministrationView)
            ? "graphite"
            : isAuthenticated && User.HasPermission(AppPermissions.CollectionsView) && !User.HasPermission(AppPermissions.SalesView)
                ? "collections"
                : isAuthenticated && User.HasPermission(AppPermissions.SalesView) && !User.HasPermission(AppPermissions.CollectionsView)
                    ? "sales"
                    : "graphite")
        : rawTheme;
    var themeColor = theme switch
    {
        "sales" => "#2f7dff",
        "forest" => "#1f8a63",
        "sunset" => "#c64d83",
        "collections" => "#6d4fd5",
        "graphite" => "#516176",
        _ => "#203a72"
    };
    var displayName = isAuthenticated ? User.GetDisplayName() : "Invitado";
    var displayRole = isAuthenticated ? User.GetDisplayRole() : "Acceso publico";
    var canDashboard = isAuthenticated && User.HasPermission(AppPermissions.DashboardView);
    var canSales = isAuthenticated && User.HasPermission(AppPermissions.SalesView);
    var canCollections = isAuthenticated && User.HasPermission(AppPermissions.CollectionsView);
    var canMaintenance = isAuthenticated && User.HasPermission(AppPermissions.MaintenanceView);
    var canAdministration = isAuthenticated && User.HasPermission(AppPermissions.AdministrationView);
    var landingController = canAdministration ? "Dashboard" : canSales && !canCollections ? "Sales" : canCollections && !canSales ? "Cobros" : canDashboard ? "Dashboard" : "Account";
    var landingAction = "Index";
    var antiForgeryToken = Antiforgery.GetAndStoreTokens(Context).RequestToken ?? string.Empty;
    var mobileContextBar = ViewData["MobileContextBar"] as MobileContextBarModel;
    var mobileViewTitle = mobileContextBar?.Title ?? ViewData["Title"]?.ToString() ?? "VitaRaiz";
    var mobileSearchAction = mobileContextBar?.Actions?.FirstOrDefault(x => string.Equals(x.DataAction, "toggle-sales-search", StringComparison.OrdinalIgnoreCase)
        || string.Equals(x.DataAction, "toggle-cobros-search", StringComparison.OrdinalIgnoreCase)
        || string.Equals(x.Icon, "search", StringComparison.OrdinalIgnoreCase));
    var toastMessage = TempData["AppToastMessage"] as string
        ?? TempData["SalesMessage"] as string
        ?? TempData["CobroMessage"] as string
        ?? TempData["AdminSecurityMessage"] as string
        ?? TempData["MaintenanceMessage"] as string;
    var toastTone = TempData["AppToastTone"] as string ?? "success";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@antiForgeryToken" />
    <meta name="theme-color" content="@themeColor" />
    <title>@ViewData["Title"] - VitaRaizPlus</title>
    <script type="importmap"></script>
    <link rel="manifest" href="~/manifest.webmanifest" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/modules/design-tokens.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/sales.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/collections.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/maintenance.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/administration.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/security.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SalesCobrosGeo.Web.styles.css" asp-append-version="true" />
</head>
<body data-role-theme="@theme" data-authenticated="@(isAuthenticated ? "true" : "false")" data-controller="@currentController.ToLowerInvariant()" data-action="@currentAction.ToLowerInvariant()">
    <div class="app-shell">
        <header class="app-header-shell">
            <nav class="navbar navbar-expand-lg navbar-dark app-topbar">
                <div class="container-fluid app-topbar-inner">
                    @if (isAuthenticated)
                    {
                        <div class="app-mobile-masterbar d-lg-none">
                            <a class="app-mobile-brand" asp-area="" asp-controller="@landingController" asp-action="@landingAction">
                                <span class="app-mobile-brandmark" aria-hidden="true">VR</span>
                                <span class="app-mobile-brandtext">VitaRaiz</span>
                            </a>
                            <div class="app-mobile-viewtitle">@mobileViewTitle</div>
                            <div class="app-mobile-headeractions">
                                @if (mobileSearchAction is not null)
                                {
                                    if (!string.IsNullOrWhiteSpace(mobileSearchAction.Url))
                                    {
                                        <a class="app-mobile-headerbtn" href="@mobileSearchAction.Url" aria-label="@(mobileSearchAction.AriaLabel ?? mobileSearchAction.Label)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <circle cx="11" cy="11" r="7"></circle>
                                                <path d="m20 20-3.5-3.5"></path>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" class="app-mobile-headerbtn" data-context-action="@mobileSearchAction.DataAction" aria-label="@(mobileSearchAction.AriaLabel ?? mobileSearchAction.Label)">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                <circle cx="11" cy="11" r="7"></circle>
                                                <path d="m20 20-3.5-3.5"></path>
                                            </svg>
                                        </button>
                                    }
                                }

                                <button class="app-mobile-headerbtn" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMoreMenu" aria-controls="mobileMoreMenu" aria-label="Abrir menu">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M4 7h16"></path>
                                        <path d="M4 12h16"></path>
                                        <path d="M4 17h16"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }

                    <a class="navbar-brand" asp-area="" asp-controller="@landingController" asp-action="@landingAction">VitaRaizPlus</a>

                    @if (isAuthenticated)
                    {
                        <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMoreMenu" aria-controls="mobileMoreMenu" aria-label="Abrir menu">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                    }

                    <div class="navbar-collapse collapse d-lg-flex justify-content-between">
                        @if (isAuthenticated)
                        {
                            <ul class="navbar-nav app-main-nav">
                                @if (canDashboard)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Dashboard" asp-action="Index"><span class="nav-icon" aria-hidden="true">DA</span><span class="nav-label">Dashboard</span></a>
                                    </li>
                                }
                                @if (canSales)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Sales" ? "active" : string.Empty)" asp-area="" asp-controller="Sales" asp-action="Index"><span class="nav-icon" aria-hidden="true">VE</span><span class="nav-label">Ventas</span></a>
                                    </li>
                                }
                                @if (canCollections)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Cobros" ? "active" : string.Empty)" asp-area="" asp-controller="Cobros" asp-action="Index"><span class="nav-icon" aria-hidden="true">CO</span><span class="nav-label">Cobros</span></a>
                                    </li>
                                }
                                @if (canMaintenance)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Maintenance" ? "active" : string.Empty)" asp-area="" asp-controller="Maintenance" asp-action="Index"><span class="nav-icon" aria-hidden="true">MT</span><span class="nav-label">Mantenimiento</span></a>
                                    </li>
                                }
                                @if (canAdministration)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link text-light @(currentController == "Administration" ? "active" : string.Empty)" asp-area="" asp-controller="Administration" asp-action="Users"><span class="nav-icon" aria-hidden="true">US</span><span class="nav-label">Usuarios</span></a>
                                    </li>
                                }
                            </ul>
                        }

                        <div class="app-user-panel">
                            @if (isAuthenticated)
                            {
                                <div class="app-user-chip">
                                    <strong>@displayName</strong>
                                    <small>@displayRole</small>
                                </div>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="app-logout-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-light">Salir</button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-light" asp-controller="Account" asp-action="Login">Ingresar</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>

            @if (mobileContextBar is not null)
            {
                @await Html.PartialAsync("_MobileContextBar", mobileContextBar)
            }
        </header>

        @if (isAuthenticated)
        {
            <div class="offcanvas offcanvas-end mobile-more-menu" tabindex="-1" id="mobileMoreMenu" aria-labelledby="mobileMoreMenuLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="mobileMoreMenuLabel">Mas accesos</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
                </div>
                <div class="offcanvas-body">
                    <div class="mobile-more-links">
                        @if (canMaintenance)
                        {
                            <a class="mobile-more-link" asp-controller="Maintenance" asp-action="Index"><span class="nav-icon" aria-hidden="true">MT</span><span class="nav-label">Mantenimiento</span></a>
                        }
                        @if (canAdministration)
                        {
                            <a class="mobile-more-link" asp-controller="Administration" asp-action="Users"><span class="nav-icon" aria-hidden="true">US</span><span class="nav-label">Usuarios y permisos</span></a>
                        }
                        @if (canDashboard)
                        {
                            <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Sales"><span class="nav-icon" aria-hidden="true">RV</span><span class="nav-label">Resumen ventas</span></a>
                            <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Collections"><span class="nav-icon" aria-hidden="true">RC</span><span class="nav-label">Resumen cobros</span></a>
                        }
                    </div>
                    <div class="mobile-more-footer">
                        <div class="mobile-more-userchip">
                            <strong>@displayName</strong>
                            <small>@displayRole</small>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="mobile-more-logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="mobile-more-logout">
                                <span class="nav-icon" aria-hidden="true">SL</span>
                                <span class="nav-label">Salir</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(toastMessage))
        {
            <div class="app-toast-host" aria-live="polite" aria-atomic="true">
                <div class="app-toast app-toast-@toastTone" data-auto-toast="true">@toastMessage</div>
            </div>
        }

        <div class="container-fluid app-content app-frame">
            <main role="main" class="pb-3 page-enter app-main">
                @RenderBody()
            </main>
        </div>

        @if (isAuthenticated)
        {
            <nav class="mobile-bottom-nav" aria-label="Menu principal movil">
                @if (canDashboard)
                {
                    <a class="mobile-bottom-link @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">DA</span>
                        <span class="mobile-bottom-text">Panel</span>
                    </a>
                }
                @if (canSales)
                {
                    <a class="mobile-bottom-link @(currentController == "Sales" ? "active" : string.Empty)" asp-controller="Sales" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">VE</span>
                        <span class="mobile-bottom-text">Ventas</span>
                    </a>
                }
                @if (canCollections)
                {
                    <a class="mobile-bottom-link @(currentController == "Cobros" ? "active" : string.Empty)" asp-controller="Cobros" asp-action="Index">
                        <span class="mobile-bottom-icon" aria-hidden="true">CO</span>
                        <span class="mobile-bottom-text">Cobros</span>
                    </a>
                }
            </nav>
        }

        <footer class="border-top footer text-muted">
            <div class="container-fluid app-footer-inner">
                &copy; 2026 - VitaRaizPlus
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
