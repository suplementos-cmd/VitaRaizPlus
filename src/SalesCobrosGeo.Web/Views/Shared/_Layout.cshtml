@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty);
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty);
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VitaRaizPlus</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SalesCobrosGeo.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header>
            <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3 app-topbar">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">VitaRaizPlus</a>
                    <button class="navbar-toggler d-sm-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMoreMenu" aria-controls="mobileMoreMenu" aria-label="Abrir menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <button class="navbar-toggler d-none d-sm-inline-flex" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-light @(currentController == "Home" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light @(currentController == "Sales" ? "active" : string.Empty)" asp-area="" asp-controller="Sales" asp-action="Index">Ventas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light @(currentController == "Cobros" ? "active" : string.Empty)" asp-area="" asp-controller="Cobros" asp-action="Index">Perfil Cobrador</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="offcanvas offcanvas-end mobile-more-menu" tabindex="-1" id="mobileMoreMenu" aria-labelledby="mobileMoreMenuLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="mobileMoreMenuLabel">Mas accesos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>
            <div class="offcanvas-body">
                <div class="mobile-more-links">
                    <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Sales">Resumen ventas</a>
                    <a class="mobile-more-link" asp-controller="Dashboard" asp-action="Collections">Resumen cobros</a>
                    <a class="mobile-more-link" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                </div>
            </div>
        </div>

        <div class="container app-content">
            <main role="main" class="pb-3 page-enter">
                @RenderBody()
            </main>
        </div>

        <nav class="mobile-bottom-nav" aria-label="Menu principal movil">
            <a class="mobile-bottom-link @(currentController == "Home" && currentAction == "Index" ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">
                <span class="mobile-bottom-icon">IN</span>
                <span class="mobile-bottom-text">Inicio</span>
            </a>
            <a class="mobile-bottom-link @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">
                <span class="mobile-bottom-icon">DB</span>
                <span class="mobile-bottom-text">Panel</span>
            </a>
            <a class="mobile-bottom-link @(currentController == "Sales" ? "active" : string.Empty)" asp-controller="Sales" asp-action="Index">
                <span class="mobile-bottom-icon">VT</span>
                <span class="mobile-bottom-text">Ventas</span>
            </a>
            <a class="mobile-bottom-link @(currentController == "Cobros" ? "active" : string.Empty)" asp-controller="Cobros" asp-action="Index">
                <span class="mobile-bottom-icon">CB</span>
                <span class="mobile-bottom-text">Cobros</span>
            </a>
        </nav>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - VitaRaizPlus
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
