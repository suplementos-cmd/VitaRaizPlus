@model SalesCobrosGeo.Web.Models.Administration.AdministrationPageViewModel
@using SalesCobrosGeo.Web.Security
@{
    ViewData["Title"] = "Administracion";
    var editor = Model.Editor.Input;
}

<div class="admin-console-page">
    <section class="admin-console-topbar">
        <div>
            <h1 class="admin-console-title">Usuarios, permisos y seguridad activa</h1>
            <div class="admin-console-subtitle">Gestion compacta para crear, editar, deshabilitar usuarios y vigilar sesiones activas sin ruido visual.</div>
        </div>
        <div class="admin-console-actions">
            <a class="btn btn-primary" asp-action="Users" asp-route-create="true">Agregar usuario</a>
            <a class="btn btn-outline-secondary" asp-action="Audit">Bitacora de auditoria</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="app-toast-inline success">@Model.Message</div>
    }

    <section class="admin-console-summarygrid">
        @foreach (var card in Model.SummaryCards)
        {
            <article class="admin-console-summarycard @card.Tone">
                <span>@card.Label</span>
                <strong>@card.Value</strong>
                <small>@card.Caption</small>
            </article>
        }
        <article class="admin-console-summarycard neutral admin-console-summarycard-link">
            <span>Bitacora</span>
            <strong>@Model.AuditTotal</strong>
            <a asp-action="Audit">Ver eventos</a>
        </article>
    </section>

    <section class="admin-console-layout">
        <div class="admin-console-main">
            <section class="admin-users-section">
                <div class="admin-section-head compact">
                    <div>
                        <h2 class="admin-section-title">Usuarios</h2>
                        <div class="admin-section-subtitle">Listado principal con acciones directas para editar, activar o deshabilitar.</div>
                    </div>
                </div>

                <div class="admin-users-grid-compact">
                    @foreach (var user in Model.Users)
                    {
                        <article class="admin-user-rowcard @(user.Status == "Activo" ? "is-active" : "is-inactive")">
                            <div class="admin-user-rowmain">
                                <div class="admin-user-rowtop">
                                    <div>
                                        <div class="admin-user-rowname">@user.Name</div>
                                        <div class="admin-user-rowusername">@user.Username</div>
                                    </div>
                                    <span class="admin-user-rolepill">@user.RoleCode</span>
                                </div>
                                <div class="admin-user-rowmeta">
                                    <span>Zona: @user.Zone</span>
                                    <span>Tema: @user.Theme</span>
                                    <span>Permisos: @user.PermissionCount</span>
                                    <span>2FA: @(user.TwoFactorEnabled ? "Si" : "No")</span>
                                </div>
                            </div>
                            <div class="admin-user-rowside">
                                <span class="admin-user-statusbadge @(user.Status == "Activo" ? "active" : "inactive")">@user.Status</span>
                                <div class="admin-user-rowactions">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Users" asp-route-editUsername="@user.Username">Editar</a>
                                    <form asp-action="SetUserStatus" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="username" value="@user.Username" />
                                        <input type="hidden" name="isActive" value="@(user.Status == "Activo" ? "false" : "true")" />
                                        <button type="submit" class="btn btn-sm @(user.Status == "Activo" ? "btn-outline-danger" : "btn-outline-success")">@(user.Status == "Activo" ? "Deshabilitar" : "Habilitar")</button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="admin-security-section">
                <div class="admin-section-head compact">
                    <div>
                        <h2 class="admin-section-title">Seguridad activa</h2>
                        <div class="admin-section-subtitle">Sesion, rastreo y control rapido para desconectar o revisar actividad reciente.</div>
                    </div>
                </div>

                <div class="admin-session-listcompact">
                    @foreach (var session in Model.Sessions)
                    {
                        <article class="admin-session-row @(session.IsConnected ? "connected" : session.IsActive ? "idle" : "inactive")">
                            <div class="admin-session-rowmain">
                                <div class="admin-session-rowtop">
                                    <div>
                                        <div class="admin-user-rowname">@session.DisplayName</div>
                                        <div class="admin-user-rowusername">@session.Username • @session.RoleLabel</div>
                                    </div>
                                    <span class="admin-session-badge @(session.IsConnected ? "connected" : session.IsActive ? "idle" : "inactive")">
                                        @(session.IsConnected ? "Conectado" : session.IsActive ? "Sin sesion" : "Inactivo")
                                    </span>
                                </div>
                                <div class="admin-user-rowmeta">
                                    <span>Zona: @session.Zone</span>
                                    <span>Ultima actividad: @session.LastSeen</span>
                                    <span>Ruta: @session.LastPath</span>
                                    <span>IP: @session.LastIp</span>
                                    <span>Coordenadas: @session.LastCoordinates</span>
                                </div>
                            </div>
                            <div class="admin-user-rowactions">
                                <form asp-action="ForceLogout" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="username" value="@session.Username" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Desconectar</button>
                                </form>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Users" asp-route-editUsername="@session.Username">Ver usuario</a>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </div>

        @if (Model.ShowEditor)
        {
            <aside class="admin-editor-dock">
                <div class="admin-section-head compact">
                    <div>
                        <h2 class="admin-section-title">@Model.Editor.Title</h2>
                        <div class="admin-section-subtitle">Completa solo lo necesario y guarda. Los permisos quedan visibles y claros.</div>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Users">Cerrar</a>
                </div>

                <form asp-action="SaveUser" method="post" class="admin-user-form compact">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OriginalUsername" value="@editor.OriginalUsername" />

                    <div class="admin-form-grid compact single">
                        <div>
                            <label class="form-label" for="username">Usuario</label>
                            <input class="form-control" id="username" name="Username" value="@editor.Username" />
                        </div>
                        <div>
                            <label class="form-label" for="displayName">Nombre</label>
                            <input class="form-control" id="displayName" name="DisplayName" value="@editor.DisplayName" />
                        </div>
                        <div>
                            <label class="form-label" for="zone">Zona</label>
                            <input class="form-control" id="zone" name="Zone" value="@editor.Zone" />
                        </div>
                        <div>
                            <label class="form-label" for="theme">Tema</label>
                            <select class="form-select" id="theme" name="Theme">
                                @foreach (var theme in Model.Editor.AvailableThemes)
                                {
                                    if (theme == editor.Theme)
                                    {
                                        <option value="@theme" selected>@theme</option>
                                    }
                                    else
                                    {
                                        <option value="@theme">@theme</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label class="form-label" for="role">Perfil base</label>
                            <select class="form-select" id="role" name="Role">
                                @if (editor.Role == AppRoles.Full) { <option value="@AppRoles.Full" selected>@AppRoles.Full</option> } else { <option value="@AppRoles.Full">@AppRoles.Full</option> }
                                @if (editor.Role == AppRoles.Sales) { <option value="@AppRoles.Sales" selected>@AppRoles.Sales</option> } else { <option value="@AppRoles.Sales">@AppRoles.Sales</option> }
                                @if (editor.Role == AppRoles.Collections) { <option value="@AppRoles.Collections" selected>@AppRoles.Collections</option> } else { <option value="@AppRoles.Collections">@AppRoles.Collections</option> }
                            </select>
                        </div>
                        <div>
                            <label class="form-label" for="password">Contrasena @(string.IsNullOrWhiteSpace(editor.OriginalUsername) ? "inicial" : "nueva")</label>
                            <input class="form-control" id="password" name="Password" type="password" autocomplete="new-password" />
                        </div>
                    </div>

                    <div class="admin-form-switches compact">
                        <label class="admin-check-chip">
                            <input type="hidden" name="IsActive" value="false" />
                            <input type="checkbox" name="IsActive" value="true" @(editor.IsActive ? "checked" : null) />
                            <span>Activo</span>
                        </label>
                        <label class="admin-check-chip">
                            <input type="hidden" name="TwoFactorEnabled" value="false" />
                            <input type="checkbox" name="TwoFactorEnabled" value="true" @(editor.TwoFactorEnabled ? "checked" : null) />
                            <span>2FA requerido</span>
                        </label>
                    </div>

                    <div>
                        <div class="admin-role-block-title mb-2">Permisos por vista</div>
                        <div class="admin-permissions-grid compact single">
                            @foreach (var permission in Model.Editor.AvailablePermissions)
                            {
                                var isChecked = editor.Permissions.Contains(permission);
                                <label class="admin-permission-chip">
                                    <input type="checkbox" name="Permissions" value="@permission" @(isChecked ? "checked" : null) />
                                    <span>@permission</span>
                                </label>
                            }
                        </div>
                    </div>

                    <div class="admin-editor-actions compact">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a class="btn btn-outline-secondary" asp-action="Users" asp-route-create="true">Nuevo</a>
                    </div>
                </form>

                @if (!string.IsNullOrWhiteSpace(editor.Username))
                {
                    <form asp-action="ResetPassword" method="post" class="admin-reset-form compact">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="username" value="@editor.Username" />
                        <div class="admin-role-block-title mb-2">Reset de contrasena</div>
                        <div class="input-group">
                            <input class="form-control" type="password" name="newPassword" placeholder="Nueva contrasena segura" autocomplete="new-password" />
                            <button type="submit" class="btn btn-outline-warning">Reset</button>
                        </div>
                    </form>
                }
            </aside>
        }
    </section>
</div>
