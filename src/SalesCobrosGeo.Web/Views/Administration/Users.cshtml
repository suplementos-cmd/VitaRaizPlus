@model SalesCobrosGeo.Web.Models.Administration.AdministrationPageViewModel
@using SalesCobrosGeo.Web.Models.Shared
@using SalesCobrosGeo.Web.Security
@{
    ViewData["Title"] = "Administracion";
    ViewData["MobileContextBar"] = new MobileContextBarModel(
        "Usuarios",
        "Permisos y seguridad activa",
        null,
        new[]
        {
            new MobileContextAction("Bitacora", "audit", Url: Url.Action("Audit", "Administration"), AriaLabel: "Ver bitacora"),
            new MobileContextAction("Agregar", "add", Url: Url.Action("Users", "Administration", new { create = true }), AriaLabel: "Agregar usuario", CssClass: "is-primary")
        });
    var editor = Model.Editor.Input;
    var themeCatalog = new[]
    {
        new { Code = "root", Name = "Azul ejecutivo", Tone = "#203a72", Accent = "#5f8cff", Surface = "#eef3ff" },
        new { Code = "sales", Name = "Azul claro", Tone = "#2f7dff", Accent = "#8bc2ff", Surface = "#eff7ff" },
        new { Code = "forest", Name = "Verde operativo", Tone = "#1f8a63", Accent = "#64d2a2", Surface = "#edf9f3" },
        new { Code = "sunset", Name = "Rosa comercial", Tone = "#c64d83", Accent = "#f59bc5", Surface = "#fff0f7" },
        new { Code = "collections", Name = "Morado ejecutivo", Tone = "#6d4fd5", Accent = "#b39afc", Surface = "#f3efff" },
        new { Code = "graphite", Name = "Gris profesional", Tone = "#516176", Accent = "#95a6bc", Surface = "#f2f5f8" }
    };
    var selectedTheme = themeCatalog.FirstOrDefault(x => x.Code == editor.Theme) ?? themeCatalog[0];
}

<div class="admin-users-view">
    <div class="admin-console-page">
        <section class="admin-console-topbar compact-only">
            <div>
                <h1 class="admin-console-title">Usuarios, permisos y seguridad activa</h1>
                <div class="admin-console-subtitle">Administracion compacta para trabajar rapido y sin perder contexto.</div>
            </div>
            <div class="admin-console-actions">
                <a class="btn btn-primary" asp-action="Users" asp-route-create="true" data-ajax-link="true" data-ajax-target=".admin-users-view">Agregar usuario</a>
                <a class="btn btn-outline-secondary" asp-action="Audit">Bitacora</a>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="app-toast-inline success">@Model.Message</div>
        }

        <section class="admin-console-summarygrid compact-summary">
            @foreach (var card in Model.SummaryCards)
            {
                <article class="admin-console-summarycard @card.Tone">
                    <span>@card.Label</span>
                    <strong>@card.Value</strong>
                    <small>@card.Caption</small>
                </article>
            }
            <article class="admin-console-summarycard neutral admin-console-summarycard-link">
                <span>Bitacora</span>
                <strong>@Model.AuditTotal</strong>
                <a asp-action="Audit">Ver eventos</a>
            </article>
        </section>

        <section class="admin-console-layout responsive-dense">
            <div class="admin-console-main responsive-dense-grid">
                <section class="admin-users-section compact-shell">
                    <div class="admin-section-head compact">
                        <div>
                            <h2 class="admin-section-title">Usuarios</h2>
                            <div class="admin-section-subtitle">Registros compactos con acciones directas y lectura rapida.</div>
                        </div>
                    </div>

                    <div class="admin-filterline">
                        <div class="admin-filterline-search">
                            <span class="admin-filterline-icon">&#8981;</span>
                            <input id="adminUserSearch" type="search" placeholder="Buscar usuario o nombre" autocomplete="off" />
                        </div>
                        <select id="adminRoleFilter" class="form-select form-select-sm">
                            <option value="">Todos los roles</option>
                            <option value="FULL">FULL</option>
                            <option value="SALES">SALES</option>
                            <option value="COLLECTIONS">COLLECTIONS</option>
                        </select>
                        <select id="adminStatusFilter" class="form-select form-select-sm">
                            <option value="">Todos los estados</option>
                            <option value="ACTIVO">Activo</option>
                            <option value="INACTIVO">Inactivo</option>
                        </select>
                    </div>

                    <div class="admin-users-grid-compact denser">
                        @foreach (var user in Model.Users)
                        {
                            var userSearch = $"{user.Name} {user.Username}".ToUpperInvariant();
                            var userTheme = themeCatalog.FirstOrDefault(x => x.Code == user.Theme);
                            var isProtectedAdmin = user.Username.Equals("RaizAdmin", StringComparison.OrdinalIgnoreCase);
                            <article class="admin-user-rowcard @(user.Status == "Activo" ? "is-active" : "is-inactive")"
                                     data-user-search="@userSearch"
                                     data-user-role="@user.RoleCode.ToUpperInvariant()"
                                     data-user-status="@user.Status.ToUpperInvariant()">
                                <div class="admin-user-rowmain">
                                    <div class="admin-user-rowtop">
                                        <div>
                                            <div class="admin-user-rowname">@user.Name</div>
                                            <div class="admin-user-rowusername">@user.Username</div>
                                        </div>
                                        <div class="admin-user-rowchips">
                                            <span class="admin-user-rolepill">@user.RoleCode</span>
                                            <span class="admin-user-statusbadge @(user.Status == "Activo" ? "active" : "inactive")">@user.Status</span>
                                        </div>
                                    </div>
                                    <div class="admin-user-rowmeta compact-grid">
                                        <span><strong>Zona</strong> @user.Zone</span>
                                        <span>
                                            <strong>Tema</strong>
                                            <span class="admin-theme-chip" style="--theme-chip-tone:@(userTheme?.Tone ?? "#516176"); --theme-chip-accent:@(userTheme?.Accent ?? "#95a6bc"); --theme-chip-surface:@(userTheme?.Surface ?? "#f2f5f8");">
                                                @(userTheme?.Name ?? user.Theme)
                                            </span>
                                        </span>
                                        <span><strong>Permisos</strong> @user.PermissionCount</span>
                                        <span><strong>2FA</strong> @(user.TwoFactorEnabled ? "Si" : "No")</span>
                                        @if (user.RbacActiveRoles > 0 || user.RbacTotalPermissions > 0)
                                        {
                                            <span><strong>Roles RBAC</strong> <span class="badge bg-primary">@user.RbacActiveRoles activos</span></span>
                                            @if (user.RbacTotalPermissions > 0)
                                            {
                                                <span><strong>Permisos Custom</strong> <span class="badge bg-info">@user.RbacTotalPermissions</span></span>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="admin-user-rowactions compact-row">
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Users" asp-route-editUsername="@user.Username" data-ajax-link="true" data-ajax-target=".admin-users-view">Editar</a>
                                    <a class="btn btn-sm btn-outline-info" asp-controller="RbacAdministration" asp-action="UserRoles" asp-route-userName="@user.Username" title="Gestionar roles RBAC">Roles RBAC</a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-controller="RbacAdministration" asp-action="UserPermissions" asp-route-userName="@user.Username" title="Gestionar permisos personalizados">Permisos</a>
                                    <form asp-action="SetUserStatus" method="post" class="admin-status-form admin-inline-toggle-form @(isProtectedAdmin ? "is-locked" : string.Empty)" data-ajaxify="true" data-ajax-target=".admin-users-view">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="username" value="@user.Username" />
                                        <input type="hidden" name="isActive" value="@(user.Status == "Activo" ? "true" : "false")" />
                                        <label class="app-switch admin-status-switch" title="Cambiar estado de usuario">
                                            <input type="checkbox"
                                                   class="app-switch-input"
                                                   @(user.Status == "Activo" ? "checked" : null)
                                                   @(isProtectedAdmin ? "disabled" : null)
                                                   data-toggle-submit="true"
                                                   data-working-label="Procesando..." />
                                            <span class="app-switch-track"></span>
                                            <span class="app-switch-label">@(isProtectedAdmin ? "Siempre activo" : user.Status == "Activo" ? "Activo" : "Inactivo")</span>
                                        </label>
                                    </form>
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <section class="admin-security-section compact-shell">
                    <div class="admin-section-head compact">
                        <div>
                            <h2 class="admin-section-title">Seguridad activa</h2>
                            <div class="admin-section-subtitle">Supervision y control rapido de sesiones activas.</div>
                        </div>
                    </div>

                    <div class="admin-session-listcompact denser">
                        @foreach (var session in Model.Sessions)
                        {
                            <article class="admin-session-row @(session.IsConnected ? "connected" : session.IsActive ? "idle" : "inactive")">
                                <div class="admin-session-rowmain">
                                    <div class="admin-session-rowtop">
                                        <div>
                                            <div class="admin-user-rowname">@session.DisplayName</div>
                                            <div class="admin-user-rowusername">@session.Username � @session.RoleLabel</div>
                                        </div>
                                        <span class="admin-session-badge @(session.IsConnected ? "connected" : session.IsActive ? "idle" : "inactive")">
                                            @(session.IsConnected ? "Conectado" : session.IsActive ? "Sin sesion" : "Inactivo")
                                        </span>
                                    </div>
                                    <div class="admin-user-rowmeta compact-grid">
                                        <span><strong>Zona</strong> @session.Zone</span>
                                        <span><strong>Actividad</strong> @session.LastSeen</span>
                                        <span><strong>Ruta</strong> @session.LastPath</span>
                                        <span><strong>IP</strong> @session.LastIp</span>
                                        <span><strong>GPS</strong> @session.LastCoordinates</span>
                                    </div>
                                </div>
                                <div class="admin-user-rowactions compact-row">
                                    <form asp-action="ForceLogout" method="post" class="admin-status-form" data-ajaxify="true" data-ajax-target=".admin-users-view">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="username" value="@session.Username" />
                                        <button type="submit" class="btn btn-sm admin-status-button btn-outline-warning" data-working-label="Cerrando...">Desconectar</button>
                                    </form>
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Users" asp-route-editUsername="@session.Username" data-ajax-link="true" data-ajax-target=".admin-users-view">Usuario</a>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            </div>
        </section>

        <section class="admin-rbac-quicklink">
            <div class="alert alert-info d-flex align-items-center justify-content-between">
                <div>
                    <strong>Sistema RBAC:</strong> Para gestión avanzada de roles, permisos y asignaciones, visita el módulo completo de RBAC.
                </div>
                <div>
                    <a class="btn btn-sm btn-primary" asp-controller="RbacAdministration" asp-action="Roles">Ir a RBAC</a>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="RbacAdministration" asp-action="UserRoles">Roles Usuarios</a>
                    <a class="btn btn-sm btn-outline-primary" asp-controller="RbacAdministration" asp-action="RolePermissions">Matriz Permisos</a>
                </div>
            </div>
        </section>
    </div>

    @if (Model.ShowEditor)
    {
        <partial name="_UserEditorRbacModal" model="Model.EditorWithRbac" />
    }
</div>

@section Styles {
    <style>
        /* Modal RBAC Styles */
        .admin-editor-dialog-wide {
            max-width: 1000px;
            width: 95%;
        }

        .nav-tabs .nav-link {
            font-weight: 500;
        }

        .rbac-role-row:hover,
        .rbac-permission-row:hover {
            background-color: #f8f9fa;
        }

        .rbac-role-checkbox:checked ~ td {
            background-color: #e7f3ff;
        }

        .admin-theme-help {
            font-size: 0.85rem;
            color: #6c757d;
            margin-top: 0.25rem;
        }

        .sticky-top {
            position: sticky;
            top: 0;
            z-index: 10;
            background: #f8f9fa;
        }
    </style>
}

@section Scripts {
    <script src="~/js/modules/administration-state.js" asp-append-version="true"></script>
    <script>
    (function() {
        'use strict';

        const form = document.getElementById('adminUserRbacForm');
        if (!form) return;

        const rolesCountBadge = document.getElementById('rolesCount');
        const permissionsCountBadge = document.getElementById('permissionsCount');
        const rbacHiddenFields = document.getElementById('rbacHiddenFields');
        const permissionsSearch = document.getElementById('permissionsSearch');

        // ═══════════════════════════════════════════════════════════════════
        // SELECT ALL ROLES
        // ═══════════════════════════════════════════════════════════════════
        document.getElementById('selectAllRoles')?.addEventListener('change', function(e) {
            document.querySelectorAll('.rbac-role-checkbox').forEach(cb => {
                cb.checked = e.target.checked;
            });
            updateCounts();
        });

        // ═══════════════════════════════════════════════════════════════════
        // UPDATE COUNTS ON CHECKBOX/SELECT CHANGE
        // ═══════════════════════════════════════════════════════════════════
        document.querySelectorAll('.rbac-role-checkbox').forEach(cb => {
            cb.addEventListener('change', updateCounts);
        });

        document.querySelectorAll('.rbac-permission-action').forEach(select => {
            select.addEventListener('change', updateCounts);
        });

        function updateCounts() {
            const rolesChecked = document.querySelectorAll('.rbac-role-checkbox:checked').length;
            const permissionsSet = Array.from(document.querySelectorAll('.rbac-permission-action'))
                .filter(s => s.value !== 'none').length;

            rolesCountBadge.textContent = rolesChecked;
            permissionsCountBadge.textContent = permissionsSet;
        }

        // ═══════════════════════════════════════════════════════════════════
        // SEARCH PERMISSIONS
        // ═══════════════════════════════════════════════════════════════════
        permissionsSearch?.addEventListener('input', function(e) {
            const search = e.target.value.toUpperCase();
            document.querySelectorAll('.rbac-permission-row').forEach(row => {
                const searchText = row.dataset.search || '';
                row.style.display = searchText.includes(search) ? '' : 'none';
            });
        });

        // ═══════════════════════════════════════════════════════════════════
        // FORM SUBMISSION - BUILD RBAC PAYLOAD
        // ═══════════════════════════════════════════════════════════════════
        form.addEventListener('submit', function(e) {
            // Clear previous hidden fields
            rbacHiddenFields.innerHTML = '';

            // Build RbacRoles array
            let roleIndex = 0;
            document.querySelectorAll('.rbac-role-checkbox:checked').forEach(cb => {
                const roleId = cb.dataset.roleId;
                const startDate = document.querySelector(`.rbac-role-start[data-role-id="${roleId}"]`)?.value || '';
                const endDate = document.querySelector(`.rbac-role-end[data-role-id="${roleId}"]`)?.value || '';

                rbacHiddenFields.innerHTML += `
                    <input type="hidden" name="RbacRoles[${roleIndex}].RoleId" value="${roleId}" />
                    <input type="hidden" name="RbacRoles[${roleIndex}].StartDate" value="${startDate}" />
                    <input type="hidden" name="RbacRoles[${roleIndex}].EndDate" value="${endDate}" />
                `;
                roleIndex++;
            });

            // Build CustomPermissions array
            let permIndex = 0;
            document.querySelectorAll('.rbac-permission-action').forEach(select => {
                if (select.value === 'none') return;

                const permissionId = select.dataset.permissionId;
                const isGranted = select.value === 'grant';
                const startDate = document.querySelector(`.rbac-permission-start[data-permission-id="${permissionId}"]`)?.value || '';
                const endDate = document.querySelector(`.rbac-permission-end[data-permission-id="${permissionId}"]`)?.value || '';

                rbacHiddenFields.innerHTML += `
                    <input type="hidden" name="CustomPermissions[${permIndex}].PermissionId" value="${permissionId}" />
                    <input type="hidden" name="CustomPermissions[${permIndex}].IsGranted" value="${isGranted}" />
                    <input type="hidden" name="CustomPermissions[${permIndex}].StartDate" value="${startDate}" />
                    <input type="hidden" name="CustomPermissions[${permIndex}].EndDate" value="${endDate}" />
                `;
                permIndex++;
            });

            // Debug logging
            const hiddenInputs = rbacHiddenFields.querySelectorAll('input[type="hidden"]');
            const payloadDebug = {
                rolesCount: roleIndex,
                permissionsCount: permIndex,
                totalHiddenInputs: hiddenInputs.length,
                hiddenFieldNames: Array.from(hiddenInputs).map(i => i.name),
                hiddenFieldValues: Array.from(hiddenInputs).map(i => ({ name: i.name, value: i.value }))
            };
            
            console.log('═══ RBAC Payload Debug ═══');
            console.log('Roles:', roleIndex);
            console.log('Permissions:', permIndex);
            console.log('Total hidden inputs:', hiddenInputs.length);
            console.log('Field names:', payloadDebug.hiddenFieldNames);
            console.log('Full payload:', payloadDebug);
            console.log('═══════════════════════════');
        });

        // ═══════════════════════════════════════════════════════════════════
        // ROLE THEME SUGGESTION (legacy feature)
        // ═══════════════════════════════════════════════════════════════════
        document.querySelectorAll('[data-role-theme-suggest]').forEach(btn => {
            btn.addEventListener('click', function() {
                const roleSelect = document.getElementById('role');
                const themeSelect = document.getElementById('theme');
                const selectedOption = roleSelect.options[roleSelect.selectedIndex];
                const suggestedTheme = selectedOption.dataset.defaultTheme;

                if (suggestedTheme) {
                    themeSelect.value = suggestedTheme;
                    const themeOption = themeSelect.options[themeSelect.selectedIndex];
                    updateThemePreview(themeOption);
                }
            });
        });

        function updateThemePreview(themeOption) {
            const dialog = document.querySelector('.admin-editor-dialog');
            if (dialog && themeOption) {
                dialog.style.setProperty('--admin-theme-tone', themeOption.dataset.themeTone);
                dialog.style.setProperty('--admin-theme-accent', themeOption.dataset.themeAccent);
                dialog.style.setProperty('--admin-theme-surface', themeOption.dataset.themeSurface);
            }
        }

        // Initial count
        updateCounts();
    })();
    </script>
}
