@using SalesCobrosGeo.Web.Models.Shared
@model SalesCobrosGeo.Web.Models.Administration.AuditDetailViewModel
@{
    ViewData["Title"] = "Detalle auditoria";
    ViewData["MobileContextBar"] = new MobileContextBarModel(Model.EventType, "Detalle del evento", Url.Action("Audit", "Administration"));
}

<div class="admin-console-page admin-audit-page">
    <section class="admin-console-topbar">
        <div>
            <h1 class="admin-console-title">@Model.EventType</h1>
            <div class="admin-console-subtitle">Detalle completo del evento seleccionado con su traza operativa y metadata persistida.</div>
        </div>
        <div class="admin-console-actions">
            <a class="btn btn-outline-secondary" asp-action="Audit">Volver a bitacora</a>
        </div>
    </section>

    <section class="admin-audit-detail-grid">
        <article class="admin-audit-detail-card">
            <div class="admin-audit-detail-label">Usuario</div>
            <strong>@Model.Username</strong>
        </article>
        <article class="admin-audit-detail-card">
            <div class="admin-audit-detail-label">Fecha</div>
            <strong>@Model.Timestamp</strong>
        </article>
        <article class="admin-audit-detail-card">
            <div class="admin-audit-detail-label">Ruta</div>
            <strong>@Model.Path</strong>
        </article>
        <article class="admin-audit-detail-card">
            <div class="admin-audit-detail-label">Coordenadas</div>
            <strong>@Model.Coordinates</strong>
        </article>
    </section>

    <section class="admin-users-table-shell compact-shell">
        <div class="admin-section-head compact">
            <div>
                <h2 class="admin-section-title">Descripcion del evento</h2>
                <div class="admin-section-subtitle">Texto y metadata almacenados en la bitacora.</div>
            </div>
        </div>
        <div class="admin-audit-detail-body">@Model.Description</div>
        <div class="admin-audit-detail-body secondary">@Model.Metadata</div>
    </section>
</div>


