@model SalesCobrosGeo.Web.Models.Maintenance.MaintenancePageViewModel
@{
    ViewData["Title"] = "Mantenimiento";
    var current = Model.Sections.First(x => x.Key == Model.SelectedSection);
    var editableSection = new[] { "zonas", "dias-cobro", "formas-pago", "productos", "vendedores", "cobradores" }
        .Contains(Model.SelectedSection, StringComparer.OrdinalIgnoreCase);

    string ToneClass(string tone) => tone switch
    {
        "success" => "maintenance-badge success",
        "warning" => "maintenance-badge warning",
        "danger" => "maintenance-badge danger",
        _ => "maintenance-badge brand"
    };

    string RowClass(bool active) => active ? "maintenance-row" : "maintenance-row inactive";
}

<div class="maintenance-compact-page">
    <section class="maintenance-titlebar">
        <div>
            <h1 class="maintenance-compact-title">Mantenimiento</h1>
            <div class="maintenance-compact-subtitle">Gestion compacta de catalogos y equipo operativo.</div>
        </div>
        @if (editableSection)
        {
            <a class="btn btn-primary maintenance-add-btn" asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-create="true" data-ajax-link="true" data-ajax-target=".maintenance-compact-page">Agregar</a>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="app-toast-inline success">@Model.Message</div>
    }

    <section class="maintenance-summary-cards">
        @foreach (var stat in Model.Stats)
        {
            <article class="maintenance-summary-card @stat.Tone">
                <small>@stat.Title</small>
                <strong>@stat.Value</strong>
            </article>
        }
    </section>

    <nav class="maintenance-top-tabs" aria-label="Catalogos">
        @foreach (var navItem in Model.Sections)
        {
            <a class="maintenance-tab @(navItem.Key == Model.SelectedSection ? "active" : string.Empty)"
               asp-action="Index"
               asp-route-section="@navItem.Key"
               data-ajax-link="true"
               data-ajax-target=".maintenance-compact-page">
                <span>@navItem.Title</span>
                <small>@navItem.Items.Count</small>
            </a>
        }
    </nav>

    <section class="maintenance-section-strip">
        <div>
            <h2 class="maintenance-section-title compact">@current.Title</h2>
            <div class="maintenance-section-subtitle compact">@current.Subtitle</div>
        </div>
        <div class="maintenance-section-summary compact">@current.Summary</div>
    </section>

    <section class="maintenance-rows-layout @(Model.ShowEditor ? "with-editor" : string.Empty)">
        <div class="maintenance-rows-panel">
            @if (current.Items.Count == 0)
            {
                <div class="app-empty-state compact">
                    <strong>Sin registros todavia</strong>
                    <span>Cuando agregues registros apareceran aqui en formato compacto.</span>
                </div>
            }
            else
            {
                <div class="maintenance-row-head">
                    <span>Nombre</span>
                    <span>Codigo</span>
                    <span>Detalle</span>
                    <span>Estatus</span>
                    <span>Acciones</span>
                </div>
                <div class="maintenance-rows-grid">
                    @foreach (var item in current.Items)
                    {
                        <article class="@RowClass(item.IsActive)">
                            <div class="maintenance-row-main">
                                <strong>@item.Name</strong>
                                <small>@item.Code</small>
                            </div>
                            <div class="maintenance-row-code">@item.Code</div>
                            <div class="maintenance-row-detail">@item.Detail</div>
                            <div class="maintenance-row-status">
                                <span class="@ToneClass(item.Tone)">@item.Badge</span>
                            </div>
                            <div class="maintenance-row-actions">
                                @if (editableSection)
                                {
                                    <form asp-action="ToggleStatus" method="post" data-ajaxify="true" data-ajax-target=".maintenance-compact-page">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="section" value="@Model.SelectedSection" />
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")">@(item.IsActive ? "Inhabilitar" : "Habilitar")</button>
                                    </form>
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@item.Id" data-ajax-link="true" data-ajax-target=".maintenance-compact-page">Editar</a>
                                }
                                else if (Model.SelectedSection == "empleados")
                                {
                                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Administration" asp-action="Users" asp-route-editUsername="@item.Code">Usuario</a>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-section="productos">Ver</a>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </div>

        @if (editableSection && Model.ShowEditor)
        {
            <aside class="maintenance-side-editor">
                <div class="maintenance-editor-titlebar">
                    <div>
                        <div class="maintenance-editor-caption">@(Model.Editor.Id is > 0 ? "Editar registro" : "Nuevo registro")</div>
                        <h3>@current.Title</h3>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-section="@Model.SelectedSection" data-ajax-link="true" data-ajax-target=".maintenance-compact-page">Cerrar</a>
                </div>

                <form asp-action="Save" method="post" class="maintenance-editor-form compact" data-ajaxify="true" data-ajax-target=".maintenance-compact-page">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Section" value="@Model.SelectedSection" />
                    <input type="hidden" name="Id" value="@Model.Editor.Id" />

                    <div>
                        <label class="form-label" for="maintenanceCode">Codigo</label>
                        <input class="form-control" id="maintenanceCode" name="Code" value="@Model.Editor.Code" />
                    </div>

                    <div>
                        <label class="form-label" for="maintenanceName">Nombre</label>
                        <input class="form-control" id="maintenanceName" name="Name" value="@Model.Editor.Name" />
                    </div>

                    @if (Model.SelectedSection == "productos")
                    {
                        <div>
                            <label class="form-label" for="maintenancePrice">Precio base</label>
                            <input class="form-control" id="maintenancePrice" name="Price" type="number" step="0.01" min="0" value="@Model.Editor.Price" />
                        </div>
                    }

                    <label class="admin-check-chip maintenance-check-chip">
                        <input type="hidden" name="IsActive" value="false" />
                        <input type="checkbox" name="IsActive" value="true" @(Model.Editor.IsActive ? "checked" : null) />
                        <span>Activo para operacion</span>
                    </label>

                    <div class="maintenance-editor-actions compact">
                        <button type="submit" class="btn btn-primary">Guardar</button>
                        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-section="@Model.SelectedSection" data-ajax-link="true" data-ajax-target=".maintenance-compact-page">Cancelar</a>
                    </div>
                </form>
            </aside>
        }
    </section>
</div>
