<div class="maint-page">

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="app-toast-inline success">@Model.Message</div>
}

@*
 ═══════════════════════════════════════════════════════════════
 MOBILE / TABLET SHELL  (hidden ≥992px via CSS)
 State:  catalogos → list → detail → editor
 ═══════════════════════════════════════════════════════════════
*@
<div class="maint-m">

    @* State 0 — Section picker *@
    @if (isAtRoot)
    {
        <div class="maint-m-sections">
            @foreach (var sec in Model.Sections.Where(x => x.Key != "catalogos"))
            {
                <a class="maint-m-scard"
                   asp-action="Index" asp-route-section="@sec.Key"
                   data-ajax-link="true" data-ajax-target=".maint-page">
                    <span class="maint-m-scard-icon @sec.Key" aria-hidden="true">@Html.Raw(SectionIcon(sec.Key))</span>
                    <span class="maint-m-scard-text">
                        <strong>@sec.Title</strong>
                        <small>@sec.Subtitle</small>
                    </span>
                    <span class="maint-m-scard-count">@sec.Items.Count</span>
                    <svg class="maint-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                    </svg>
                </a>
            }
        </div>
    }

    @* State 1 — Compact item rows list *@
    else if (isAtList)
    {
        if (current.Items.Count == 0)
        {
            <div class="maint-empty">
                <svg class="maint-empty-icon" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                    <circle cx="24" cy="24" r="22" fill="currentColor" opacity=".06"/>
                    <path d="M15 18h18M15 24h12M15 30h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <strong>Sin registros todavía</strong>
                <span>Cuando agregues registros aparecerán aquí.</span>
                @if (editableSection)
                {
                    <a class="btn btn-primary btn-sm"
                       asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-create="true"
                       data-ajax-link="true" data-ajax-target=".maint-page">Agregar primero</a>
                }
            </div>
        }
        else
        {
            <div class="maint-m-list">
                @foreach (var item in current.Items)
                {
                    <a class="maint-m-row @(!item.IsActive ? "inactive" : string.Empty)"
                       asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-viewId="@item.Id"
                       data-ajax-link="true" data-ajax-target=".maint-page">
                        <span class="maint-code-pill">@item.Code</span>
                        <span class="maint-m-row-body">
                            <strong>@item.Name</strong>
                            <small>@item.Detail</small>
                        </span>
                        <span class="@BadgeClass(item.Tone)">@item.Badge</span>
                        <svg class="maint-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                        </svg>
                    </a>
                }
            </div>
        }
    }

    @* State 2 — Item detail *@
    else if (isAtDetail && viewItem != null)
    {
        <div class="maint-m-detail">
            <div class="maint-m-detail-card">
                <div class="maint-m-detail-top">
                    <span class="maint-m-detail-icon @current.Key" aria-hidden="true">@Html.Raw(SectionIcon(current.Key))</span>
                    <div>
                        <strong class="maint-m-detail-name">@viewItem.Name</strong>
                        <span class="maint-code-pill">@viewItem.Code</span>
                    </div>
                    <span class="@BadgeClass(viewItem.Tone)">@viewItem.Badge</span>
                </div>
                <div class="maint-m-detail-fields">
                    <div class="maint-m-detail-field"><label>Código</label><span>@viewItem.Code</span></div>
                    <div class="maint-m-detail-field"><label>Nombre</label><span>@viewItem.Name</span></div>
                    <div class="maint-m-detail-field"><label>Detalle</label><span>@viewItem.Detail</span></div>
                    <div class="maint-m-detail-field">
                        <label>Estado</label>
                        <span class="@BadgeClass(viewItem.Tone)">@viewItem.Badge</span>
                    </div>
                </div>
            </div>
            <div class="maint-m-detail-actions">
                @if (editableSection)
                {
                    <form asp-action="ToggleStatus" method="post"
                          class="maintenance-toggle-form admin-inline-toggle-form"
                          data-ajaxify="true" data-ajax-target=".maint-page">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="section"  value="@Model.SelectedSection" />
                        <input type="hidden" name="id"       value="@viewItem.Id" />
                        <input type="hidden" name="isActive" value="@(viewItem.IsActive ? "true" : "false")" />
                        <label class="app-switch maintenance-status-switch" title="Cambiar estado">
                            <input type="checkbox" class="app-switch-input"
                                   @(viewItem.IsActive ? "checked" : null)
                                   data-toggle-submit="true" data-working-label="Procesando..." />
                            <span class="app-switch-track"></span>
                            <span class="app-switch-label">@(viewItem.IsActive ? "Activo" : "Inactivo")</span>
                        </label>
                    </form>
                    <a class="btn btn-primary"
                       asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@viewItem.Id"
                       data-ajax-link="true" data-ajax-target=".maint-page">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="width:15px;height:15px">
                            <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z"/>
                            <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0010 3H4.75A2.75 2.75 0 002 5.75v9.5A2.75 2.75 0 004.75 18h9.5A2.75 2.75 0 0017 15.25V10a.75.75 0 00-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z"/>
                        </svg>
                        Editar
                    </a>
                }
                else if (Model.SelectedSection == "empleados")
                {
                    <a class="btn btn-outline-secondary"
                       asp-controller="Administration" asp-action="Users" asp-route-editUsername="@viewItem.Code">
                        Ver usuario
                    </a>
                }
            </div>
        </div>
    }

    @* State 3 — Editor form *@
    else if (isAtEditor)
    {
        <div class="maint-m-editor">
            <div class="maint-m-editor-head">
                <div class="maint-editor-caption">@(Model.Editor.Id is > 0 ? "Editar registro" : "Nuevo registro")</div>
                <h2 class="maint-m-editor-title">@current.Title</h2>
            </div>
            <form asp-action="Save" method="post"
                  class="maint-editor-form" data-ajaxify="true" data-ajax-target=".maint-page">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Section" value="@Model.SelectedSection" />
                <input type="hidden" name="Id" value="@Model.Editor.Id" />
                
                @* Campos dinámicos *@
                @foreach (var field in Model.Editor.Fields.OrderBy(f => 
                    f.Key == "Code" || f.Key == "UserName" ? 0 : 
                    f.Key == "Name" || f.Key == "Label" || f.Key == "DisplayName" ? 1 : 
                    f.Key == "IsActive" ? 999 : 
                    2))
                {
                    var fieldType = GetFieldType(field.Key, field.Value);
                    var fieldName = "Field_" + field.Key;
                    var fieldLabel = FormatFieldLabel(field.Key);
                    var isReadonly = readonlyCodeSection && field.Key == "Code";
                    
                    if (fieldType == "checkbox")
                    {
                        <label class="admin-check-chip maintenance-check-chip">
                            <input type="hidden" name="@fieldName" value="false" />
                            <input type="checkbox" name="@fieldName" value="true" @(field.Value is bool b && b ? "checked" : null) />
                            <span>@fieldLabel</span>
                        </label>
                    }
                    else
                    {
                        <div>
                            <label class="form-label" for="@fieldName">@fieldLabel</label>
                            @if (fieldType == "number")
                            {
                                <input class="form-control" id="@fieldName" name="@fieldName"
                                       type="number" step="0.01" value="@field.Value" @(isReadonly ? "readonly" : null) />
                            }
                            else if (field.Key.Contains("Svg", StringComparison.OrdinalIgnoreCase) || field.Value?.ToString()?.Length > 100)
                            {
                                <textarea class="form-control" id="@fieldName" name="@fieldName" rows="3" @(isReadonly ? "readonly" : null)>@field.Value</textarea>
                            }
                            else
                            {
                                <input class="form-control" id="@fieldName" name="@fieldName"
                                       value="@field.Value" @(isReadonly ? "readonly" : null) />
                            }
                        </div>
                    }
                }
                
                <div class="maint-editor-actions">
                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <a class="btn btn-outline-secondary" href="@cancelUrl"
                       data-ajax-link="true" data-ajax-target=".maint-page">Cancelar</a>
                </div>
            </form>
        </div>
    }

</div>
@* /maint-m *@

@*
 ═══════════════════════════════════════════════════════════════
 DESKTOP SHELL  (hidden ≤991px via CSS)
 Cards overview + main panel + optional sticky detail/editor aside
 ═══════════════════════════════════════════════════════════════
*@
<div class="maint-d">

    @* ── Content body: single panel or split ──────────────── *@
    <div class="maint-d-body @(desktopSplit ? "split" : string.Empty)">

        @* Main panel *@
        <section class="maint-d-panel">
            <div class="maint-d-panel-head maint-d-panel-head-enhanced">
                <div class="maint-d-panel-head-left">
                    <span class="maint-d-panel-icon @current.Key" aria-hidden="true">@Html.Raw(SectionIcon(current.Key))</span>
                    <div class="maint-d-panel-text">
                        <h2 class="maint-d-panel-title">@current.Title</h2>
                        <p class="maint-d-panel-sub">@current.Subtitle</p>
                    </div>
                </div>
                @if (editableSection)
                {
                    <a class="btn btn-sm btn-primary maint-d-add-btn"
                       asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-create="true"
                       data-ajax-link="true" data-ajax-target=".maint-page">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/></svg>
                        Agregar
                    </a>
                }
            </div>

            @if (isAtRoot)
            {
                @* Section overview ─ CARD GRID *@
                <div class="maint-d-overview-grid">
                    @foreach (var sec in Model.Sections.Where(x => x.Key != "catalogos"))
                    {
                        <a class="maint-d-overview-card @sec.Key"
                           asp-action="Index" asp-route-section="@sec.Key"
                           data-ajax-link="true" data-ajax-target=".maint-page">
                            <div class="maint-d-overview-card-icon">
                                <span class="maint-d-overview-icon-box @sec.Key" aria-hidden="true">@Html.Raw(SectionIcon(sec.Key))</span>
                            </div>
                            <div class="maint-d-overview-card-body">
                                <h3 class="maint-d-overview-card-title">@sec.Title</h3>
                                <p class="maint-d-overview-card-sub">@sec.Subtitle</p>
                                <div class="maint-d-overview-card-count">
                                    <span>@sec.Items.Count</span>
                                    <small>registro@(sec.Items.Count != 1 ? "s" : "")</small>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else if (current.Items.Count == 0)
            {
                <div class="maint-empty">
                    <svg class="maint-empty-icon" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                        <circle cx="24" cy="24" r="22" fill="currentColor" opacity=".06"/>
                        <path d="M15 18h18M15 24h12M15 30h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    <strong>Sin registros todavía</strong>
                    <span>Cuando agregues registros aparecerán aquí.</span>
                    @if (editableSection)
                    {
                        <a class="btn btn-primary btn-sm"
                           asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-create="true"
                           data-ajax-link="true" data-ajax-target=".maint-page">Agregar primero</a>
                    }
                </div>
            }
            else
            {
                @* Item cards grid – click body→detail, hover icon→edit *@
                <div class="maint-d-cards">
                    @foreach (var item in current.Items)
                    {
                        bool isSelected = Model.ViewItemId == item.Id || (Model.ShowEditor && Model.Editor.Id == item.Id);

                        string cardBodyHref;
                        bool cardBodyAjax;
                        if (editableSection)
                        {
                            cardBodyHref = Url.Action("Index", "Maintenance", new { section = Model.SelectedSection, viewId = item.Id }) ?? "#";
                            cardBodyAjax = true;
                        }
                        else if (Model.SelectedSection == "empleados")
                        {
                            cardBodyHref = Url.Action("Users", "Administration", new { editUsername = item.Code }) ?? "#";
                            cardBodyAjax = false;
                        }
                        else if (catalogSectionMap.TryGetValue(item.Code, out var dSec))
                        {
                            cardBodyHref = Url.Action("Index", "Maintenance", new { section = dSec }) ?? "#";
                            cardBodyAjax = true;
                        }
                        else
                        {
                            cardBodyHref = "#"; cardBodyAjax = false;
                        }

                        <article class="maint-d-card @(!item.IsActive ? "inactive" : string.Empty) @(isSelected ? "selected" : string.Empty)">
                            <a class="maint-d-card-body" href="@cardBodyHref"
                               @(cardBodyAjax ? Html.Raw("data-ajax-link=\"true\" data-ajax-target=\".maint-page\"") : null)>
                                <div class="maint-d-card-top">
                                    <span class="maint-code-pill">@item.Code</span>
                                    <span class="@BadgeClass(item.Tone)">@item.Badge</span>
                                </div>
                                <strong class="maint-d-card-name">@item.Name</strong>
                                <p class="maint-d-card-detail">@item.Detail</p>
                            </a>
                            @if (editableSection)
                            {
                                <a class="maint-d-card-editbtn"
                                   asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@item.Id"
                                   data-ajax-link="true" data-ajax-target=".maint-page"
                                   title="Editar @item.Name" aria-label="Editar">
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z"/>
                                        <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0010 3H4.75A2.75 2.75 0 002 5.75v9.5A2.75 2.75 0 004.75 18h9.5A2.75 2.75 0 0017 15.25V10a.75.75 0 00-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z"/>
                                    </svg>
                                </a>
                            }
                        </article>
                    }
                </div>
            }
        </section>

        @* Detail/editor aside – rendered only when desktopSplit *@
        @if (desktopSplit)
        {
            <aside class="maint-d-detail">
                @if (Model.ShowEditor)
                {
                    @* Editor pane *@
                    <div class="maint-d-aside-head">
                        <div>
                            <div class="maint-editor-caption">@(Model.Editor.Id is > 0 ? "Editar registro" : "Nuevo registro")</div>
                            <h3 class="maint-d-aside-title">@current.Title</h3>
                        </div>
                        <div class="maint-d-aside-head-btns">
                            @* Prev/Next navigation *@
                            @if (prevItemId.HasValue || nextItemId.HasValue)
                            {
                                <div class="maint-d-nav-arrows">
                                    @if (prevItemId.HasValue)
                                    {
                                        <a class="maint-d-nav-arrow"
                                           asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@prevItemId"
                                           data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Anterior">
                                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    { <span class="maint-d-nav-arrow disabled"></span> }
                                    @if (nextItemId.HasValue)
                                    {
                                        <a class="maint-d-nav-arrow"
                                           asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@nextItemId"
                                           data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Siguiente">
                                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    { <span class="maint-d-nav-arrow disabled"></span> }
                                </div>
                            }
                            <a class="maint-d-aside-close" href="@cancelUrl"
                               data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Cerrar">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                    @* Quick section navigator *@
                    <div class="maint-d-quick-sections">
                        @foreach (var sec in Model.Sections.Where(x => x.Key != "catalogos"))
                        {
                            <a class="maint-d-quick-sec @(sec.Key == Model.SelectedSection ? "active" : string.Empty) @sec.Key"
                               asp-action="Index" asp-route-section="@sec.Key"
                               data-ajax-link="true" data-ajax-target=".maint-page"
                               title="@sec.Title">
                                <span class="maint-d-quick-sec-icon" aria-hidden="true">@Html.Raw(SectionIcon(sec.Key))</span>
                            </a>
                        }
                    </div>
                    <form asp-action="Save" method="post"
                          class="maint-editor-form" data-ajaxify="true" data-ajax-target=".maint-page">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Section" value="@Model.SelectedSection" />
                        <input type="hidden" name="Id" value="@Model.Editor.Id" />
                        
                        @* Campos dinámicos *@
                        @foreach (var field in Model.Editor.Fields.OrderBy(f => f.Key == "Code" ? 0 : f.Key == "Name" || f.Key == "Label" ? 1 : 2))
                        {
                            var fieldType = GetFieldType(field.Key, field.Value);
                            var fieldName = "Field_" + field.Key;
                            var fieldLabel = FormatFieldLabel(field.Key);
                            var isReadonly = readonlyCodeSection && field.Key == "Code";
                            
                            if (fieldType == "checkbox")
                            {
                                <label class="admin-check-chip maintenance-check-chip">
                                    <input type="hidden" name="@fieldName" value="false" />
                                    <input type="checkbox" name="@fieldName" value="true" @(field.Value is bool b && b ? "checked" : null) />
                                    <span>@fieldLabel</span>
                                </label>
                            }
                            else
                            {
                                <div>
                                    <label class="form-label" for="d@field.Key">@fieldLabel</label>
                                    @if (fieldType == "number")
                                    {
                                        <input class="form-control" id="d@field.Key" name="@fieldName"
                                               type="number" step="0.01" value="@field.Value" @(isReadonly ? "readonly" : null) />
                                    }
                                    else if (field.Key.Contains("Svg", StringComparison.OrdinalIgnoreCase) || field.Value?.ToString()?.Length > 100)
                                    {
                                        <textarea class="form-control" id="d@field.Key" name="@fieldName" rows="3" @(isReadonly ? "readonly" : null)>@field.Value</textarea>
                                    }
                                    else
                                    {
                                        <input class="form-control" id="d@field.Key" name="@fieldName"
                                               value="@field.Value" @(isReadonly ? "readonly" : null) />
                                    }
                                </div>
                            }
                        }
                        
                        <div class="maint-editor-actions">
                            <button type="submit" class="btn btn-primary">Guardar</button>
                            <a class="btn btn-outline-secondary" href="@cancelUrl"
                               data-ajax-link="true" data-ajax-target=".maint-page">Cancelar</a>
                        </div>
                    </form>
                }
                else if (viewItem != null)
                {
                    @* Detail pane *@
                    <div class="maint-d-aside-head">
                        <div>
                            <div class="maint-editor-caption">Detalle</div>
                            <h3 class="maint-d-aside-title">@viewItem.Name</h3>
                        </div>
                        <div class="maint-d-aside-head-btns">
                            @* Prev/Next navigation *@
                            @if (prevItemId.HasValue || nextItemId.HasValue)
                            {
                                <div class="maint-d-nav-arrows">
                                    @if (prevItemId.HasValue)
                                    {
                                        <a class="maint-d-nav-arrow"
                                           asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-viewId="@prevItemId"
                                           data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Anterior">
                                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd"/>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    { <span class="maint-d-nav-arrow disabled"></span> }
                                    @if (nextItemId.HasValue)
                                    {
                                        <a class="maint-d-nav-arrow"
                                           asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-viewId="@nextItemId"
                                           data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Siguiente">
                                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/>
                                            </svg>
                                        </a>
                                    }
                                    else
                                    { <span class="maint-d-nav-arrow disabled"></span> }
                                </div>
                            }
                            @if (editableSection)
                            {
                                <a class="btn btn-sm btn-primary"
                                   asp-action="Index" asp-route-section="@Model.SelectedSection" asp-route-editId="@viewItem.Id"
                                   data-ajax-link="true" data-ajax-target=".maint-page">
                                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="width:14px;height:14px">
                                        <path d="M5.433 13.917l1.262-3.155A4 4 0 017.58 9.42l6.92-6.918a2.121 2.121 0 013 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 01-.65-.65z"/>
                                        <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0010 3H4.75A2.75 2.75 0 002 5.75v9.5A2.75 2.75 0 004.75 18h9.5A2.75 2.75 0 0017 15.25V10a.75.75 0 00-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z"/>
                                    </svg>
                                    Editar
                                </a>
                            }
                            <a class="maint-d-aside-close"
                               asp-action="Index" asp-route-section="@Model.SelectedSection"
                               data-ajax-link="true" data-ajax-target=".maint-page" aria-label="Cerrar">
                                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                    <div class="maint-d-detail-body">
                        <div class="maint-d-detail-fields">
                            <div class="maint-d-detail-field"><label>Código</label><span class="maint-code-pill">@viewItem.Code</span></div>
                            <div class="maint-d-detail-field"><label>Nombre</label><span>@viewItem.Name</span></div>
                            <div class="maint-d-detail-field"><label>Detalle</label><span>@viewItem.Detail</span></div>
                            <div class="maint-d-detail-field">
                                <label>Estado</label>
                                <span class="@BadgeClass(viewItem.Tone)">@viewItem.Badge</span>
                            </div>
                        </div>
                        @if (editableSection)
                        {
                            <div class="maint-d-detail-toggle">
                                <form asp-action="ToggleStatus" method="post"
                                      class="maintenance-toggle-form admin-inline-toggle-form"
                                      data-ajaxify="true" data-ajax-target=".maint-page">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="section"  value="@Model.SelectedSection" />
                                    <input type="hidden" name="id"       value="@viewItem.Id" />
                                    <input type="hidden" name="isActive" value="@(viewItem.IsActive ? "true" : "false")" />
                                    <label class="app-switch maintenance-status-switch" title="Cambiar estado">
                                        <input type="checkbox" class="app-switch-input"
                                               @(viewItem.IsActive ? "checked" : null)
                                               data-toggle-submit="true" data-working-label="Procesando..." />
                                        <span class="app-switch-track"></span>
                                        <span class="app-switch-label">@(viewItem.IsActive ? "Activo" : "Inactivo")</span>
                                    </label>
                                </form>
                            </div>
                        }
                        else if (Model.SelectedSection == "empleados")
                        {
                            <div class="maint-d-detail-toggle">
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-controller="Administration" asp-action="Users" asp-route-editUsername="@viewItem.Code">
                                    Ver usuario
                                </a>
                            </div>
                        }
                    </div>
                }
            </aside>
        }

    </div>
    @* /maint-d-body *@

</div>
@* /maint-d *@

</div>
@* /maint-page *@

@section Scripts {
    <script src="~/js/modules/maintenance-state.js" asp-append-version="true"></script>
}
