    string StatIcon(int i) => i switch
    {
        0 => """<svg viewBox="0 0 20 20" fill="currentColor"><path d="M3 4a1 1 0 00-1 1v1a1 1 0 001 1h14a1 1 0 001-1V5a1 1 0 00-1-1H3zM3 9a1 1 0 00-1 1v1a1 1 0 001 1h14a1 1 0 001-1v-1a1 1 0 00-1-1H3zM3 14a1 1 0 00-1 1v1a1 1 0 001 1h14a1 1 0 001-1v-1a1 1 0 00-1-1H3z"/></svg>""",
