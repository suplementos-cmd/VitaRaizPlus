@using SalesCobrosGeo.Web.Models.Shared
@model SalesCobrosGeo.Web.Models.Maintenance.MaintenancePageViewModel
@{
    ViewData["Title"] = "Mantenimiento";
    var current = Model.Sections.First(x => x.Key == Model.SelectedSection);
    var editableSection = new[] { "zonas", "dias-cobro", "formas-pago", "productos", "vendedores", "cobradores", "estatus-venta", "estatus-cobro-grupos", "menu-items", "tipos-catalogo", "config-ui" }
        .Contains(Model.SelectedSection, StringComparer.OrdinalIgnoreCase);
    var readonlyCodeSection = Model.SelectedSection.Equals("estatus-cobro-grupos", StringComparison.OrdinalIgnoreCase);

    // Helper para determinar tipo de campo basado en nombre de columna
    string GetFieldType(string fieldName, object? value)
    {
        if (fieldName.Contains("Price", StringComparison.OrdinalIgnoreCase) || 
            fieldName.Contains("Amount", StringComparison.OrdinalIgnoreCase))
            return "number";
        if (fieldName.Contains("Sort", StringComparison.OrdinalIgnoreCase) || 
            fieldName.Contains("Priority", StringComparison.OrdinalIgnoreCase) || 
            fieldName.Contains("Order", StringComparison.OrdinalIgnoreCase))
            return "number";
        if (value is int || value is long || value is decimal || value is double)
            return "number";
        if (value is bool)
            return "checkbox";
        return "text";
    }

    string FormatFieldLabel(string fieldName)
    {
        // Convertir CamelCase a palabras separadas
        var result = System.Text.RegularExpressions.Regex.Replace(fieldName, "([A-Z])", " $1").Trim();
        return char.ToUpper(result[0]) + result.Substring(1);
    }

    // Resolve the item being viewed (detail panel)
    var viewItem = Model.ViewItemId.HasValue
        ? current.Items.FirstOrDefault(x => x.Id == Model.ViewItemId.Value)
        : null;

    // ─── State machine flags ────────────────────────────────────────
    var isAtRoot   = Model.SelectedSection == "catalogos";
    var isAtList   = !isAtRoot && viewItem == null && !Model.ShowEditor;
    var isAtDetail = !isAtRoot && viewItem != null && !Model.ShowEditor;
    var isAtEditor = !isAtRoot && Model.ShowEditor;
    var desktopSplit = !isAtRoot && (Model.ViewItemId.HasValue || Model.ShowEditor);

    // ─── Prev/Next navigation (for detail/editor aside) ────────────
    int currentIndex = -1;
    long? prevItemId = null;
    long? nextItemId = null;
    if ((isAtDetail || isAtEditor) && !isAtRoot && current.Items.Count > 1)
    {
        var targetId = isAtDetail ? viewItem?.Id : Model.Editor.Id;
        if (targetId.HasValue && targetId.Value > 0)
        {
            var itemWithIndex = current.Items
                .Select((item, idx) => new { item, idx })
                .FirstOrDefault(x => x.item.Id == targetId.Value);
            
            if (itemWithIndex != null)
            {
                currentIndex = itemWithIndex.idx;
                if (currentIndex > 0)
                    prevItemId = current.Items[currentIndex - 1].Id;
                if (currentIndex < current.Items.Count - 1)
                    nextItemId = current.Items[currentIndex + 1].Id;
            }
        }
    }

    // ─── Catalog section map (for overview → section nav) ──────────
    var catalogSectionMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["ZON"]  = "zonas",     ["DIA"]  = "dias-cobro",         ["PAG"]  = "formas-pago",
        ["PRO"]  = "productos", ["VEN"]  = "vendedores",         ["COB"]  = "cobradores",
        ["ESTV"] = "estatus-venta", ["ESTC"] = "estatus-cobro-grupos", 
        ["MENU"] = "menu-items", ["TIPO"] = "tipos-catalogo",    ["UI"]   = "config-ui",
        ["EMP"] = "empleados"
    };

    // ─── Cancel URL for editor (desktop + mobile) ──────────────────
    var cancelUrl = Model.Editor.Id is > 0
        ? Url.Action("Index", "Maintenance", new { section = Model.SelectedSection, viewId = Model.Editor.Id })
        : Url.Action("Index", "Maintenance", new { section = Model.SelectedSection });

    // ─── Mobile layout bar setup ────────────────────────────────────
    string? mobileBackUrl =
        isAtList   ? Url.Action("Index", "Maintenance", new { section = "catalogos" })
        : isAtDetail ? Url.Action("Index", "Maintenance", new { section = Model.SelectedSection })
        : isAtEditor  ? cancelUrl
        : null;

    MobileContextAction[]? mobileActions =
        isAtList && editableSection
            ? new[] { new MobileContextAction("Agregar", "add",
                Url: Url.Action("Index", "Maintenance", new { section = Model.SelectedSection, create = true }),
                AriaLabel: "Agregar registro", CssClass: "is-primary") }
        : isAtDetail && editableSection && viewItem != null
            ? new[] { new MobileContextAction("Editar", "edit",
                Url: Url.Action("Index", "Maintenance", new { section = Model.SelectedSection, editId = viewItem.Id }),
                AriaLabel: "Editar registro") }
        : null;

    ViewData["MobileContextBar"] = new MobileContextBarModel(
        isAtRoot ? "Mantenimiento" : current.Title,
        isAtRoot ? "Catálogos"
            : isAtDetail && viewItem != null ? viewItem.Name
            : isAtEditor ? (Model.Editor.Id is > 0 ? "Editar registro" : "Nuevo registro")
            : current.Subtitle,
        mobileBackUrl,
        mobileActions);

    string BadgeClass(string tone) => tone switch
    {
        "success" => "maint-badge success",
        "warning" => "maint-badge warning",
        "danger"  => "maint-badge danger",
        _         => "maint-badge brand"
    };

