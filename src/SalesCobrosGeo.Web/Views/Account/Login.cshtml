@model SalesCobrosGeo.Web.Models.Security.LoginViewModel
@{
    ViewData["Title"] = "Ingreso seguro";
}

<div class="security-auth-shell">
    <section class="security-auth-card">
        <div class="security-auth-brand">
            <span class="security-brand-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
                    <path d="M12 22V12"/><path d="M12 12C12 7 17 3 22 3c0 5-4 9-10 9z"/><path d="M12 12C12 7 7 3 2 3c0 5 4 9 10 9z"/>
                </svg>
            </span>
            <span class="security-brand-name">VitaRaizPlus</span>
        </div>

        <div class="security-auth-head">
            <div class="security-auth-eyebrow">Acceso protegido</div>
            <h1 class="security-auth-title">Bienvenido</h1>
            <p class="security-auth-subtitle">Ingresa tus credenciales para acceder al sistema de ventas y cobros.</p>
        </div>

        <form asp-action="Login" method="post" class="security-auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="security-field">
                <label asp-for="Username" class="form-label">Usuario</label>
                <div class="security-input-wrap">
                    <svg class="security-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    <input asp-for="Username" class="form-control form-control-lg security-input-field" autocomplete="username" placeholder="usuario.demo" />
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="security-field">
                <label asp-for="Password" class="form-label">Contrase&ntilde;a</label>
                <div class="security-input-wrap">
                    <svg class="security-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                    <input asp-for="Password" class="form-control form-control-lg security-input-field" autocomplete="current-password" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label class="form-check security-remember">
                <input asp-for="RememberMe" class="form-check-input" />
                <span class="form-check-label">Mantener sesi&oacute;n activa en este equipo</span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg w-100 security-submit-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Entrar al sistema
            </button>
        </form>
    </section>

    <aside class="security-hint-card">
        <div class="security-hint-header">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
            <div>
                <div class="security-hint-title">Credenciales iniciales</div>
                <div class="security-hint-subtitle">Cuentas semilla para iniciar el proyecto.</div>
            </div>
        </div>

        <div class="security-hint-list">
            @foreach (var hint in Model.Hints)
            {
                <article class="security-hint-item">
                    <div class="security-hint-role">@hint.RoleLabel</div>
                    <strong>@hint.Username</strong>
                    <div class="security-hint-password">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="13" height="13" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        @hint.Password
                    </div>
                    <p>@hint.Summary</p>
                </article>
            }
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
