@model SalesCobrosGeo.Web.Models.Security.LoginViewModel
@{
    ViewData["Title"] = "Ingreso seguro";
}

<div class="security-auth-shell">
    <section class="security-auth-card">
        <div class="security-auth-head">
            <div class="security-auth-eyebrow">Acceso protegido</div>
            <h1 class="security-auth-title">Ingresar al sistema</h1>
            <p class="security-auth-subtitle">Autenticacion por usuario, contrasena y permisos por modulo. Todo el contenido operativo queda protegido por cookie segura y control de cache.</p>
        </div>

        <form asp-action="Login" method="post" class="security-auth-form">
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="security-field">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control form-control-lg" autocomplete="username" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="security-field">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <label class="form-check security-remember">
                <input asp-for="RememberMe" class="form-check-input" />
                <span class="form-check-label">Mantener sesion activa en este equipo</span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg w-100">Entrar</button>
        </form>
    </section>

    <aside class="security-hint-card">
        <div class="security-hint-title">Credenciales iniciales</div>
        <div class="security-hint-subtitle">Estas cuentas son semilla para iniciar el proyecto. Lo siguiente ideal es migrarlas a base de datos y obligar cambio de contrasena.</div>

        <div class="security-hint-list">
            @foreach (var hint in Model.Hints)
            {
                <article class="security-hint-item">
                    <div class="security-hint-role">@hint.RoleLabel</div>
                    <strong>@hint.Username</strong>
                    <div class="security-hint-password">@hint.Password</div>
                    <p>@hint.Summary</p>
                </article>
            }
        </div>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
