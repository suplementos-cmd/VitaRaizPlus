@model SalesCobrosGeo.Web.Models.Dashboard.DashboardPageViewModel
@{
    ViewData["Title"] = "Dashboard";

    var salesDayPeak = Math.Max(1m, Model.WeeklySales.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.DailySummary("", "", 0, 0m)).Max(x => (decimal)x.Count));
    var collectionDayPeak = Math.Max(1m, Model.WeeklyCollections.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.DailySummary("", "", 0, 0m)).Max(x => x.Amount));
    var salesZonePeak = Math.Max(1m, Model.SalesByZone.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => (decimal)x.Count));
    var collectionsZonePeak = Math.Max(1m, Model.CollectionsByZone.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => x.Amount));
    var collectionsCollectorPeak = Math.Max(1m, Model.CollectionsByCollector.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => x.Amount));
}

<div class="admin-dashboard">
    <section class="dashboard-filter-bar mb-4">
        <form method="get" class="dashboard-period-form">
            <div class="dashboard-period-controls compact">
                <div class="dashboard-period-scope">
                    <a class="period-chip @(Model.Period.Scope == "week" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="week" asp-route-offset="0">Semana</a>
                    <a class="period-chip @(Model.Period.Scope == "month" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="month" asp-route-offset="0">Mes</a>
                </div>
                <div class="dashboard-period-nav compact">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@(Model.Period.Offset - 1)">Anterior</a>
                    <div class="dashboard-period-current compact">
                        <strong>@Model.Period.Label</strong>
                        <span>@Model.Period.Subtitle</span>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@(Model.Period.Offset + 1)">Siguiente</a>
                </div>
            </div>
        </form>
    </section>

    <section class="dashboard-chart-grid">
        <article class="card admin-panel dashboard-chart-panel">
            <div class="card-header admin-panel-head dashboard-chart-head">
                <div>
                    <div class="dashboard-panel-total-label">Total ventas</div>
                    <strong class="dashboard-panel-total-value">Bs @Model.WeeklySales.Sum(x => x.Amount).ToString("0,0.##")</strong>
                </div>
                <a class="btn btn-sm btn-outline-primary" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-bars-wrap">
                    <div class="dashboard-bars dashboard-bars-scroll">
                        @foreach (var item in Model.WeeklySales)
                        {
                            var pct = item.Count <= 0 ? 8m : Math.Max(10m, ((decimal)item.Count / salesDayPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-day="@item.Key">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag">@item.Count</span>
                                    <div class="dashboard-bar-fill sales" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label">@item.Label</div>
                                <div class="dashboard-bar-meta">@item.Count ventas</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </article>

        <article class="card admin-panel dashboard-chart-panel">
            <div class="card-header admin-panel-head dashboard-chart-head">
                <div>
                    <div class="dashboard-panel-total-label">Total cobros</div>
                    <strong class="dashboard-panel-total-value">Bs @Model.WeeklyCollections.Sum(x => x.Amount).ToString("0,0.##")</strong>
                </div>
                <a class="btn btn-sm btn-outline-primary" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="day">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-bars-wrap">
                    <div class="dashboard-bars dashboard-bars-scroll">
                        @foreach (var item in Model.WeeklyCollections)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionDayPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="day" asp-route-day="@item.Key">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collections" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label">@item.Label</div>
                                <div class="dashboard-bar-meta">Bs @item.Amount.ToString("0")</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </article>

        <article class="card admin-panel dashboard-chart-panel">
            <div class="card-header admin-panel-head dashboard-chart-head">
                <div>
                    <div class="dashboard-panel-total-label">Total ventas por zona</div>
                    <strong class="dashboard-panel-total-value">@Model.SalesByZone.Sum(x => x.Count) ventas</strong>
                </div>
                <a class="btn btn-sm btn-outline-primary" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-bars-wrap">
                    <div class="dashboard-bars dashboard-bars-scroll wide-labels">
                        @foreach (var item in Model.SalesByZone)
                        {
                            var pct = item.Count <= 0 ? 8m : Math.Max(10m, ((decimal)item.Count / salesZonePeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-zone="@item.Key">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag">@item.Count</span>
                                    <div class="dashboard-bar-fill sales" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                                <div class="dashboard-bar-meta">@item.Count ventas</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </article>

        <article class="card admin-panel dashboard-chart-panel">
            <div class="card-header admin-panel-head dashboard-chart-head">
                <div>
                    <div class="dashboard-panel-total-label">Total cobros por zona</div>
                    <strong class="dashboard-panel-total-value">Bs @Model.CollectionsByZone.Sum(x => x.Amount).ToString("0,0.##")</strong>
                </div>
                <a class="btn btn-sm btn-outline-primary" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="zone">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-bars-wrap">
                    <div class="dashboard-bars dashboard-bars-scroll wide-labels">
                        @foreach (var item in Model.CollectionsByZone)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionsZonePeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="zone" asp-route-value="@item.Key">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collections" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                                <div class="dashboard-bar-meta">Bs @item.Amount.ToString("0")</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </article>

        <article class="card admin-panel dashboard-chart-panel dashboard-chart-panel-full">
            <div class="card-header admin-panel-head dashboard-chart-head">
                <div>
                    <div class="dashboard-panel-total-label">Total cobros por cobrador</div>
                    <strong class="dashboard-panel-total-value">Bs @Model.CollectionsByCollector.Sum(x => x.Amount).ToString("0,0.##")</strong>
                </div>
                <a class="btn btn-sm btn-outline-primary" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="collector">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-bars-wrap">
                    <div class="dashboard-bars dashboard-bars-scroll wide-labels collectors">
                        @foreach (var item in Model.CollectionsByCollector)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionsCollectorPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="collector" asp-route-value="@item.Key">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collector" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                                <div class="dashboard-bar-meta">Bs @item.Amount.ToString("0")</div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </article>
    </section>
</div>
