@model SalesCobrosGeo.Web.Models.Dashboard.DashboardPageViewModel
@{
    ViewData["Title"] = "Dashboard";
    var salesPeak = Math.Max(1m, Model.SellerSummaries.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.SellerPerformanceSummary("", 0, 0, 0m)).Max(x => x.TotalAmount));
    var collectionsPeak = Math.Max(1m, Model.CollectionSummaries.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => x.Amount));

    string ToneClass(string tone) => tone switch
    {
        "success" => "dashboard-kpi success",
        "warning" => "dashboard-kpi warning",
        "danger" => "dashboard-kpi danger",
        _ => "dashboard-kpi brand"
    };

    string GroupLabel(string grouping) => grouping switch
    {
        "collector" => "cobrador",
        "day" => "dia",
        _ => "zona"
    };
}

<div class="admin-dashboard">
    <section class="admin-hero mb-4">
        <div>
            <div class="admin-eyebrow">Administrador</div>
            <h1 class="admin-title">Dashboard operativo</h1>
            <div class="admin-subtitle">Totales por periodo, ventas por vendedora y cobros segmentados para navegar al detalle</div>
        </div>
        <div class="admin-hero-stats">
            <form method="get" class="dashboard-period-form">
                <input type="hidden" name="collectionsBy" value="@Model.CollectionGrouping" />
                <div class="dashboard-period-controls">
                    <div class="dashboard-period-scope">
                        <a class="period-chip @(Model.Period.Scope == "week" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="week" asp-route-offset="0" asp-route-collectionsBy="@Model.CollectionGrouping">Semana</a>
                        <a class="period-chip @(Model.Period.Scope == "month" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="month" asp-route-offset="0" asp-route-collectionsBy="@Model.CollectionGrouping">Mes</a>
                    </div>
                    <div class="dashboard-period-nav">
                        <a class="btn btn-sm btn-outline-light" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@(Model.Period.Offset - 1)" asp-route-collectionsBy="@Model.CollectionGrouping">Anterior</a>
                        <div class="dashboard-period-current">
                            <strong>@Model.Period.Label</strong>
                            <span>@Model.Period.Subtitle</span>
                        </div>
                        <a class="btn btn-sm btn-outline-light" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@(Model.Period.Offset + 1)" asp-route-collectionsBy="@Model.CollectionGrouping">Siguiente</a>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="admin-kpis mb-4">
        @foreach (var card in Model.Kpis)
        {
            <article class="@ToneClass(card.Tone)">
                <div class="dashboard-kpi-title">@card.Title</div>
                <div class="dashboard-kpi-value">@card.Value</div>
                <div class="dashboard-kpi-trend">@card.Trend</div>
            </article>
        }
    </section>

    <section class="admin-grid mb-4">
        <article class="card admin-panel">
            <div class="card-header admin-panel-head">
                <span>Ventas por vendedora</span>
                <a class="btn btn-sm btn-outline-primary" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset">Ver detalle</a>
            </div>
            <div class="card-body">
                <div class="dashboard-summary-list">
                    @if (Model.SellerSummaries.Count == 0)
                    {
                        <div class="text-muted text-center">Sin ventas en este periodo.</div>
                    }
                    else
                    {
                        @foreach (var row in Model.SellerSummaries)
                        {
                            var pct = row.TotalAmount <= 0 ? 8m : Math.Max(10m, (row.TotalAmount / salesPeak) * 100m);
                            <a class="dashboard-summary-card" asp-action="Sales" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-seller="@row.Seller">
                                <div class="dashboard-summary-top">
                                    <div>
                                        <div class="dashboard-summary-title">@row.Seller</div>
                                        <div class="dashboard-summary-meta">@row.TotalSales ventas • @row.ClosedSales cerradas</div>
                                    </div>
                                    <div class="dashboard-summary-amount">Bs @row.TotalAmount.ToString("0,0.##")</div>
                                </div>
                                <div class="dashboard-inline-bar"><div class="dashboard-inline-fill sales" style="width:@pct%"></div></div>
                            </a>
                        }
                    }
                </div>
            </div>
        </article>

        <article class="card admin-panel">
            <div class="card-header admin-panel-head">
                <span>Cobros por @GroupLabel(Model.CollectionGrouping)</span>
                <div class="dashboard-group-switches">
                    <a class="period-chip @(Model.CollectionGrouping == "zone" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="zone">Zona</a>
                    <a class="period-chip @(Model.CollectionGrouping == "collector" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="collector">Cobrador</a>
                    <a class="period-chip @(Model.CollectionGrouping == "day" ? "active" : string.Empty)" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="day">Dia</a>
                </div>
            </div>
            <div class="card-body">
                <div class="dashboard-summary-list">
                    @if (Model.CollectionSummaries.Count == 0)
                    {
                        <div class="text-muted text-center">Sin cobros en este periodo.</div>
                    }
                    else
                    {
                        @foreach (var row in Model.CollectionSummaries)
                        {
                            var pct = row.Amount <= 0 ? 8m : Math.Max(10m, (row.Amount / collectionsPeak) * 100m);
                            <a class="dashboard-summary-card" asp-action="Collections" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="@Model.CollectionGrouping" asp-route-value="@row.Key">
                                <div class="dashboard-summary-top">
                                    <div>
                                        <div class="dashboard-summary-title">@row.Label</div>
                                        <div class="dashboard-summary-meta">@row.Count movimientos</div>
                                    </div>
                                    <div class="dashboard-summary-amount">Bs @row.Amount.ToString("0,0.##")</div>
                                </div>
                                <div class="dashboard-inline-bar"><div class="dashboard-inline-fill collections" style="width:@pct%"></div></div>
                            </a>
                        }
                    }
                </div>
            </div>
        </article>
    </section>
</div>
