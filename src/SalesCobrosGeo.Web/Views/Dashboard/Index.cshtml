@using SalesCobrosGeo.Web.Models.Shared
@model SalesCobrosGeo.Web.Models.Dashboard.DashboardPageViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["MobileContextBar"] = new MobileContextBarModel(
        "Dashboard",
        $"{Model.Period.Start:dd/MM} - {Model.Period.End:dd/MM}",
        null,
        new[] { new MobileContextAction("Filtros", "filter", DataAction: "focus-dashboard-filter", AriaLabel: "Ir a filtros") });

    var salesDayPeak = Math.Max(1m, Model.WeeklySales.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.DailySummary("", "", 0, 0m)).Max(x => (decimal)x.Count));
    var collectionDayPeak = Math.Max(1m, Model.WeeklyCollections.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.DailySummary("", "", 0, 0m)).Max(x => x.Amount));
    var salesZonePeak = Math.Max(1m, Model.SalesByZone.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => (decimal)x.Count));
    var collectionsZonePeak = Math.Max(1m, Model.CollectionsByZone.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => x.Amount));
    var collectionsCollectorPeak = Math.Max(1m, Model.CollectionsByCollector.DefaultIfEmpty(new SalesCobrosGeo.Web.Models.Dashboard.CollectionGroupingSummary("", "", 0, 0m)).Max(x => x.Amount));
}

<div class="admin-dashboard dashboard-shell">
    <aside class="dashboard-sidebar-shell">
        <section class="dashboard-filter-bar dashboard-filter-panel">
            <div class="dashboard-filter-title">Filtros</div>
            <div class="dashboard-filter-copy">Selecciona el rango y navega el resumen administrativo.</div>
            <form method="get" class="dashboard-period-form compact-range-form" data-ajaxify="true" data-ajax-target=".dashboard-shell">
                <div class="compact-range-line compact-range-stack">
                    <div class="compact-range-field">
                        <label for="from">Inicio</label>
                        <input id="from" name="from" type="date" class="form-control form-control-sm" value="@Model.Period.Start.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="compact-range-field">
                        <label for="to">Fin</label>
                        <input id="to" name="to" type="date" class="form-control form-control-sm" value="@Model.Period.End.ToString("yyyy-MM-dd")" />
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary compact-range-btn">Aplicar</button>
                </div>
            </form>
        </section>
    </aside>

    <div class="dashboard-main-shell">
        <section class="dashboard-chart-grid">
            <article class="card admin-panel dashboard-chart-panel">
                <div class="card-header admin-panel-head dashboard-chart-head">
                    <div class="dashboard-panel-header-wrap">
                        <span class="dashboard-panel-icon dashboard-panel-icon--sales" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M15.5 2A1.5 1.5 0 0014 3.5v13a1.5 1.5 0 003 0v-13A1.5 1.5 0 0015.5 2zM9.5 6A1.5 1.5 0 008 7.5v9a1.5 1.5 0 003 0v-9A1.5 1.5 0 009.5 6zM3.5 10A1.5 1.5 0 002 11.5v5a1.5 1.5 0 003 0v-5A1.5 1.5 0 003.5 10z"/></svg>
                        </span>
                        <div>
                            <div class="dashboard-panel-total-label">Total ventas</div>
                            <strong class="dashboard-panel-total-value">Bs @Model.WeeklySales.Sum(x => x.Amount).ToString("0,0.##")</strong>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary dashboard-detail-btn" asp-action="Sales" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" title="Ver todas las ventas"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg><span class="btn-text-mobile">Ventas</span></a>
                </div>
                <div class="card-body">
                    <div class="dashboard-bars-fit" style="--bar-count:@Math.Max(1, Model.WeeklySales.Count)">
                        @foreach (var item in Model.WeeklySales)
                        {
                            var pct = item.Count <= 0 ? 8m : Math.Max(10m, ((decimal)item.Count / salesDayPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Sales" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-day="@item.Key" title="Ver ventas del @item.Label">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag plain">@item.Count</span>
                                    <div class="dashboard-bar-fill sales" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label">@item.Label</div>
                            </a>
                        }
                    </div>
                </div>
            </article>

            <article class="card admin-panel dashboard-chart-panel">
                <div class="card-header admin-panel-head dashboard-chart-head">
                    <div class="dashboard-panel-header-wrap">
                        <span class="dashboard-panel-icon dashboard-panel-icon--collections" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.75-11.25a.75.75 0 00-1.5 0v.67l-.046.008C7.472 7.696 6.25 9.048 6.25 10.7c0 1.68 1.25 3.02 3 3.26v1.29a.75.75 0 001.5 0v-1.29c1.75-.24 3-1.58 3-3.26v-.007c0-1.652-1.222-3.004-2.954-3.272L10.75 7.42v-.67zm-1.5 1.726l-.092.015C7.846 8.687 7.25 9.608 7.25 10.7c0 1.09.6 2.013 1.908 2.21l.092.014V9.476zm1.5.04v3.01l.092-.015C12.15 12.713 12.75 11.79 12.75 10.7v-.007c0-1.086-.597-2.007-1.908-2.21l-.092-.016z" clip-rule="evenodd"/></svg>
                        </span>
                        <div>
                            <div class="dashboard-panel-total-label">Total cobros</div>
                            <strong class="dashboard-panel-total-value">Bs @Model.WeeklyCollections.Sum(x => x.Amount).ToString("0,0.##")</strong>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary dashboard-detail-btn" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="day" title="Ver todos los cobros"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg><span class="btn-text-mobile">Cobros</span></a>
                </div>
                <div class="card-body">
                    <div class="dashboard-bars-fit" style="--bar-count:@Math.Max(1, Model.WeeklyCollections.Count)">
                        @foreach (var item in Model.WeeklyCollections)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionDayPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="day" asp-route-day="@item.Key" title="Ver cobros del @item.Label">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag plain money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collections" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label">@item.Label</div>
                            </a>
                        }
                    </div>
                </div>
            </article>

            <article class="card admin-panel dashboard-chart-panel">
                <div class="card-header admin-panel-head dashboard-chart-head">
                    <div class="dashboard-panel-header-wrap">
                        <span class="dashboard-panel-icon dashboard-panel-icon--sales" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/></svg>
                        </span>
                        <div>
                            <div class="dashboard-panel-total-label">Total ventas por zona</div>
                            <strong class="dashboard-panel-total-value">@Model.SalesByZone.Sum(x => x.Count) ventas</strong>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary dashboard-detail-btn" asp-action="Sales" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" title="Ver ventas por zona"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg><span class="btn-text-mobile">Ventas</span></a>
                </div>
                <div class="card-body">
                    <div class="dashboard-bars-fit" style="--bar-count:@Math.Max(1, Model.SalesByZone.Count)">
                        @foreach (var item in Model.SalesByZone)
                        {
                            var pct = item.Count <= 0 ? 8m : Math.Max(10m, ((decimal)item.Count / salesZonePeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Sales" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-zone="@item.Key" title="Ver ventas en @item.Label">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag plain">@item.Count</span>
                                    <div class="dashboard-bar-fill sales" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                            </a>
                        }
                    </div>
                </div>
            </article>

            <article class="card admin-panel dashboard-chart-panel">
                <div class="card-header admin-panel-head dashboard-chart-head">
                    <div class="dashboard-panel-header-wrap">
                        <span class="dashboard-panel-icon dashboard-panel-icon--collections" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/></svg>
                        </span>
                        <div>
                            <div class="dashboard-panel-total-label">Total cobros por zona</div>
                            <strong class="dashboard-panel-total-value">Bs @Model.CollectionsByZone.Sum(x => x.Amount).ToString("0,0.##")</strong>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary dashboard-detail-btn" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="zone" title="Ver cobros por zona"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg><span class="btn-text-mobile">Cobros</span></a>
                </div>
                <div class="card-body">
                    <div class="dashboard-bars-fit" style="--bar-count:@Math.Max(1, Model.CollectionsByZone.Count)">
                        @foreach (var item in Model.CollectionsByZone)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionsZonePeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="zone" asp-route-value="@item.Key" title="Ver cobros en @item.Label">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag plain money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collections" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                            </a>
                        }
                    </div>
                </div>
            </article>

            <article class="card admin-panel dashboard-chart-panel dashboard-chart-panel-full">
                <div class="card-header admin-panel-head dashboard-chart-head">
                    <div class="dashboard-panel-header-wrap">
                        <span class="dashboard-panel-icon dashboard-panel-icon--collector" aria-hidden="true">
                            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M7 8a3 3 0 100-6 3 3 0 000 6zM14.5 9a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM1.615 16.428a1.224 1.224 0 01-.569-1.175 6.002 6.002 0 0111.908 0c.058.467-.172.92-.57 1.174A9.953 9.953 0 017 17a9.953 9.953 0 01-5.385-1.572zM14.5 16h-.106c.07-.297.088-.611.048-.933a7.47 7.47 0 00-1.588-3.755 4.502 4.502 0 015.874 2.636.818.818 0 01-.36.98A7.465 7.465 0 0114.5 16z"/></svg>
                        </span>
                        <div>
                            <div class="dashboard-panel-total-label">Total cobros por cobrador</div>
                            <strong class="dashboard-panel-total-value">Bs @Model.CollectionsByCollector.Sum(x => x.Amount).ToString("0,0.##")</strong>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary dashboard-detail-btn" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="collector" title="Ver cobros por vendedor"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg><span class="btn-text-mobile">Cobros</span></a>
                </div>
                <div class="card-body">
                    <div class="dashboard-bars-fit" style="--bar-count:@Math.Max(1, Model.CollectionsByCollector.Count)">
                        @foreach (var item in Model.CollectionsByCollector)
                        {
                            var pct = item.Amount <= 0 ? 8m : Math.Max(10m, (item.Amount / collectionsCollectorPeak) * 100m);
                            <a class="dashboard-bar-item dashboard-bar-card" asp-action="Collections" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")" asp-route-collectionsBy="collector" asp-route-value="@item.Key" title="Ver cobros de @item.Label">
                                <div class="dashboard-bar-track">
                                    <span class="dashboard-bar-tag plain money">@item.Amount.ToString("0")</span>
                                    <div class="dashboard-bar-fill collector" style="height:@pct%"></div>
                                </div>
                                <div class="dashboard-bar-label zone">@item.Label</div>
                            </a>
                        }
                    </div>
                </div>
            </article>
        </section>
    </div>
</div>


