@model SalesCobrosGeo.Web.Models.Dashboard.DashboardPageViewModel
@{
    ViewData["Title"] = "Cobros";
    var value = Context.Request.Query["value"].ToString();
    var day = Context.Request.Query["day"].ToString();

    string StatusClass(string status) => status.ToUpperInvariant() switch
    {
        "LIQUIDADO" => "status-chip status-done",
        "AL CORRIENTE" => "status-chip status-current",
        "ATRASADO" => "status-chip status-late",
        "POR INICIAR" => "status-chip status-start",
        _ => "status-chip"
    };

    string GroupLabel(string grouping) => grouping switch
    {
        "collector" => "cobrador",
        "day" => "dia",
        _ => "zona"
    };
}

<div class="admin-list-page">
    <div class="admin-list-topbar">
        <div>
            <h1 class="admin-list-title">Cobros por @GroupLabel(Model.CollectionGrouping)</h1>
            <div class="admin-list-subtitle">
                Periodo: @Model.Period.Label
                @(string.IsNullOrWhiteSpace(value) ? string.Empty : $" • {value}")
                @(string.IsNullOrWhiteSpace(day) ? string.Empty : $" • {DateTime.Parse(day).ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-ES"))}")
            </div>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-scope="@Model.Period.Scope" asp-route-offset="@Model.Period.Offset" asp-route-collectionsBy="@Model.CollectionGrouping">Volver al dashboard</a>
    </div>

    <div class="admin-record-list">
        @if (Model.Collections.Count == 0)
        {
            <div class="card card-body text-center text-muted">Sin cobros para esta seleccion.</div>
        }
        else
        {
            @foreach (var row in Model.Collections)
            {
                <article class="admin-record-card">
                    <div>
                        <div class="admin-record-title">@row.ClientName</div>
                        <div class="admin-record-meta">@row.SaleNumber</div>
                        <div class="admin-record-meta">@row.Collector • @row.Zone • @row.DayLabel</div>
                    </div>
                    <div>
                        <div class="admin-record-amount">Bs @row.Collected.ToString("0.##")</div>
                        <div class="admin-record-meta">Pendiente Bs @row.Pending.ToString("0.##")</div>
                    </div>
                    <div class="@StatusClass(row.Status)">@row.Status</div>
                </article>
            }
        }
    </div>
</div>
