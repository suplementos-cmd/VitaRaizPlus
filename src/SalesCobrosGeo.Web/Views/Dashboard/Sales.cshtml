@model SalesCobrosGeo.Web.Models.Dashboard.DashboardPageViewModel
@{
    ViewData["Title"] = "Ventas";
    var seller = Context.Request.Query["seller"].ToString();
    var zone = Context.Request.Query["zone"].ToString();
    var day = Context.Request.Query["day"].ToString();

    string StatusClass(string status) => status.ToUpperInvariant() switch
    {
        "LIQUIDADO" => "status-chip status-done",
        "AL CORRIENTE" => "status-chip status-current",
        "ATRASADO" => "status-chip status-late",
        "POR INICIAR" => "status-chip status-start",
        _ => "status-chip"
    };
}

<div class="admin-list-page">
    <div class="admin-list-topbar">
        <div>
            <h1 class="admin-list-title">Detalle de ventas</h1>
            <div class="admin-list-subtitle">
                Periodo: @Model.Period.Label
                @(string.IsNullOrWhiteSpace(seller) ? string.Empty : $" • Vendedora: {seller}")
                @(string.IsNullOrWhiteSpace(zone) ? string.Empty : $" • Zona: {zone}")
                @(string.IsNullOrWhiteSpace(day) ? string.Empty : $" • {DateTime.Parse(day).ToString("ddd dd/MM", new System.Globalization.CultureInfo("es-ES"))}")
            </div>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index" asp-route-from="@Model.Period.Start.ToString("yyyy-MM-dd")" asp-route-to="@Model.Period.End.ToString("yyyy-MM-dd")">Volver al dashboard</a>
    </div>

    <div class="admin-record-list">
        @if (Model.Sales.Count == 0)
        {
            <div class="card card-body text-center text-muted">Sin ventas para esta seleccion.</div>
        }
        else
        {
            @foreach (var row in Model.Sales)
            {
                <article class="admin-record-card">
                    <div>
                        <div class="admin-record-title">@row.ClientName</div>
                        <div class="admin-record-meta">@row.SaleNumber</div>
                        <div class="admin-record-meta">@row.Seller • @row.Zone</div>
                    </div>
                    <div>
                        <div class="admin-record-amount">Bs @row.Total.ToString("0.##")</div>
                        <div class="admin-record-meta">@row.UpdatedAt</div>
                    </div>
                    <div class="@StatusClass(row.Status)">@row.Status</div>
                </article>
            }
        }
    </div>
</div>
