@model SalesCobrosGeo.Web.Models.Sales.SaleFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="sale-form-shell">
    <div class="sale-form-topbar sale-form-topbar-app">
        <a class="sale-form-backbtn" asp-controller="Sales" asp-action="Index" aria-label="Volver a ventas">&#8592;</a>
        <div class="sale-form-headcopy">
            <div class="app-page-eyebrow">Ventas</div>
            <h1 class="app-page-title">@Model.PageTitle</h1>
            <div class="app-page-subtitle">Captura rapida de cliente, producto, fotos y ubicacion.</div>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="app-toast-inline danger">Revisa los campos obligatorios antes de continuar.</div>
    }

    <div class="sale-wizard-steps" id="saleWizardSteps">
        <button type="button" class="sale-step-chip active" data-step-target="1"><span>1</span><small>Cliente</small></button>
        <button type="button" class="sale-step-chip" data-step-target="2"><span>2</span><small>Producto</small></button>
        <button type="button" class="sale-step-chip" data-step-target="3"><span>3</span><small>Fotos</small></button>
        <button type="button" class="sale-step-chip" data-step-target="4"><span>4</span><small>GPS</small></button>
        <button type="button" class="sale-step-chip" data-step-target="5"><span>5</span><small>OK</small></button>
    </div>

    <form method="post" class="sale-form" id="saleForm">
        @Html.AntiForgeryToken()
        <input asp-for="Input.IdV" type="hidden" />
        <input asp-for="Input.NumVenta" type="hidden" />

        <section class="sale-step-panel active" data-sale-step="1">
            <div class="card mb-3">
                <div class="card-header">Cliente y venta</div>
                <div class="card-body row g-3">
                    <div class="col-md-4">
                        <label asp-for="Input.FechaVenta" class="form-label">Fecha de venta</label>
                        <input asp-for="Input.FechaVenta" type="date" class="form-control" />
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Input.NombreCliente" class="form-label">Nombre cliente</label>
                        <input asp-for="Input.NombreCliente" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Celular" class="form-label">Celular</label>
                        <input asp-for="Input.Celular" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.Telefono" class="form-label">Telefono</label>
                        <input asp-for="Input.Telefono" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.Zona" class="form-label">Zona</label>
                        <select asp-for="Input.Zona" class="form-select" asp-items="@(new SelectList(Model.Catalogs.Zones, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                            <option value="">Seleccione</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.FormaPago" class="form-label">Forma de pago</label>
                        <select asp-for="Input.FormaPago" class="form-select" asp-items="@(new SelectList(Model.Catalogs.PaymentMethods, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                            <option value="">Seleccione</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Input.DiaCobro" class="form-label">Dia de cobro</label>
                        <select asp-for="Input.DiaCobro" class="form-select" asp-items="@(new SelectList(Model.Catalogs.CollectionDays, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                            <option value="">Seleccione</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.ObservacionVenta" class="form-label">Observacion venta</label>
                        <textarea asp-for="Input.ObservacionVenta" class="form-control" rows="3"></textarea>
                    </div>
                </div>
            </div>
        </section>

        <section class="sale-step-panel" data-sale-step="2">
            <div class="card mb-3 products-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Productos</span>
                    <button type="button" id="btnAddProduct" class="btn btn-sm btn-outline-primary">Agregar</button>
                </div>
                <div class="card-body">
                    <div class="products-mobile-note">En movil solo ves producto e importe. Usa Detalle si necesitas editar cantidad o precio.</div>
                    <div class="table-responsive products-table-wrap">
                        <table class="table" id="productsTable">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th style="width:120px;">Cantidad</th>
                                    <th style="width:160px;">Precio</th>
                                    <th style="width:160px;">Subtotal</th>
                                    <th style="width:110px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                            @for (var i = 0; i < Model.Input.Productos.Count; i++)
                            {
                                <tr class="product-row">
                                    <td>
                                        <label class="mobile-field-label">Producto</label>
                                        <select name="Input.Productos[@i].ProductCode" class="form-select product-select">
                                            <option value="">Seleccione</option>
                                            @foreach (var p in Model.Catalogs.Products)
                                            {
                                                if (p.Code == Model.Input.Productos[i].ProductCode)
                                                {
                                                    <option value="@p.Code" data-price="@p.Price" selected>@p.Name (@p.Code)</option>
                                                }
                                                else
                                                {
                                                    <option value="@p.Code" data-price="@p.Price">@p.Name (@p.Code)</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                    <td class="product-detail-cell">
                                        <label class="mobile-field-label">Cantidad</label>
                                        <input name="Input.Productos[@i].Quantity" value="@Model.Input.Productos[i].Quantity" type="number" min="1" class="form-control qty-input" />
                                    </td>
                                    <td class="product-detail-cell">
                                        <label class="mobile-field-label">Precio</label>
                                        <input name="Input.Productos[@i].UnitPrice" value="@Model.Input.Productos[i].UnitPrice" type="number" step="0.01" min="0" class="form-control price-input" />
                                    </td>
                                    <td>
                                        <label class="mobile-field-label">Importe</label>
                                        <input type="text" class="form-control subtotal-input" readonly />
                                    </td>
                                    <td class="product-actions-cell">
                                        <button type="button" class="btn btn-sm btn-outline-secondary btn-product-toggle">Detalle</button>
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-remove">Quitar</button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    <div class="text-end fw-bold products-total">Total: <span id="totalAmount">0.00</span></div>
                </div>
            </div>
        </section>

        <section class="sale-step-panel" data-sale-step="3">
            <div class="card mb-3">
                <div class="card-header">Fotos (tomar o cargar)</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-sm-6 col-lg-4">@await Html.PartialAsync("_PhotoPicker", ("Input_FotoCliente", "Foto cliente", Model.Input.FotoCliente))</div>
                        <div class="col-sm-6 col-lg-4">@await Html.PartialAsync("_PhotoPicker", ("Input_FotoFachada", "Foto fachada", Model.Input.FotoFachada))</div>
                        <div class="col-sm-6 col-lg-4">@await Html.PartialAsync("_PhotoPicker", ("Input_FotoContrato", "Foto contrato", Model.Input.FotoContrato))</div>
                        <div class="col-sm-6 col-lg-4">@await Html.PartialAsync("_PhotoPicker", ("Input_FotoAdd1", "Foto add 1", Model.Input.FotoAdd1))</div>
                        <div class="col-sm-6 col-lg-4">@await Html.PartialAsync("_PhotoPicker", ("Input_FotoAdd2", "Foto add 2", Model.Input.FotoAdd2))</div>
                    </div>
                    <input asp-for="Input.FotoCliente" type="hidden" id="Input_FotoCliente" />
                    <input asp-for="Input.FotoFachada" type="hidden" id="Input_FotoFachada" />
                    <input asp-for="Input.FotoContrato" type="hidden" id="Input_FotoContrato" />
                    <input asp-for="Input.FotoAdd1" type="hidden" id="Input_FotoAdd1" />
                    <input asp-for="Input.FotoAdd2" type="hidden" id="Input_FotoAdd2" />
                </div>
            </div>
        </section>

        <section class="sale-step-panel" data-sale-step="4">
            <div class="row g-3">
                <div class="col-lg-5">
                    <div class="card mb-3">
                        <div class="card-header">Asignaciones</div>
                        <div class="card-body row g-3">
                            <div class="col-12">
                                <label asp-for="Input.Vendedor" class="form-label">Vendedor</label>
                                <select asp-for="Input.Vendedor" class="form-select" asp-items="@(new SelectList(Model.Catalogs.Sellers, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                                    <option value="">Seleccione</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label asp-for="Input.Cobrador" class="form-label">Cobrador</label>
                                <select asp-for="Input.Cobrador" class="form-select" asp-items="@(new SelectList(Model.Catalogs.Collectors, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                                    <option value="">Seleccione</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label asp-for="Input.Usuario" class="form-label">Usuario (email)</label>
                                <input asp-for="Input.Usuario" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Input.ComisionVendedorPct" class="form-label">% Comision vendedor</label>
                                <input asp-for="Input.ComisionVendedorPct" type="number" step="0.01" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="card mb-3">
                        <div class="card-header">Ubicacion y estado</div>
                        <div class="card-body row g-3">
                            <div class="col-12">
                                <label asp-for="Input.Coordenadas" class="form-label">Coordenadas (GPS automatico)</label>
                                <div class="input-group">
                                    <input asp-for="Input.Coordenadas" class="form-control" id="gpsCoordinates" readonly />
                                    <button type="button" class="btn btn-outline-primary" id="btnGpsLocate">GPS</button>
                                </div>
                                <small id="gpsStatus" class="text-muted">Detectando ubicacion...</small>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.Coordenadas2" class="form-label">Coordenadas 2</label>
                                <input asp-for="Input.Coordenadas2" class="form-control" id="gpsCoordinates2" readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.UrlUbicacion" class="form-label">URL ubicacion</label>
                                <input asp-for="Input.UrlUbicacion" class="form-control" id="gpsUrl" readonly />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.Estado" class="form-label">Estado</label>
                                <input asp-for="Input.Estado" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.Estado2" class="form-label">Estado2</label>
                                <input asp-for="Input.Estado2" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Input.Cobrar" class="form-label">Cobrar</label>
                                <input asp-for="Input.Cobrar" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.FechaPrimerCobro" class="form-label">Fecha primer cobro</label>
                                <input asp-for="Input.FechaPrimerCobro" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="sale-step-panel" data-sale-step="5">
            <div class="card mb-3 sale-confirm-card">
                <div class="card-header">Confirmacion</div>
                <div class="card-body">
                    <div class="sale-confirm-grid">
                        <div>
                            <span>Cliente</span>
                            <strong id="confirmClient">@Model.Input.NombreCliente</strong>
                        </div>
                        <div>
                            <span>Zona</span>
                            <strong id="confirmZone">@Model.Input.Zona</strong>
                        </div>
                        <div>
                            <span>Pago</span>
                            <strong id="confirmPayment">@Model.Input.FormaPago</strong>
                        </div>
                        <div>
                            <span>Dia de cobro</span>
                            <strong id="confirmDay">@Model.Input.DiaCobro</strong>
                        </div>
                        <div>
                            <span>Vendedor</span>
                            <strong id="confirmSeller">@Model.Input.Vendedor</strong>
                        </div>
                        <div>
                            <span>Cobrador</span>
                            <strong id="confirmCollector">@Model.Input.Cobrador</strong>
                        </div>
                        <div class="highlight">
                            <span>Total estimado</span>
                            <strong id="confirmTotal">0.00</strong>
                        </div>
                        <div class="highlight">
                            <span>Coordenadas</span>
                            <strong id="confirmCoordinates">@Model.Input.Coordenadas</strong>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <div class="sale-wizard-footer">
            <button type="button" class="btn btn-outline-secondary sale-wizard-iconbtn" id="btnPrevStep" aria-label="Paso anterior"><span aria-hidden="true">&#8592;</span><strong>Atras</strong></button>
            <div class="sale-wizard-progress"><span id="saleWizardLabel">Paso 1 de 5</span></div>
            <button type="button" class="btn btn-primary sale-wizard-iconbtn" id="btnNextStep" aria-label="Paso siguiente"><strong>Sigue</strong><span aria-hidden="true">&#8594;</span></button>
            <button type="submit" class="btn btn-success sale-wizard-iconbtn" id="btnSubmitSale"><span aria-hidden="true">&#10003;</span><strong>@(Model.IsEdit ? "Guardar" : "Registrar")</strong></button>
        </div>
    </form>
</div>

@section Scripts {
<script>
(function() {
    const tableBody = document.querySelector('#productsTable tbody');
    const addBtn = document.getElementById('btnAddProduct');
    const totalNode = document.getElementById('totalAmount');
    const products = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Catalogs.Products));
    const steps = [...document.querySelectorAll('[data-sale-step]')];
    const stepButtons = [...document.querySelectorAll('[data-step-target]')];
    const prevBtn = document.getElementById('btnPrevStep');
    const nextBtn = document.getElementById('btnNextStep');
    const submitBtn = document.getElementById('btnSubmitSale');
    const wizardLabel = document.getElementById('saleWizardLabel');
    let currentStep = 1;

    function getProductCode(product) { return product.code ?? product.Code ?? ''; }
    function getProductName(product) { return product.name ?? product.Name ?? ''; }
    function getProductPrice(product) { return product.price ?? product.Price ?? ''; }

    function updateConfirm() {
        document.getElementById('confirmClient').textContent = document.getElementById('Input_NombreCliente')?.value || '-';
        document.getElementById('confirmZone').textContent = document.getElementById('Input_Zona')?.value || '-';
        document.getElementById('confirmPayment').textContent = document.getElementById('Input_FormaPago')?.value || '-';
        document.getElementById('confirmDay').textContent = document.getElementById('Input_DiaCobro')?.value || '-';
        document.getElementById('confirmSeller').textContent = document.getElementById('Input_Vendedor')?.value || '-';
        document.getElementById('confirmCollector').textContent = document.getElementById('Input_Cobrador')?.value || '-';
        document.getElementById('confirmTotal').textContent = totalNode.textContent || '0.00';
        document.getElementById('confirmCoordinates').textContent = document.getElementById('gpsCoordinates')?.value || '-';
    }

    function setStep(step) {
        currentStep = Math.max(1, Math.min(5, step));
        steps.forEach((panel, index) => panel.classList.toggle('active', index + 1 === currentStep));
        stepButtons.forEach((button, index) => button.classList.toggle('active', index + 1 === currentStep));
        prevBtn.disabled = currentStep === 1;
        nextBtn.style.display = currentStep === 5 ? 'none' : 'inline-flex';
        submitBtn.style.display = currentStep === 5 ? 'inline-flex' : 'none';
        wizardLabel.textContent = `Paso ${currentStep} de 5`;
        updateConfirm();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function bindRow(row) {
        const select = row.querySelector('.product-select');
        const qty = row.querySelector('.qty-input');
        const price = row.querySelector('.price-input');
        const subtotal = row.querySelector('.subtotal-input');
        const toggle = row.querySelector('.btn-product-toggle');

        function recalcRow() {
            const q = parseFloat(qty.value || '0');
            const p = parseFloat(price.value || '0');
            subtotal.value = (q * p).toFixed(2);
            recalcTotal();
        }

        select.addEventListener('change', () => {
            const selected = select.options[select.selectedIndex];
            const autoPrice = selected && selected.dataset.price ? selected.dataset.price : '';
            if (autoPrice) {
                price.value = autoPrice;
            }
            recalcRow();
        });

        qty.addEventListener('input', recalcRow);
        price.addEventListener('input', recalcRow);

        if (toggle) {
            toggle.addEventListener('click', () => {
                row.classList.toggle('show-details');
                toggle.textContent = row.classList.contains('show-details') ? 'Ocultar' : 'Detalle';
            });
        }

        row.querySelector('.btn-remove').addEventListener('click', () => {
            if (tableBody.children.length === 1) {
                qty.value = 1;
                price.value = '';
                select.value = '';
                recalcRow();
                return;
            }
            row.remove();
            reindexRows();
            recalcTotal();
        });

        recalcRow();
    }

    function reindexRows() {
        [...tableBody.children].forEach((row, i) => {
            row.querySelector('.product-select').name = `Input.Productos[${i}].ProductCode`;
            row.querySelector('.qty-input').name = `Input.Productos[${i}].Quantity`;
            row.querySelector('.price-input').name = `Input.Productos[${i}].UnitPrice`;
        });
    }

    function recalcTotal() {
        let total = 0;
        [...tableBody.querySelectorAll('.subtotal-input')].forEach(x => {
            total += parseFloat(x.value || '0');
        });
        totalNode.textContent = total.toFixed(2);
        updateConfirm();
    }

    addBtn.addEventListener('click', () => {
        const i = tableBody.children.length;
        const row = document.createElement('tr');
        row.className = 'product-row';
        const options = ['<option value="">Seleccione</option>']
            .concat(products.map(p => {
                const code = getProductCode(p);
                const name = getProductName(p);
                const price = getProductPrice(p);
                return `<option value="${code}" data-price="${price}">${name} (${code})</option>`;
            }))
            .join('');

        row.innerHTML = `
            <td>
                <label class="mobile-field-label">Producto</label>
                <select name="Input.Productos[${i}].ProductCode" class="form-select product-select">${options}</select>
            </td>
            <td class="product-detail-cell">
                <label class="mobile-field-label">Cantidad</label>
                <input name="Input.Productos[${i}].Quantity" value="1" type="number" min="1" class="form-control qty-input" />
            </td>
            <td class="product-detail-cell">
                <label class="mobile-field-label">Precio</label>
                <input name="Input.Productos[${i}].UnitPrice" type="number" step="0.01" min="0" class="form-control price-input" />
            </td>
            <td>
                <label class="mobile-field-label">Importe</label>
                <input type="text" class="form-control subtotal-input" readonly />
            </td>
            <td class="product-actions-cell">
                <button type="button" class="btn btn-sm btn-outline-secondary btn-product-toggle">Detalle</button>
                <button type="button" class="btn btn-sm btn-outline-danger btn-remove">Quitar</button>
            </td>`;

        tableBody.appendChild(row);
        bindRow(row);
    });

    [...tableBody.children].forEach(bindRow);
    reindexRows();

    stepButtons.forEach((button) => {
        button.addEventListener('click', () => setStep(parseInt(button.dataset.stepTarget || '1', 10)));
    });
    prevBtn.addEventListener('click', () => setStep(currentStep - 1));
    nextBtn.addEventListener('click', () => setStep(currentStep + 1));
    document.querySelectorAll('#Input_NombreCliente, #Input_Zona, #Input_FormaPago, #Input_DiaCobro, #Input_Vendedor, #Input_Cobrador, #gpsCoordinates').forEach((el) => {
        el.addEventListener('input', updateConfirm);
        el.addEventListener('change', updateConfirm);
    });
    setStep(1);
})();

(function() {
    const MAX_WIDTH = 1280;
    const MAX_HEIGHT = 1280;
    const JPEG_QUALITY = 0.78;

    function readAsDataUrl(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => resolve(String(reader.result || ''));
            reader.onerror = () => reject(new Error('No se pudo leer la imagen.'));
            reader.readAsDataURL(file);
        });
    }

    function loadImage(dataUrl) {
        return new Promise((resolve, reject) => {
            const image = new Image();
            image.onload = () => resolve(image);
            image.onerror = () => reject(new Error('No se pudo procesar la imagen.'));
            image.src = dataUrl;
        });
    }

    async function compressImage(file) {
        if (!file.type.startsWith('image/')) {
            return readAsDataUrl(file);
        }

        const dataUrl = await readAsDataUrl(file);
        const image = await loadImage(dataUrl);
        let width = image.width;
        let height = image.height;
        const ratio = Math.min(MAX_WIDTH / width, MAX_HEIGHT / height, 1);
        width = Math.round(width * ratio);
        height = Math.round(height * ratio);
        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const context = canvas.getContext('2d');
        context.drawImage(image, 0, 0, width, height);
        return canvas.toDataURL('image/jpeg', JPEG_QUALITY);
    }

    function initPhotoPicker(key) {
        const input = document.getElementById(key);
        const file = document.getElementById(`${key}_file`);
        const preview = document.getElementById(`${key}_preview`);
        const remove = document.getElementById(`${key}_remove`);
        const picker = document.querySelector(`[data-photo-key="${key}"]`);
        if (!input || !file || !preview || !remove || !picker) {
            return;
        }

        function refreshPreview() {
            const hasValue = !!input.value;
            preview.src = hasValue ? input.value : 'https://placehold.co/320x200?text=Sin+foto';
            remove.disabled = !hasValue;
            picker.classList.toggle('has-image', hasValue);
            picker.classList.remove('is-loading');
        }

        file.addEventListener('change', async (e) => {
            const selected = e.target.files && e.target.files[0];
            if (!selected) {
                return;
            }

            picker.classList.add('is-loading');
            try {
                const compressed = await compressImage(selected);
                input.value = compressed;
                refreshPreview();
            } catch {
                input.value = '';
                refreshPreview();
            }
        });

        remove.addEventListener('click', () => {
            input.value = '';
            file.value = '';
            refreshPreview();
        });

        refreshPreview();
    }

    ['Input_FotoCliente','Input_FotoFachada','Input_FotoContrato','Input_FotoAdd1','Input_FotoAdd2'].forEach(initPhotoPicker);
})();

(function() {
    const coords = document.getElementById('gpsCoordinates');
    const coords2 = document.getElementById('gpsCoordinates2');
    const url = document.getElementById('gpsUrl');
    const status = document.getElementById('gpsStatus');
    const btn = document.getElementById('btnGpsLocate');

    function applyLocation(position) {
        const lat = position.coords.latitude.toFixed(6);
        const lng = position.coords.longitude.toFixed(6);
        const value = `${lat}, ${lng}`;
        coords.value = value;
        coords2.value = value;
        url.value = `https://maps.google.com/?q=${lat},${lng}`;
        status.textContent = 'Ubicacion detectada correctamente.';
        document.getElementById('confirmCoordinates').textContent = value;
    }

    function detect() {
        if (!navigator.geolocation) {
            status.textContent = 'GPS no disponible en este dispositivo.';
            return;
        }

        status.textContent = 'Detectando ubicacion...';
        navigator.geolocation.getCurrentPosition(
            applyLocation,
            function(err) { status.textContent = `No se pudo detectar GPS (${err.message}).`; },
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
        );
    }

    btn.addEventListener('click', detect);

    if (!coords.value) {
        detect();
    } else {
        status.textContent = 'Coordenadas cargadas.';
    }
})();
</script>
}
