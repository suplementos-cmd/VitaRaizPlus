@model IReadOnlyList<SalesCobrosGeo.Web.Models.Sales.SaleRecord>
@{
    ViewData["Title"] = "Ventas";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Ventas Registradas</h1>
        <small class="text-muted">Formulario demo local en JSON</small>
    </div>
    <a class="btn btn-primary" asp-controller="Sales" asp-action="Create">Nueva Venta</a>
</div>

@if (TempData["SalesMessage"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<div class="card">
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Num</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Zona</th>
                    <th>Vendedor</th>
                    <th>Importe</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-4">Sin ventas registradas.</td></tr>
            }
            else
            {
                foreach (var row in Model)
                {
                    <tr>
                        <td>@row.NumVenta</td>
                        <td>@row.FechaVenta.ToString("yyyy-MM-dd")</td>
                        <td>@row.NombreCliente</td>
                        <td>@row.Zona</td>
                        <td>@row.Vendedor</td>
                        <td>@row.ImporteTotal.ToString("0.00")</td>
                        <td>@row.Estado2</td>
                        <td class="text-end">
                            <a class="btn btn-outline-secondary btn-sm" asp-controller="Sales" asp-action="Edit" asp-route-id="@row.IdV">Editar</a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
