@model SalesCobrosGeo.Web.Models.Sales.SalesListViewModel
@{
    ViewData["Title"] = "Perfil ventas";
}

<div class="ventas-mobile">
    <div class="ventas-toolbar">
        <div>
            <div class="ventas-title">Perfil ventas</div>
            <div class="ventas-subtitle">Vista semanal agrupada por dia</div>
        </div>
        <a class="btn btn-primary btn-add" asp-controller="Sales" asp-action="Create">+ Agregar</a>
    </div>

    @if (TempData["SalesMessage"] is string msg)
    {
        <div class="alert alert-success mt-2">@msg</div>
    }

    @if (Model.Groups.Count == 0)
    {
        <div class="card mt-3"><div class="card-body text-center text-muted">No hay ventas registradas esta semana.</div></div>
    }
    else
    {
        foreach (var group in Model.Groups)
        {
            <div class="day-header">
                <span class="day-bullet">★</span>
                <span>@group.Day.ToString("d/M/yyyy")</span>
                <span class="day-count">@group.Sales.Count</span>
            </div>

            foreach (var sale in group.Sales)
            {
                <a class="sale-touch-card" asp-controller="Sales" asp-action="Details" asp-route-id="@sale.IdV">
                    <div class="sale-images">
                        <img src="@(string.IsNullOrWhiteSpace(sale.FotoFachada) ? "https://placehold.co/96x72?text=Fachada" : sale.FotoFachada)" alt="Fachada" />
                        <img src="@(string.IsNullOrWhiteSpace(sale.FotoCliente) ? "https://placehold.co/96x72?text=Cliente" : sale.FotoCliente)" alt="Cliente" />
                    </div>
                    <div class="sale-main">
                        <div class="sale-client">@sale.NombreCliente</div>
                        <div class="sale-meta">@sale.Coordenadas</div>
                        <div class="sale-meta">@sale.Zona • @sale.FormaPago</div>
                    </div>
                    <div class="sale-amount">@sale.ImporteTotal.ToString("0,0")</div>
                </a>
            }
        }
    }
</div>
