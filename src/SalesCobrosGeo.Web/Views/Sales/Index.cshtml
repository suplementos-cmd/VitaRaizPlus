@model SalesCobrosGeo.Web.Models.Sales.SalesListViewModel
@{
    ViewData["Title"] = "Perfil ventas";
    string ResolveImage(string? path, string fallback) =>
        string.IsNullOrWhiteSpace(path) ? fallback :
        (path.StartsWith("http", StringComparison.OrdinalIgnoreCase) || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/")
            ? path
            : "/" + path);
}

<div class="ventas-mobile">
    <div class="ventas-toolbar">
        <div>
            <div class="ventas-title">Perfil ventas</div>
            <div class="ventas-subtitle">Ventas agrupadas por semana y dia</div>
        </div>
        <button type="button" class="sales-toolbar-searchbtn" data-sales-search-toggle="true" aria-label="Buscar ventas">
            <span aria-hidden="true">&#8981;</span>
        </button>
    </div>

    <section class="sales-app-search" data-sales-search-shell="true" hidden>
        <div class="sales-app-search-box">
            <span class="sales-app-search-icon" aria-hidden="true">&#8981;</span>
            <input id="salesAppSearch" type="search" placeholder="Buscar cliente, zona, producto o vendedora" autocomplete="off" />
        </div>
    </section>

    @if (TempData["SalesMessage"] is string msg)
    {
        <div class="alert alert-success mt-2">@msg</div>
    }

    @if (Model.Weeks.Count == 0)
    {
        <div class="card mt-3"><div class="card-body text-center text-muted">No hay ventas registradas.</div></div>
    }
    else
    {
        foreach (var week in Model.Weeks)
        {
            <details class="sales-week-accordion" @(week.IsCurrentWeek ? "open" : null)>
                <summary class="sales-week-summary">
                    <div>
                        <div class="sales-week-title">Semana @week.WeekStart.ToString("dd/MM") - @week.WeekEnd.ToString("dd/MM")</div>
                        <div class="sales-week-meta">@week.Days.Sum(x => x.Sales.Count) ventas</div>
                    </div>
                    <span class="sales-week-toggle">+</span>
                </summary>

                <div class="sales-week-body">
                    @foreach (var group in week.Days)
                    {
                        <div class="day-header compact sales-app-dayhead">
                            <span>@group.Day.ToString("ddd dd/MM")</span>
                            <span class="day-count">@group.Sales.Count</span>
                        </div>

                        foreach (var sale in group.Sales)
                        {
                            var firstProduct = sale.Productos.FirstOrDefault()?.ProductCode ?? sale.Producto;
                            var saleSearch = $"{sale.NombreCliente} {sale.Zona} {sale.DiaCobro} {sale.Vendedor} {firstProduct}".ToLowerInvariant();
                            var mapsUrl = $"https://maps.google.com/?q={sale.Coordenadas}";
                            <article class="sales-app-record" data-sales-search="@saleSearch">
                                <a class="sales-app-record-link" asp-controller="Sales" asp-action="Details" asp-route-id="@sale.IdV">
                                    <div class="sales-app-record-photo">
                                        <img class="image-previewable" data-previewable="true" src="@ResolveImage(sale.FotoFachada, "https://placehold.co/96x96?text=Venta")" alt="Fachada" loading="lazy" decoding="async" />
                                    </div>
                                    <div class="sales-app-record-body">
                                        <div class="sales-app-record-top">
                                            <strong class="sales-app-record-client">@sale.NombreCliente</strong>
                                            <span class="sales-app-record-amount">@sale.ImporteTotal.ToString("0,0")</span>
                                        </div>
                                        <div class="sales-app-record-line">
                                            <span class="sales-app-record-zone">@sale.Zona</span>
                                            <span>@sale.DiaCobro</span>
                                        </div>
                                        <div class="sales-app-record-line muted">
                                            <span>@sale.Vendedor</span>
                                            <span>@sale.FormaPago</span>
                                        </div>
                                        <div class="sales-app-record-product">@firstProduct</div>
                                    </div>
                                </a>
                                <div class="sales-app-record-actions">
                                    @if (!string.IsNullOrWhiteSpace(sale.Coordenadas))
                                    {
                                        <a class="sales-app-actionbtn" href="@mapsUrl" target="_blank" rel="noopener noreferrer">GPS</a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(sale.Celular))
                                    {
                                        <a class="sales-app-actionbtn" href="tel:@sale.Celular">TEL</a>
                                    }
                                </div>
                            </article>
                        }
                    }
                </div>
            </details>
        }
    }

    <a class="sales-app-fab" asp-controller="Sales" asp-action="Create" aria-label="Agregar venta">+</a>
</div>
