@using SalesCobrosGeo.Web.Models.Shared
@model SalesCobrosGeo.Web.Models.Sales.SaleDetailViewModel
@{
    ViewData["Title"] = "Detalle venta";
    var sale = Model.Sale;
    ViewData["MobileContextBar"] = new MobileContextBarModel(
        sale.NombreCliente,
        $"Venta #{sale.NumVenta}",
        Url.Action("Index", "Sales"),
        new[]
        {
            new MobileContextAction("Editar", "edit", Url: Url.Action("Edit", "Sales", new { id = sale.IdV }), AriaLabel: "Editar venta", CssClass: "is-primary")
        });
    string ResolveImage(string? path, string fallback) =>
        string.IsNullOrWhiteSpace(path) ? fallback :
        (path.StartsWith("http", StringComparison.OrdinalIgnoreCase) || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/")
            ? path
            : "/" + path);
}

<div class="sales-detail-mobile">
    <div class="sales-detail-appbar">
        <a class="sales-detail-navbtn" asp-controller="Sales" asp-action="Index" aria-label="Volver">&#8592;</a>
        <div class="sales-detail-headcopy">
            <strong>@sale.NombreCliente</strong>
            <span>Venta #@sale.NumVenta</span>
        </div>
        <a class="sales-detail-navbtn primary" asp-controller="Sales" asp-action="Edit" asp-route-id="@sale.IdV" aria-label="Editar">ED</a>
    </div>

    <div class="detail-hero sales-detail-hero">
        <img class="image-previewable" data-previewable="true" src="@ResolveImage(sale.FotoFachada, "https://placehold.co/900x420?text=Fachada")" alt="Fachada" loading="lazy" decoding="async" />
    </div>

    <div class="sales-detail-summary">
        <span class="sales-detail-pill">@sale.Zona</span>
        <span class="sales-detail-pill">@sale.DiaCobro</span>
        <span class="sales-detail-pill amount">@sale.ImporteTotal.ToString("0,0")</span>
    </div>

    <div class="sales-detail-actionrow">
        @if (!string.IsNullOrWhiteSpace(sale.Celular))
        {
            <a class="sales-detail-actionbtn" href="tel:@sale.Celular">TEL</a>
        }
        @if (!string.IsNullOrWhiteSpace(sale.Coordenadas))
        {
            <a class="sales-detail-actionbtn" href="https://maps.google.com/?q=@sale.Coordenadas" target="_blank" rel="noopener noreferrer">GPS</a>
        }
    </div>

    <div class="sales-detail-panel mt-3">
        <div class="detail-client-photo-wrap sales-detail-photo">
            <img class="detail-client-photo image-previewable" data-previewable="true" src="@ResolveImage(sale.FotoCliente, "https://placehold.co/320x220?text=Cliente")" alt="Foto cliente" loading="lazy" decoding="async" />
            <div class="text-muted small">Toca la imagen para ampliar</div>
        </div>
    </div>

    <div class="sales-detail-form mt-3">
        <div class="sales-detail-row">
            <span>Fecha venta</span>
            <strong>@sale.FechaVenta.ToString("d/M/yyyy")</strong>
        </div>
        <div class="sales-detail-row">
            <span>Cliente</span>
            <strong>@sale.NombreCliente</strong>
        </div>
        <div class="sales-detail-row">
            <span>Celular</span>
            <strong>@sale.Celular</strong>
        </div>
        <div class="sales-detail-row">
            <span>Vendedora</span>
            <strong>@sale.Vendedor</strong>
        </div>
        <div class="sales-detail-row">
            <span>Forma pago</span>
            <strong>@sale.FormaPago</strong>
        </div>
        <div class="sales-detail-row">
            <span>Estado</span>
            <strong>@sale.Estado2</strong>
        </div>
        <div class="sales-detail-row">
            <span>Coordenadas</span>
            <strong>@sale.Coordenadas</strong>
        </div>
    </div>

    <div class="sales-detail-products mt-3">
        <div class="sales-detail-sectiontitle">Productos</div>
        <div class="sales-detail-productlist">
            @foreach (var p in sale.Productos)
            {
                <div class="sales-detail-productitem">
                    <span>@p.ProductCode x @p.Quantity</span>
                    <strong>@((p.UnitPrice ?? 0m) * p.Quantity)</strong>
                </div>
            }
        </div>
    </div>
</div>




@section Scripts {
    <script src="~/js/modules/sales-state.js" asp-append-version="true"></script>
}
