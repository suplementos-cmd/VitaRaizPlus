@model SalesCobrosGeo.Web.Models.Sales.SaleDetailViewModel
@{
    ViewData["Title"] = "Detalle venta";
    var sale = Model.Sale;
}

<div class="sales-detail-mobile">
    <div class="detail-topbar">
        <a class="btn btn-sm btn-outline-secondary" asp-controller="Sales" asp-action="Index">← Ventas</a>
        <div class="detail-id">@sale.IdV</div>
        <a class="btn btn-sm btn-primary" asp-controller="Sales" asp-action="Edit" asp-route-id="@sale.IdV">Editar</a>
    </div>

    <div class="detail-hero">
        <img src="@(string.IsNullOrWhiteSpace(sale.FotoFachada) ? "https://placehold.co/900x420?text=Fachada" : sale.FotoFachada)" alt="Fachada" />
        <div class="detail-hero-actions">
            <a class="btn btn-light btn-sm" asp-controller="Sales" asp-action="Edit" asp-route-id="@sale.IdV">Editar fachada</a>
            <a class="btn btn-light btn-sm" asp-controller="Sales" asp-action="Edit" asp-route-id="@sale.IdV">Editar foto cliente</a>
        </div>
    </div>

    <div class="detail-grid card card-body mt-3">
        <div><strong>NUM_VENTA</strong><br /><span class="detail-value">@sale.NumVenta</span></div>
        <div><strong>FECHA DE VENTA</strong><br /><span class="detail-highlight">@sale.FechaVenta.ToString("d/M/yyyy")</span></div>
        <div><strong>CLIENTE</strong><br /><span class="detail-value">@sale.NombreCliente</span></div>
        <div><strong>CELULAR</strong><br /><span class="detail-value">@sale.Celular</span></div>
        <div><strong>ZONA</strong><br /><span class="detail-highlight">@sale.Zona</span></div>
        <div><strong>FORMA DE PAGO</strong><br /><span class="detail-value">@sale.FormaPago</span></div>
        <div><strong>DIA DE COBRO</strong><br /><span class="detail-highlight">@sale.DiaCobro</span></div>
        <div><strong>IMPORTE TOTAL</strong><br /><span class="detail-amount">@sale.ImporteTotal.ToString("0,0")</span></div>
        <div><strong>COORDENADAS</strong><br /><span class="detail-value">@sale.Coordenadas</span></div>
        <div><strong>ESTADO</strong><br /><span class="detail-value">@sale.Estado2</span></div>
    </div>

    <div class="card mt-3">
        <div class="card-header">Productos</div>
        <div class="card-body">
            @foreach (var p in sale.Productos)
            {
                <div class="d-flex justify-content-between border-bottom py-2">
                    <span>@p.ProductCode x @p.Quantity</span>
                    <span>@((p.UnitPrice ?? 0m) * p.Quantity)</span>
                </div>
            }
        </div>
    </div>
</div>
