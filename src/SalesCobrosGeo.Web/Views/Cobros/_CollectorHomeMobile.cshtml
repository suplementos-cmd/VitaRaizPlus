@using SalesCobrosGeo.Web.Models.Collections
@model CollectorHomeViewModel
@functions {
    string IconSvg(string filter) => filter switch
    {
        "promise" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        "followup" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M21 12a9 9 0 1 1-3-6.7'/><path d='M21 3v6h-6'/></svg>",
        "overdue" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };

    string SaleTone(CollectorClientListItem item) => item.Status.ToUpperInvariant() switch
    {
        _ when item.HasPromiseOverdue => "danger",
        _ when item.IsNotLocated => "warning",
        _ when item.IsRefused => "muted",
        "ATRASADO" => "danger",
        "CANCELADO" => "muted",
        "LIQUIDADO" => "success",
        "AL CORRIENTE" => "success",
        "PARCIAL" => "warning",
        "POR INICIAR" => "neutral",
        _ when item.HasPromise => "info",
        _ => "neutral"
    };

    string SaleFlag(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "Promesa vencida",
        _ when item.HasPromise => "Promesa activa",
        _ when item.IsNotLocated => "No localizado",
        _ when item.IsRefused => "Se nego",
        _ when item.Status.Equals("ATRASADO", StringComparison.OrdinalIgnoreCase) => "Urgente",
        _ when item.Status.Equals("CANCELADO", StringComparison.OrdinalIgnoreCase) => "Cancelada",
        _ when item.Status.Equals("LIQUIDADO", StringComparison.OrdinalIgnoreCase) => "Liquidada",
        _ => "Pendiente"
    };

    string SaleIcon(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 9v4'/><path d='M12 17h.01'/><path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/></svg>",
        _ when item.HasPromise => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        _ when item.IsNotLocated => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m21 10-5.2-5.2a2 2 0 0 0-2.8 0L4 14v6h6l9-9a2 2 0 0 0 0-2.8Z'/><path d='M7 17h.01'/></svg>",
        _ when item.IsRefused => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>",
        _ when item.Status.Equals("ATRASADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        _ when item.Status.Equals("LIQUIDADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m5 13 4 4L19 7'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };
}
<div class="collector-mobile-shell compact-home">
    <div class="collector-mobile-historycards">
        @foreach (var summary in Model.HistorySummaryCards)
        {
            var targetUrl = summary.Code == "pending"
                ? Url.Action("CollectorQueue", "Cobros", new { profile = Model.Profile, groupBy = "status", filter = "all" })
                : Url.Action("CollectionHistory", "Cobros", new { profile = Model.Profile, outcome = summary.Code });
            <a class="collector-mobile-historycard @(summary.IsActive ? "active" : string.Empty)" href="@targetUrl">
                <strong>@summary.Title</strong>
                <span>@summary.Subtitle</span>
                <b>@summary.Count</b>
            </a>
        }
    </div>
    <div class="collector-mobile-tree">
        @foreach (var card in Model.Cards)
        {
            var filter = string.IsNullOrWhiteSpace(card.StatusKey) ? "pending" : card.StatusKey;
            <a class="collector-mobile-treeitem collector-mobile-treeitem-link" asp-action="@card.TargetAction" asp-route-profile="@Model.Profile" asp-route-status="@filter" asp-route-filter="all" asp-route-groupBy="status">
                <span class="collector-mobile-treeicon @filter">@Html.Raw(IconSvg(filter))</span>
                <div class="collector-mobile-treecopy">
                    <strong>@card.Title</strong>
                    <span>@card.Subtitle</span>
                </div>
                <div class="collector-mobile-treeaside">
                    <span class="collector-mobile-treecount">@card.Count</span>
                    <span class="collector-mobile-treearrow">&rsaquo;</span>
                </div>
            </a>
        }
    </div>
    <div class="collector-mobile-compactlist">
        @foreach (var item in Model.TodayClients)
        {
            var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
            var tone = SaleTone(item);
            <article class="collector-mobile-clientrow status-@tone">
                <a class="collector-mobile-clientmain" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                    <strong><span class="collector-semantic-icon @tone">@Html.Raw(SaleIcon(item))</span>@item.Name <span class="collector-inline-flag @tone">@SaleFlag(item)</span></strong>
                    <span>@item.Zone · @item.NextAction</span>
                </a>
                <div class="collector-mobile-clientactions">
                    @if (!string.IsNullOrWhiteSpace(item.Phone))
                    {
                        <a href="tel:@item.Phone" class="cma-btn cma-call" title="Llamar" aria-label="Llamar">
                            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 15.352V16.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/></svg>
                        </a>
                    }
                    <a href="@mapLink" target="_blank" rel="noopener" class="cma-btn cma-map @(mapLink == "#" ? "disabled" : string.Empty)" title="Ver mapa" aria-label="Ver en mapa">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/></svg>
                    </a>
                    <a asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" class="cma-btn cma-register" title="Registrar cobro" aria-label="Registrar cobro">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M2.695 14.763l-1.262 3.154a.5.5 0 00.65.65l3.155-1.262a4 4 0 001.343-.885L17.5 5.5a2.121 2.121 0 00-3-3L3.58 13.42a4 4 0 00-.885 1.343z"/></svg>
                    </a>                </div>
            </article>
        }
    </div>
</div>