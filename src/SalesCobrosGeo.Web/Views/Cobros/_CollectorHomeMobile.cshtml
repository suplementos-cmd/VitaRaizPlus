@using SalesCobrosGeo.Web.Models.Collections
@model CollectorHomeViewModel
@functions {
    string IconSvg(string filter) => filter switch
    {
        "promise" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        "followup" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M21 12a9 9 0 1 1-3-6.7'/><path d='M21 3v6h-6'/></svg>",
        "overdue" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };

    string SaleTone(CollectorClientListItem item) => item.Status.ToUpperInvariant() switch
    {
        "ATRASADO" => "danger",
        "CANCELADO" => "muted",
        "LIQUIDADO" => "success",
        "AL CORRIENTE" => "success",
        "PARCIAL" => "warning",
        "POR INICIAR" => "neutral",
        _ when item.HasPromise => "info",
        _ => "neutral"
    };

    string SaleFlag(string tone) => tone switch
    {
        "danger" => "Urgente",
        "muted" => "Cancelada",
        "success" => "Estable",
        "warning" => "Seguimiento",
        "info" => "Promesa",
        _ => "Pendiente"
    };
}
<div class="collector-mobile-shell compact-home">
    <div class="collector-mobile-tree">
        @foreach (var card in Model.Cards)
        {
            var filter = string.IsNullOrWhiteSpace(card.StatusKey) ? "pending" : card.StatusKey;
            <a class="collector-mobile-treeitem collector-mobile-treeitem-link" asp-action="@card.TargetAction" asp-route-profile="@Model.Profile" asp-route-status="@filter" asp-route-filter="all" asp-route-groupBy="status">
                <span class="collector-mobile-treeicon @filter">@Html.Raw(IconSvg(filter))</span>
                <div class="collector-mobile-treecopy">
                    <strong>@card.Title</strong>
                    <span>@card.Subtitle</span>
                </div>
                <div class="collector-mobile-treeaside">
                    <span class="collector-mobile-treecount">@card.Count</span>
                    <span class="collector-mobile-treearrow">&rsaquo;</span>
                </div>
            </a>
        }
    </div>
    <div class="collector-mobile-compactlist">
        @foreach (var item in Model.TodayClients)
        {
            var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
            var tone = SaleTone(item);
            <article class="collector-mobile-clientrow status-@tone">
                <a class="collector-mobile-clientmain" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                    <strong>@item.Name <span class="collector-inline-flag @tone">@SaleFlag(tone)</span></strong>
                    <span>@item.Zone · @item.NextAction</span>
                </a>
                <div class="collector-mobile-clientactions">
                    @if (!string.IsNullOrWhiteSpace(item.Phone)) { <a href="tel:@item.Phone">LL</a> }
                    <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)">MP</a>
                    <a asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">RG</a>
                </div>
            </article>
        }
    </div>
</div>

