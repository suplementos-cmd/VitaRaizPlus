@model IReadOnlyList<SalesCobrosGeo.Web.Models.Sales.CollectorPortfolioItem>
@using SalesCobrosGeo.Web.Models.Sales
@{
    ViewData["Title"] = "Perfil Cobrador";
    var profiles = ViewBag.Profiles as IReadOnlyList<CatalogOption> ?? [];
    var selected = ViewBag.Profile as string;
    var history = ViewBag.History as IReadOnlyList<SalesCobrosGeo.Web.Models.Sales.CollectionRecord> ?? [];
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-0">Perfil Cobrador</h1>
        <small class="text-muted">Ventas asignadas y registro de cobros</small>
    </div>
</div>

@if (TempData["CobroMessage"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

<form method="get" class="card card-body mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-6 col-lg-4">
            <label class="form-label">Usuario cobrador</label>
            <select class="form-select" name="profile">
                <option value="">Todos</option>
                @foreach (var p in profiles)
                {
                    if (string.Equals(selected, p.Code, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@p.Code" selected>@p.Name</option>
                    }
                    else
                    {
                        <option value="@p.Code">@p.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 col-lg-2">
            <button class="btn btn-primary w-100" type="submit">Filtrar</button>
        </div>
    </div>
</form>

<div class="card mb-4">
    <div class="card-header">Cartera para cobro</div>
    <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Num Venta</th>
                    <th>Cliente</th>
                    <th>Zona</th>
                    <th>Cobrador</th>
                    <th>Total</th>
                    <th>Abonado</th>
                    <th>Restante</th>
                    <th>Estatus</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted py-4">Sin cartera para mostrar.</td></tr>
            }
            else
            {
                foreach (var row in Model)
                {
                    <tr>
                        <td>@row.NumVenta</td>
                        <td>@row.NombreCliente</td>
                        <td>@row.Zona</td>
                        <td>@row.Cobrador</td>
                        <td>@row.ImporteTotal.ToString("0.00")</td>
                        <td>@row.ImporteAbonado.ToString("0.00")</td>
                        <td>@row.ImporteRestante.ToString("0.00")</td>
                        <td>@row.Estatus</td>
                        <td class="text-end">
                            @if (row.ImporteRestante > 0)
                            {
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Cobros" asp-action="Register" asp-route-id="@row.IdV" asp-route-profile="@selected">Registrar</a>
                            }
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

<div class="card">
    <div class="card-header">Historial de cobros</div>
    <div class="card-body table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>ID_CC</th>
                    <th>ID_V</th>
                    <th>NUM_VENTA</th>
                    <th>NOMBRE CLIENTE</th>
                    <th>IMPORTE DE COBRO</th>
                    <th>FECHA DE COBRO</th>
                    <th>OBSERVACION COBRO</th>
                    <th>FECHA CAPTURA</th>
                    <th>IMPORTE TOTAL</th>
                    <th>IMPORTE RESTANTE</th>
                    <th>ESTADO_CC</th>
                    <th>USUARIO</th>
                    <th>IMPORTE ABONADO</th>
                    <th>ESTATUS</th>
                    <th>ZONA</th>
                    <th>DIA COBRO PREVISTO</th>
                    <th>DIA COBRADO</th>
                    <th>COORDENADAS COBRO</th>
                </tr>
            </thead>
            <tbody>
            @if (history.Count == 0)
            {
                <tr><td colspan="18" class="text-center text-muted py-4">Sin cobros registrados.</td></tr>
            }
            else
            {
                foreach (var c in history)
                {
                    <tr>
                        <td>@c.IdCc</td>
                        <td>@c.IdV</td>
                        <td>@c.NumVenta</td>
                        <td>@c.NombreCliente</td>
                        <td>@c.ImporteCobro.ToString("0.00")</td>
                        <td>@c.FechaCobro.ToString("yyyy-MM-dd")</td>
                        <td>@c.ObservacionCobro</td>
                        <td>@c.FechaCaptura.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@c.ImporteTotal.ToString("0.00")</td>
                        <td>@c.ImporteRestante.ToString("0.00")</td>
                        <td>@c.EstadoCc</td>
                        <td>@c.Usuario</td>
                        <td>@c.ImporteAbonado.ToString("0.00")</td>
                        <td>@c.Estatus</td>
                        <td>@c.Zona</td>
                        <td>@c.DiaCobroPrevisto</td>
                        <td>@c.DiaCobrado</td>
                        <td>@c.CoordenadasCobro</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
