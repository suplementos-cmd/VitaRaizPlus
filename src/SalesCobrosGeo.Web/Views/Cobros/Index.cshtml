@model SalesCobrosGeo.Web.Models.Sales.CollectorPortfolioViewModel
@{
    ViewData["Title"] = "Perfil Cobrador";
    var totalRestante = Model.Sales.Sum(x => x.ImporteRestante);
    var hasBack = Model.ShowAll || !string.IsNullOrWhiteSpace(Model.SelectedDay) || !string.IsNullOrWhiteSpace(Model.SelectedStatus) || !string.IsNullOrWhiteSpace(Model.SelectedZone);
    var showMobileSearch = Model.ShowAll || !string.IsNullOrWhiteSpace(Model.SelectedZone);

    string? backDay = null;
    string? backStatus = null;
    string? backZone = null;
    bool? backAll = null;

    if (!string.IsNullOrWhiteSpace(Model.SelectedZone))
    {
        backDay = Model.SelectedDay;
        backStatus = Model.SelectedStatus;
    }
    else if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
    {
        backDay = Model.SelectedDay;
    }
    else if (Model.ShowAll)
    {
        backAll = false;
    }

    string ResolveImage(string? path, string fallback) =>
        string.IsNullOrWhiteSpace(path) ? fallback :
        (path.StartsWith("http", StringComparison.OrdinalIgnoreCase) || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/", StringComparison.OrdinalIgnoreCase)
            ? path
            : "/" + path);

    string StatusClass(string status) => status.ToUpperInvariant() switch
    {
        "POR INICIAR" => "status-chip status-start",
        "AL CORRIENTE" => "status-chip status-current",
        "ATRASADO" => "status-chip status-late",
        "LIQUIDADO" => "status-chip status-done",
        _ => "status-chip"
    };

    string StatusIcon(string status) => status.ToUpperInvariant() switch
    {
        "POR INICIAR" => "PI",
        "AL CORRIENTE" => "AC",
        "ATRASADO" => "AT",
        "LIQUIDADO" => "OK",
        _ => "ES"
    };

    string StatusAccent(string status) => status.ToUpperInvariant() switch
    {
        "AL CORRIENTE" => "green",
        "ATRASADO" => "red",
        "PASAR MANANA" => "orange",
        "PROXIMA SEMANA" => "pink",
        _ => string.Empty
    };

    string CleanPhone(string? phone) => string.IsNullOrWhiteSpace(phone) ? string.Empty : new string(phone.Where(char.IsDigit).ToArray());

    var mobileContext = !string.IsNullOrWhiteSpace(Model.SelectedZone)
        ? $"{Model.SelectedDay} / {Model.SelectedStatus} / {Model.SelectedZone}"
        : !string.IsNullOrWhiteSpace(Model.SelectedStatus)
            ? $"{Model.SelectedDay} / {Model.SelectedStatus}"
            : !string.IsNullOrWhiteSpace(Model.SelectedDay)
                ? Model.SelectedDay
                : Model.ShowAll
                    ? "Todas las cuentas"
                    : "Todo";
}

<div class="collector-mobile-app">
    <header class="collector-mobile-header">
        <div class="collector-mobile-topbar">
            <a class="collector-mobile-navbtn @(hasBack ? string.Empty : "is-menu")"
               asp-action="Index"
               asp-route-profile="@Model.Profile"
               asp-route-day="@backDay"
               asp-route-status="@backStatus"
               asp-route-zone="@backZone"
               asp-route-all="@backAll"
               aria-label="@(hasBack ? "Volver" : "Menu")">
                @(hasBack ? "←" : "≡")
            </a>
            <div class="collector-mobile-brandwrap">
                <div class="collector-mobile-brandtitle">COBROS</div>
                <div class="collector-mobile-brandmeta">@mobileContext</div>
            </div>
            <div class="collector-mobile-actions">
                <a class="collector-mobile-chip @(Model.ShowAll ? "active" : string.Empty)"
                   asp-action="Index"
                   asp-route-profile="@Model.Profile"
                   asp-route-all="true">Todo</a>
                <a class="collector-mobile-iconbtn"
                   asp-action="Index"
                   asp-route-profile="@Model.Profile"
                   asp-route-day="@Model.SelectedDay"
                   asp-route-status="@Model.SelectedStatus"
                   asp-route-zone="@Model.SelectedZone"
                   asp-route-all="@(Model.ShowAll ? true : null)"
                   aria-label="Recargar">↻</a>
            </div>
        </div>

        <div class="collector-mobile-summarybar">
            <div class="collector-mobile-summaryitem">
                <span class="collector-mobile-summarylabel">Cuentas</span>
                <strong id="collectorMobileCount">@Model.Sales.Count</strong>
            </div>
            <div class="collector-mobile-summaryitem money">
                <span class="collector-mobile-summarylabel">Restante</span>
                <strong>@totalRestante.ToString("0.00")</strong>
            </div>
        </div>

        @if (showMobileSearch)
        {
            <div class="collector-mobile-searchbar">
                <span class="collector-mobile-searchicon">⌕</span>
                <input id="collectorMobileSearch"
                       type="search"
                       class="collector-mobile-searchinput"
                       placeholder="Buscar cliente, zona o venta"
                       autocomplete="off" />
            </div>
        }
    </header>

    @if (Model.ShowAll)
    {
        <div class="collector-mobile-list collector-mobile-sales" id="collectorMobileSalesList">
            @foreach (var item in Model.Sales)
            {
                var photo = string.IsNullOrWhiteSpace(item.FotoCliente)
                    ? ResolveImage(item.FotoFachada, "https://placehold.co/160x120?text=Venta")
                    : ResolveImage(item.FotoCliente, "https://placehold.co/160x120?text=Venta");
                var cleanPhone = CleanPhone(item.Celular);
                var mapLink = string.IsNullOrWhiteSpace(item.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordenadas)}";
                var searchText = $"{item.NombreCliente} {item.Zona} {item.NumVenta} {item.DiaCobroPrevisto} {item.Estatus}".ToLowerInvariant();
                <article class="collector-mobile-sale-row" data-search="@searchText">
                    <a class="collector-mobile-sale-link" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                        <img class="collector-mobile-thumb" src="@photo" alt="@item.NombreCliente" loading="lazy" decoding="async" />
                        <div class="collector-mobile-sale-main">
                            <div class="collector-mobile-sale-head">
                                <div class="collector-mobile-sale-name">@item.NombreCliente</div>
                                <span class="collector-mobile-chevron">›</span>
                            </div>
                            <div class="collector-mobile-sale-zone">@item.Zona</div>
                            <div class="collector-mobile-sale-meta">#@item.NumVenta • @item.DiaCobroPrevisto • @item.ImporteRestante.ToString("0.00")</div>
                            <div class="collector-mobile-sale-state @StatusAccent(item.Estatus)">@item.Estatus</div>
                        </div>
                    </a>
                    <div class="collector-mobile-mini-actions">
                        @if (!string.IsNullOrWhiteSpace(cleanPhone))
                        {
                            <a href="tel:@cleanPhone" aria-label="Llamar">TEL</a>
                        }
                        <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)" aria-label="Abrir mapa">MAP</a>
                    </div>
                </article>
            }
        </div>
        <div class="collector-mobile-emptysearch" id="collectorMobileEmptySearch" hidden>
            <strong>No encontramos coincidencias.</strong>
            <span>Prueba con otro nombre, zona o numero de venta.</span>
        </div>
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedDay))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Days)
            {
                <a class="collector-mobile-row day" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@item.Day">
                    <span class="collector-mobile-row-icon day">D</span>
                    <span class="collector-mobile-row-label">@item.Day</span>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow">›</span>
                </a>
            }
        </div>
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedStatus))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Statuses)
            {
                <a class="collector-mobile-row status @StatusAccent(item.Status)" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@item.Status">
                    <span class="collector-mobile-row-icon status">E</span>
                    <span class="collector-mobile-row-label">@item.Status</span>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow">›</span>
                </a>
            }
        </div>
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedZone))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Zones)
            {
                <a class="collector-mobile-row zone" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@item.Zone">
                    <span class="collector-mobile-row-icon zone">Z</span>
                    <span class="collector-mobile-row-label">@item.Zone</span>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow">›</span>
                </a>
            }
        </div>
    }
    else
    {
        <div class="collector-mobile-list collector-mobile-sales" id="collectorMobileSalesList">
            @foreach (var item in Model.Sales)
            {
                var photo = string.IsNullOrWhiteSpace(item.FotoCliente)
                    ? ResolveImage(item.FotoFachada, "https://placehold.co/160x120?text=Venta")
                    : ResolveImage(item.FotoCliente, "https://placehold.co/160x120?text=Venta");
                var cleanPhone = CleanPhone(item.Celular);
                var mapLink = string.IsNullOrWhiteSpace(item.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordenadas)}";
                var searchText = $"{item.NombreCliente} {item.Zona} {item.NumVenta} {item.DiaCobroPrevisto} {item.Estatus}".ToLowerInvariant();
                <article class="collector-mobile-sale-row" data-search="@searchText">
                    <a class="collector-mobile-sale-link" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                        <img class="collector-mobile-thumb" src="@photo" alt="@item.NombreCliente" loading="lazy" decoding="async" />
                        <div class="collector-mobile-sale-main">
                            <div class="collector-mobile-sale-head">
                                <div class="collector-mobile-sale-name">@item.NombreCliente</div>
                                <span class="collector-mobile-chevron">›</span>
                            </div>
                            <div class="collector-mobile-sale-zone">@item.Zona</div>
                            <div class="collector-mobile-sale-meta">#@item.NumVenta • @item.ImporteRestante.ToString("0.00")</div>
                            <div class="collector-mobile-sale-state @StatusAccent(item.Estatus)">@item.Estatus</div>
                        </div>
                    </a>
                    <div class="collector-mobile-mini-actions">
                        @if (!string.IsNullOrWhiteSpace(cleanPhone))
                        {
                            <a href="tel:@cleanPhone" aria-label="Llamar">TEL</a>
                        }
                        <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)" aria-label="Abrir mapa">MAP</a>
                    </div>
                </article>
            }
        </div>
        <div class="collector-mobile-emptysearch" id="collectorMobileEmptySearch" hidden>
            <strong>No encontramos coincidencias.</strong>
            <span>Prueba con otro nombre, zona o numero de venta.</span>
        </div>
    }
</div>

<div class="collector-shell collector-desktop-shell">
    <aside class="collector-sidebar-shell">
        <div class="collector-hub-top desktop-panel-head">
            <div>
                <h1 class="collector-hub-title">Cobros</h1>
                <div class="collector-hub-subtitle">Ruta por dia, estado, zona y ventas pendientes</div>
            </div>
            <div class="collector-hub-actions">
                @if (Model.ShowAll)
                {
                    <a class="btn btn-outline-secondary collector-icon-btn" asp-action="Index" asp-route-profile="@Model.Profile">
                        <span class="btn-icon-mobile">GR</span>
                        <span class="btn-text-mobile">Agrupado</span>
                    </a>
                }
                else
                {
                    <a class="btn btn-outline-primary collector-icon-btn" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-all="true">
                        <span class="btn-icon-mobile">TO</span>
                        <span class="btn-text-mobile">Ver todos</span>
                    </a>
                }
            </div>
        </div>

        <form method="get" class="collector-filter mb-3">
            <input type="hidden" name="day" value="@Model.SelectedDay" />
            <input type="hidden" name="status" value="@Model.SelectedStatus" />
            <input type="hidden" name="zone" value="@Model.SelectedZone" />
            <input type="hidden" name="all" value="@(Model.ShowAll ? "true" : "false")" />
            <div class="collector-filter-grid collector-filter-grid-stack">
                <div>
                    <label class="form-label mb-1">Cobrador</label>
                    <select class="form-select" name="profile">
                        <option value="">Todos</option>
                        @foreach (var p in Model.Profiles)
                        {
                            if (string.Equals(Model.Profile, p.Code, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@p.Code" selected>@p.Name</option>
                            }
                            else
                            {
                                <option value="@p.Code">@p.Name</option>
                            }
                        }
                    </select>
                </div>
                <button class="btn btn-primary collector-btn" type="submit">Aplicar</button>
            </div>
        </form>

        <div class="collector-breadcrumbs mb-3">
            <a asp-action="Index" asp-route-profile="@Model.Profile">Dias</a>
            @if (!string.IsNullOrWhiteSpace(Model.SelectedDay))
            {
                <span>/</span>
                <a asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay">@Model.SelectedDay</a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
            {
                <span>/</span>
                <a asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus">@Model.SelectedStatus</a>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SelectedZone))
            {
                <span>/</span>
                <span>@Model.SelectedZone</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SelectedDay) || Model.ShowAll)
        {
            <div class="collector-level-banner mb-3">
                @if (!string.IsNullOrWhiteSpace(Model.SelectedDay))
                {
                    <div class="collector-level-chip">@Model.SelectedDay</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
                {
                    <div class="collector-level-chip">@Model.SelectedStatus</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SelectedZone))
                {
                    <div class="collector-level-chip">@Model.SelectedZone</div>
                }
                @if (Model.ShowAll)
                {
                    <div class="collector-level-chip">TODAS</div>
                }
                <div class="collector-level-stat">
                    <strong>@Model.Sales.Count</strong>
                    <span>ventas</span>
                </div>
                <div class="collector-level-stat collector-level-money">
                    <strong>@totalRestante.ToString("0.00")</strong>
                    <span>restante</span>
                </div>
            </div>
        }
    </aside>

    <div class="collector-main-shell">
        @if (Model.ShowAll)
        {
            <section>
                <div class="collector-section-title">Todas las cuentas pendientes</div>
                <div class="collector-sales-list all-view">
                    @foreach (var item in Model.Sales)
                    {
                        var photo = string.IsNullOrWhiteSpace(item.FotoCliente)
                            ? ResolveImage(item.FotoFachada, "https://placehold.co/160x120?text=Venta")
                            : ResolveImage(item.FotoCliente, "https://placehold.co/160x120?text=Venta");
                        var cleanPhone = CleanPhone(item.Celular);
                        var mapLink = string.IsNullOrWhiteSpace(item.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordenadas)}";

                        <article class="collector-sale-card compact collector-sale-card-actions">
                            <a class="collector-sale-card-mainlink" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                                <img class="collector-sale-photo" src="@photo" alt="@item.NombreCliente" loading="lazy" decoding="async" />
                                <div class="collector-sale-main">
                                    <div class="collector-sale-main-top">
                                        <div class="collector-sale-client">@item.NombreCliente</div>
                                        <div class="collector-sale-rest">@item.ImporteRestante.ToString("0.00")</div>
                                    </div>
                                    <div class="collector-sale-meta">Venta #@item.NumVenta • @item.Zona</div>
                                    <div class="collector-sale-meta">@item.DiaCobroPrevisto • @item.Cobrador</div>
                                </div>
                                <div class="collector-sale-side compact">
                                    <div class="@StatusClass(item.Estatus)">
                                        <span class="status-icon-mobile">@StatusIcon(item.Estatus)</span>
                                        <span class="status-text-mobile">@item.Estatus</span>
                                    </div>
                                </div>
                            </a>
                            <div class="collector-quick-actions">
                                @if (!string.IsNullOrWhiteSpace(cleanPhone))
                                {
                                    <a class="btn btn-sm btn-outline-secondary" href="tel:@cleanPhone">LL</a>
                                    <a class="btn btn-sm btn-outline-success" href="https://wa.me/@cleanPhone" target="_blank" rel="noopener">WA</a>
                                }
                                <a class="btn btn-sm btn-outline-primary @(mapLink == "#" ? "disabled" : string.Empty)" href="@mapLink" target="_blank" rel="noopener">MP</a>
                                <a class="btn btn-sm btn-success" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">CB</a>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
        else if (string.IsNullOrWhiteSpace(Model.SelectedDay))
        {
            <section>
                <div class="collector-section-title">Dias con ventas pendientes</div>
                <div class="collector-choice-grid">
                    @if (Model.Days.Count == 0)
                    {
                        <div class="app-empty-state compact">
                            <strong>No hay ventas pendientes por cobrar.</strong>
                            <span>Cuando entren nuevas cuentas apareceran aqui agrupadas por dia.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.Days)
                        {
                            <a class="collector-choice-card" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@item.Day">
                                <div class="collector-choice-label">@item.Day</div>
                                <div class="collector-choice-value">@item.Count</div>
                                <div class="collector-choice-meta">cuentas</div>
                            </a>
                        }
                    }
                </div>
            </section>
        }
        else if (string.IsNullOrWhiteSpace(Model.SelectedStatus))
        {
            <section>
                <div class="collector-section-title">Estados para @Model.SelectedDay</div>
                <div class="collector-choice-grid">
                    @foreach (var item in Model.Statuses)
                    {
                        <a class="collector-choice-card compact-status" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@item.Status">
                            <div class="@StatusClass(item.Status)">
                                <span class="status-icon-mobile">@StatusIcon(item.Status)</span>
                                <span class="status-text-mobile">@item.Status</span>
                            </div>
                            <div class="collector-choice-value">@item.Count</div>
                            <div class="collector-choice-meta">ventas</div>
                        </a>
                    }
                </div>
            </section>
        }
        else if (string.IsNullOrWhiteSpace(Model.SelectedZone))
        {
            <section>
                <div class="collector-section-title">Zonas en @Model.SelectedStatus</div>
                <div class="collector-choice-grid">
                    @foreach (var item in Model.Zones)
                    {
                        <a class="collector-choice-card" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@item.Zone">
                            <div class="collector-choice-label">@item.Zone</div>
                            <div class="collector-choice-value">@item.Count</div>
                            <div class="collector-choice-meta">ventas</div>
                        </a>
                    }
                </div>
            </section>
        }
        else
        {
            <section>
                <div class="collector-section-title">Ventas en @Model.SelectedZone</div>
                <div class="collector-sales-list">
                    @if (Model.Sales.Count == 0)
                    {
                        <div class="app-empty-state compact">
                            <strong>No hay ventas para esta seleccion.</strong>
                            <span>Prueba con otro estado o usa el modo ver todos.</span>
                        </div>
                    }
                    else
                    {
                        @foreach (var item in Model.Sales)
                        {
                            var photo = string.IsNullOrWhiteSpace(item.FotoCliente)
                                ? ResolveImage(item.FotoFachada, "https://placehold.co/160x120?text=Venta")
                                : ResolveImage(item.FotoCliente, "https://placehold.co/160x120?text=Venta");
                            var cleanPhone = CleanPhone(item.Celular);
                            var mapLink = string.IsNullOrWhiteSpace(item.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordenadas)}";

                            <article class="collector-sale-card compact collector-sale-card-actions">
                                <a class="collector-sale-card-mainlink" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                                    <img class="collector-sale-photo" src="@photo" alt="@item.NombreCliente" loading="lazy" decoding="async" />
                                    <div class="collector-sale-main">
                                        <div class="collector-sale-main-top">
                                            <div class="collector-sale-client">@item.NombreCliente</div>
                                            <div class="collector-sale-rest">@item.ImporteRestante.ToString("0.00")</div>
                                        </div>
                                        <div class="collector-sale-meta">Venta #@item.NumVenta • @item.Zona</div>
                                        <div class="collector-sale-meta">@item.DiaCobroPrevisto • @item.Cobrador</div>
                                    </div>
                                    <div class="collector-sale-side compact">
                                        <div class="@StatusClass(item.Estatus)">
                                            <span class="status-icon-mobile">@StatusIcon(item.Estatus)</span>
                                            <span class="status-text-mobile">@item.Estatus</span>
                                        </div>
                                    </div>
                                </a>
                                <div class="collector-quick-actions">
                                    @if (!string.IsNullOrWhiteSpace(cleanPhone))
                                    {
                                        <a class="btn btn-sm btn-outline-secondary" href="tel:@cleanPhone">LL</a>
                                        <a class="btn btn-sm btn-outline-success" href="https://wa.me/@cleanPhone" target="_blank" rel="noopener">WA</a>
                                    }
                                    <a class="btn btn-sm btn-outline-primary @(mapLink == "#" ? "disabled" : string.Empty)" href="@mapLink" target="_blank" rel="noopener">MP</a>
                                    <a class="btn btn-sm btn-success" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">CB</a>
                                </div>
                            </article>
                        }
                    }
                </div>
            </section>
        }
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('collectorMobileSearch');
            const list = document.getElementById('collectorMobileSalesList');
            const empty = document.getElementById('collectorMobileEmptySearch');
            const count = document.getElementById('collectorMobileCount');
            if (!input || !list || !count) {
                return;
            }

            const rows = Array.from(list.querySelectorAll('.collector-mobile-sale-row'));
            const initialCount = rows.length;

            const applyFilter = () => {
                const term = input.value.trim().toLowerCase();
                let visible = 0;
                rows.forEach((row) => {
                    const haystack = row.getAttribute('data-search') || '';
                    const match = term.length === 0 || haystack.includes(term);
                    row.hidden = !match;
                    if (match) {
                        visible += 1;
                    }
                });
                count.textContent = String(visible);
                if (empty) {
                    empty.hidden = visible !== 0;
                }
            };

            input.addEventListener('input', applyFilter);
            count.textContent = String(initialCount);
        })();
    </script>
}
