@model IReadOnlyList<SalesCobrosGeo.Web.Models.Sales.CollectorPortfolioItem>
@using SalesCobrosGeo.Web.Models.Sales
@{
    ViewData["Title"] = "Perfil Cobrador";
    var profiles = ViewBag.Profiles as IReadOnlyList<CatalogOption> ?? [];
    var selected = ViewBag.Profile as string;

    var dayOrder = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
    {
        ["LUNES"] = 1,
        ["MARTES"] = 2,
        ["MIERCOLES"] = 3,
        ["MIERCOLES"] = 3,
        ["JUEVES"] = 4,
        ["VIERNES"] = 5,
        ["SABADO"] = 6,
        ["DOMINGO"] = 7
    };

    static string NormalizeText(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim().ToUpperInvariant();
    }

    var pending = Model
        .Where(x => x.ImporteRestante > 0)
        .ToList();

    var grouped = pending
        .GroupBy(x => new
        {
            Day = NormalizeText(x.DiaCobroPrevisto, "SIN DIA"),
            Zone = NormalizeText(x.Zona, "SIN ZONA")
        })
        .OrderBy(g => dayOrder.TryGetValue(g.Key.Day, out var pos) ? pos : 99)
        .ThenBy(g => g.Key.Day)
        .ThenBy(g => g.Key.Zone)
        .ToList();
}

<div class="collector-mobile">
    <div class="collector-toolbar">
        <div>
            <h1 class="collector-title">Perfil Cobrador</h1>
            <div class="collector-subtitle">Solo ventas pendientes, agrupadas por dia de cobro y zona</div>
        </div>
    </div>

    @if (TempData["CobroMessage"] is string msg)
    {
        <div class="alert alert-success">@msg</div>
    }

    <form method="get" class="collector-filter mb-3">
        <div class="collector-filter-grid">
            <div>
                <label class="form-label mb-1">Usuario cobrador</label>
                <select class="form-select" name="profile">
                    <option value="">Todos</option>
                    @foreach (var p in profiles)
                    {
                        if (string.Equals(selected, p.Code, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@p.Code" selected>@p.Name</option>
                        }
                        else
                        {
                            <option value="@p.Code">@p.Name</option>
                        }
                    }
                </select>
            </div>
            <button class="btn btn-primary collector-btn" type="submit">Filtrar</button>
        </div>
    </form>

    @if (pending.Count == 0)
    {
        <div class="card card-body text-center text-muted">No hay ventas pendientes por cobrar.</div>
    }
    else
    {
        var currentDay = string.Empty;
        foreach (var zoneGroup in grouped)
        {
            if (!string.Equals(currentDay, zoneGroup.Key.Day, StringComparison.OrdinalIgnoreCase))
            {
                currentDay = zoneGroup.Key.Day;
                <div class="collector-day-head mt-3">
                    <span class="collector-day-star">?</span>
                    <span>@currentDay</span>
                </div>
            }

            <section class="collector-zone-block">
                <div class="collector-zone-head">
                    <span class="collector-zone-name">@zoneGroup.Key.Zone</span>
                    <span class="collector-zone-count">@zoneGroup.Count() ventas</span>
                </div>

                <div class="collector-cards">
                    @foreach (var row in zoneGroup)
                    {
                        <article class="collector-card">
                            <div class="collector-card-main">
                                <div class="collector-client">@row.NombreCliente</div>
                                <div class="collector-meta">Venta #@row.NumVenta</div>
                                <div class="collector-meta">Cobrador: @row.Cobrador</div>
                            </div>

                            <div class="collector-balance">
                                <div><span>Total</span><strong>@row.ImporteTotal.ToString("0.00")</strong></div>
                                <div><span>Abonado</span><strong>@row.ImporteAbonado.ToString("0.00")</strong></div>
                                <div class="collector-restante"><span>Restante</span><strong>@row.ImporteRestante.ToString("0.00")</strong></div>
                            </div>

                            <div class="collector-actions">
                                <a class="btn btn-sm btn-outline-primary" asp-controller="Cobros" asp-action="Register" asp-route-id="@row.IdV" asp-route-profile="@selected">Registrar cobro</a>
                            </div>
                        </article>
                    }
                </div>
            </section>
        }
    }
</div>
