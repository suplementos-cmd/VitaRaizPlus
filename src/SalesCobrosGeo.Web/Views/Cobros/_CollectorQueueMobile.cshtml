@using SalesCobrosGeo.Web.Models.Collections
@model CollectorQueueViewModel
@functions {
    string SaleTone(CollectorClientListItem item) => item.Status.ToUpperInvariant() switch
    {
        "ATRASADO" => "danger",
        "CANCELADO" => "muted",
        "LIQUIDADO" => "success",
        "AL CORRIENTE" => "success",
        "PARCIAL" => "warning",
        "POR INICIAR" => "neutral",
        _ when item.HasPromise => "info",
        _ => "neutral"
    };

    string SaleFlag(string tone) => tone switch
    {
        "danger" => "Urgente",
        "muted" => "Cancelada",
        "success" => "Estable",
        "warning" => "Seguimiento",
        "info" => "Promesa",
        _ => "Pendiente"
    };

    string StatusIcon(string icon) => icon switch
    {
        "promise" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        "followup" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M21 12a9 9 0 1 1-3-6.7'/><path d='M21 3v6h-6'/></svg>",
        "overdue" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        "recovery" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M3 12h18'/><path d='M15 6l6 6-6 6'/></svg>",
        "current" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='m5 13 4 4L19 7'/></svg>",
        "liquidated" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='m9 12 2 2 4-4'/></svg>",
        "cancelled" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };
}
<div class="collector-mobile-shell compact-queue compact-tree-queue">
    <div class="collector-mobile-daybar" aria-label="Dias de cobro">
        @foreach (var day in Model.DayTabs)
        {
            <a class="collector-mobile-daytab @(day.IsActive ? "active" : string.Empty)" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@day.Code" asp-route-groupBy="status" asp-route-filter="all" title="@day.Label">
                <span>@day.ShortLabel</span>
            </a>
        }
    </div>

    <div class="collector-mobile-searchbar" data-cobros-search-shell="true" hidden>
        <span class="collector-mobile-searchicon">&#8981;</span>
        <input id="collectorRoleSearch" type="search" class="collector-mobile-searchinput" placeholder="@Model.SearchPlaceholder" autocomplete="off" />
    </div>

    <div id="collectorRoleSearchList">
        @if (string.IsNullOrWhiteSpace(Model.SelectedStatus))
        {
            <div class="collector-mobile-statusstack">
                @foreach (var status in Model.MobileStatusGroups)
                {
                    <a class="collector-mobile-statusitem @status.Tone collector-mobile-statuslink" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@status.Key" asp-route-groupBy="status" asp-route-filter="all" data-search="@(status.Title.ToLowerInvariant())">
                        <span class="collector-mobile-statusicon @status.Tone">@Html.Raw(StatusIcon(status.Icon))</span>
                        <div class="collector-mobile-statuscopy">
                            <strong>@status.Title</strong>
                            <span>@status.Count cuentas</span>
                        </div>
                        <div class="collector-mobile-statusaside">
                            <span class="collector-mobile-treecount">@status.Count</span>
                            <span class="collector-mobile-treearrow">&rsaquo;</span>
                        </div>
                    </a>
                }
            </div>
        }
        else if (string.IsNullOrWhiteSpace(Model.SelectedZone))
        {
            <div class="collector-mobile-zonestack">
                @foreach (var zone in Model.MobileZoneGroups)
                {
                    <a class="collector-mobile-zoneitem" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@zone.Zone" asp-route-groupBy="status" asp-route-filter="all" data-search="@zone.Zone.ToLowerInvariant()">
                        <div class="collector-mobile-zonecopy">
                            <strong>@zone.Zone</strong>
                            <span>@zone.Accounts ventas por cobrar</span>
                        </div>
                        <div class="collector-mobile-statusaside">
                            <span class="collector-mobile-treecount">@zone.Accounts</span>
                            <span class="collector-mobile-treearrow">&rsaquo;</span>
                        </div>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="collector-mobile-compactlist">
                @foreach (var item in Model.MobileZoneClients)
                {
                    var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
                    var tone = SaleTone(item);
                    <article class="collector-mobile-clientrow compact zone-child status-@tone" data-search="@(item.Name.ToLowerInvariant()) @(item.Zone.ToLowerInvariant()) @(item.ReferenceText.ToLowerInvariant()) @(item.NumVenta)">
                        <a class="collector-mobile-clientmain" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                            <strong>@item.Name <span class="collector-inline-flag @tone">@SaleFlag(tone)</span></strong>
                            <span>@item.Zone · @item.NextAction</span>
                        </a>
                        <div class="collector-mobile-clientactions">
                            @if (!string.IsNullOrWhiteSpace(item.Phone)) { <a href="tel:@item.Phone">LL</a> }
                            <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)">MP</a>
                            <a asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">RG</a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</div>
