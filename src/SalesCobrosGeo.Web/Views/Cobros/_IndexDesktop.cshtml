@model SalesCobrosGeo.Web.Models.Sales.CollectorPortfolioViewModel
@{
    var totalRestante = Model.Sales.Sum(x => x.ImporteRestante);
    var desktopSubtitle = Model.ShowAll
        ? "Cartera completa pendiente con acceso rapido a cada venta."
        : !string.IsNullOrWhiteSpace(Model.SelectedZone)
            ? "Lista compacta para revisar y registrar cobros de la zona activa."
            : !string.IsNullOrWhiteSpace(Model.SelectedStatus)
                ? "Filtrado por estado para que priorices las cuentas mas urgentes."
                : !string.IsNullOrWhiteSpace(Model.SelectedDay)
                    ? "Selecciona una zona o trabaja directamente las cuentas del dia."
                    : "Usa el arbol lateral para navegar por dia, estado y zona.";

    string ResolveImage(string? path, string fallback) =>
        string.IsNullOrWhiteSpace(path) ? fallback :
        (path.StartsWith("http", StringComparison.OrdinalIgnoreCase) || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/", StringComparison.OrdinalIgnoreCase)
            ? path
            : "/" + path);

    string StatusIcon(string status) => status.ToUpperInvariant() switch
    {
        "POR INICIAR" => "PI",
        "AL CORRIENTE" => "AC",
        "ATRASADO" => "AT",
        "LIQUIDADO" => "OK",
        _ => "ES"
    };

    string StatusAccent(string status) => status.ToUpperInvariant() switch
    {
        "AL CORRIENTE" => "green",
        "ATRASADO" => "red",
        "PASAR MANANA" => "orange",
        "PROXIMA SEMANA" => "pink",
        _ => string.Empty
    };

    string CleanPhone(string? phone) => string.IsNullOrWhiteSpace(phone) ? string.Empty : new string(phone.Where(char.IsDigit).ToArray());
}

<div class="collector-desktop-workbench-modern">
    <aside class="collector-desktop-sidebar-compact">
        <form method="get" class="collector-filter-modern" data-ajaxify="true" data-ajax-target=".collector-desktop-workbench-modern">
            <input type="hidden" name="day" value="@Model.SelectedDay" />
            <input type="hidden" name="status" value="@Model.SelectedStatus" />
            <input type="hidden" name="zone" value="@Model.SelectedZone" />
            <input type="hidden" name="all" value="@(Model.ShowAll ? "true" : "false")" />
            <div class="collector-filter-group-modern">
                <label for="collectorProfile">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                    Cobrador
                </label>
                <div class="collector-filter-row-modern">
                    <select id="collectorProfile" class="form-select form-select-sm" name="profile">
                        <option value="">Todos</option>
                        @foreach (var p in Model.Profiles)
                        {
                            if (string.Equals(Model.Profile, p.Code, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@p.Code" selected>@p.Name</option>
                            }
                            else
                            {
                                <option value="@p.Code">@p.Name</option>
                            }
                        }
                    </select>
                    <button class="btn btn-sm btn-primary" type="submit">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="m5 13 4 4L19 7"/>
                        </svg>
                    </button>
                </div>
            </div>
        </form>

        <div class="collector-summary-modern">
            <div class="collector-summary-card-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <div>
                    <span>Cuentas</span>
                    <strong id="collectorDesktopCount">@Model.Sales.Count</strong>
                </div>
            </div>
            <div class="collector-summary-card-modern money">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                </svg>
                <div>
                    <span>Restante</span>
                    <strong>$@totalRestante.ToString("N0")</strong>
                </div>
            </div>
        </div>

        <nav class="collector-tree-modern" aria-label="Árbol de cobros">
            @foreach (var dayGroup in Model.DayTree)
            {
                var dayKey = dayGroup.Day?.Trim() ?? string.Empty;
                var isDaySelected = string.Equals(dayKey, Model.SelectedDay, StringComparison.OrdinalIgnoreCase);
                var isOpen = isDaySelected || string.IsNullOrWhiteSpace(Model.SelectedDay);
                <section class="collector-tree-group-modern @(isDaySelected ? "active" : string.Empty) @(isOpen ? "is-open" : string.Empty)">
                    <div class="collector-day-header-modern">
                        <button type="button" class="collector-toggle-modern @(isOpen ? "open" : string.Empty)" data-tree-toggle aria-expanded="@(isOpen ? "true" : "false")" aria-label="Mostrar u ocultar estados de @dayGroup.Day">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <path d="m9 18 6-6-6-6"/>
                            </svg>
                        </button>
                        <a class="collector-day-link-modern" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@dayGroup.Day" data-ajax-link="true" data-ajax-target=".collector-desktop-workbench-modern">
                            <span class="collector-day-label-modern">@dayGroup.Day</span>
                            <span class="collector-day-count-modern">@dayGroup.Count</span>
                        </a>
                    </div>
                    <div class="collector-status-list-modern" @(isOpen ? null : "hidden")>
                        @foreach (var statusItem in dayGroup.Statuses)
                        {
                            var isStatusSelected = isDaySelected && string.Equals(statusItem.Status?.Trim(), Model.SelectedStatus, StringComparison.OrdinalIgnoreCase);
                            <a class="collector-status-link-modern @(isStatusSelected ? "active" : string.Empty) @StatusAccent(statusItem.Status ?? string.Empty)" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@dayGroup.Day" asp-route-status="@statusItem.Status" data-ajax-link="true" data-ajax-target=".collector-desktop-workbench-modern">
                                <span class="collector-status-dot-modern">@StatusIcon(statusItem.Status ?? string.Empty)</span>
                                <span class="collector-status-label-modern">@statusItem.Status</span>
                                <span class="collector-status-count-modern">@statusItem.Count</span>
                            </a>
                        }
                    </div>
                </section>
            }
        </nav>
    </aside>

    <section class="collector-desktop-main-compact">
        <div class="collector-toolbar-modern">
            <div class="collector-search-modern">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                </svg>
                <input id="collectorDesktopSearch" type="search" placeholder="Buscar cliente, zona o número de venta..." autocomplete="off" />
            </div>
            @if (!string.IsNullOrWhiteSpace(desktopSubtitle))
            {
                <div class="collector-subtitle-modern">@desktopSubtitle</div>
            }
        </div>

        <div class="collector-context-chips-modern">
            @if (Model.ShowAll)
            {
                <span class="collector-chip-modern">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/>
                    </svg>
                    Todas
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SelectedDay))
            {
                <span class="collector-chip-modern">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                    </svg>
                    @Model.SelectedDay
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
            {
                <span class="collector-chip-modern">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <path d="m9 11 3 3L22 4"/>
                    </svg>
                    @Model.SelectedStatus
                </span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SelectedZone))
            {
                <span class="collector-chip-modern">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                    @Model.SelectedZone
                </span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SelectedStatus) && string.IsNullOrWhiteSpace(Model.SelectedZone) && Model.Zones.Count > 0)
        {
            <div class="collector-zone-strip-modern">
                @foreach (var zoneItem in Model.Zones)
                {
                    <a class="collector-zone-pill-modern" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@zoneItem.Zone" data-ajax-link="true" data-ajax-target=".collector-desktop-workbench-modern">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                        </svg>
                        <span>@zoneItem.Zone</span>
                        <strong>@zoneItem.Count</strong>
                    </a>
                }
            </div>
        }

        <div class="collector-list-modern" id="collectorDesktopSalesList">
            @if (Model.Sales.Count == 0)
            {
                <div class="collector-empty-modern">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <strong>No hay cuentas pendientes para esta selección</strong>
                    <span>Prueba con otro día, estado o cobrador para seguir filtrando</span>
                </div>
            }
            else
            {
                @foreach (var item in Model.Sales)
                {
                    var photo = string.IsNullOrWhiteSpace(item.FotoCliente)
                        ? ResolveImage(item.FotoFachada, "https://placehold.co/160x120?text=V")
                        : ResolveImage(item.FotoCliente, "https://placehold.co/160x120?text=V");
                    var cleanPhone = CleanPhone(item.Celular);
                    var mapLink = string.IsNullOrWhiteSpace(item.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordenadas)}";
                    var whatsappLink = string.IsNullOrWhiteSpace(cleanPhone) ? "#" : $"https://wa.me/{cleanPhone}";
                    var searchText = $"{item.NombreCliente} {item.Zona} {item.NumVenta} {item.DiaCobroPrevisto} {item.Estatus} {item.Cobrador}".ToLowerInvariant();
                    <article class="collector-item-compact" data-search="@searchText">
                        <div class="collector-item-image-compact">
                            <img src="@photo" alt="@item.NombreCliente" loading="lazy" decoding="async" />
                        </div>
                        <a class="collector-item-content-compact" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                            <div class="collector-item-main-section">
                                <div class="collector-item-header-section">
                                    <strong class="collector-item-name">@item.NombreCliente</strong>
                                    <span class="collector-item-status @StatusAccent(item.Estatus)">@item.Estatus</span>
                                </div>
                                <div class="collector-item-meta-section">
                                    <span class="collector-item-meta-row">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                                        </svg>
                                        Venta #@item.NumVenta
                                    </span>
                                    <span class="collector-item-meta-row">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                                        </svg>
                                        @item.Zona
                                    </span>
                                    <span class="collector-item-meta-row">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                                        </svg>
                                        @item.DiaCobroPrevisto
                                    </span>
                                </div>
                                <div class="collector-item-collector-section">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                    </svg>
                                    <span>@item.Cobrador</span>
                                </div>
                            </div>
                            <div class="collector-item-amounts-section">
                                <div class="collector-amount-total">
                                    <span>Total</span>
                                    <strong>$@item.ImporteTotal.ToString("N0")</strong>
                                </div>
                                <div class="collector-amount-pending">
                                    <span>Restante</span>
                                    <strong>$@item.ImporteRestante.ToString("N0")</strong>
                                </div>
                            </div>
                        </a>
                        <div class="collector-item-actions-compact">
                            @if (!string.IsNullOrWhiteSpace(cleanPhone))
                            {
                                <a class="collector-action-btn-compact" href="tel:@cleanPhone" title="Llamar">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                    </svg>
                                </a>
                                <a class="collector-action-btn-compact success" href="@whatsappLink" target="_blank" rel="noopener" title="WhatsApp">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                    </svg>
                                </a>
                            }
                            <a class="collector-action-btn-compact @(mapLink == "#" ? "disabled" : string.Empty)" href="@mapLink" target="_blank" rel="noopener" title="Ver mapa">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                            </a>
                            <a class="collector-action-btn-compact primary" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone" title="Registrar cobro">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                </svg>
                            </a>
                        </div>
                    </article>
                }
            }
        </div>

        <div class="collector-empty-search-modern" id="collectorDesktopEmptySearch" hidden>
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <strong>No hay coincidencias para esta búsqueda</strong>
            <span>Prueba con otro cliente, zona o número de venta</span>
        </div>
    </section>
</div>
