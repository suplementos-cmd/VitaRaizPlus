@using SalesCobrosGeo.Web.Models.Collections
@using SalesCobrosGeo.Web.Models.Shared
@model CollectorRouteViewModel
<div class="collector-mobile-shell compact-route">
    <div class="collector-mobile-routebar">
        <strong>@Model.TotalStops paradas</strong>
        <span>@Model.GeoPoints con GPS</span>
        @if (!string.IsNullOrWhiteSpace(Model.RouteUrl))
        {
            <a href="@Model.RouteUrl" target="_blank" rel="noopener">Ruta</a>
        }
    </div>
    <div class="collector-mobile-compactlist route-list">
        @foreach (var item in Model.Clients)
        {
            var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
            <article class="collector-mobile-clientrow compact route-stop">
                <span class="collector-mobile-order">@item.OrderIndex</span>
                <a class="collector-mobile-clientmain" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                    <strong>@item.Name</strong>
                    <span>@item.Zone · @item.NextAction</span>
                </a>
                <div class="collector-mobile-clientactions">
                    <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)">MP</a>
                </div>
            </article>
        }
    </div>
</div>
