@using SalesCobrosGeo.Web.Models.Collections
@model CollectorQueueViewModel
@functions {
    string SaleTone(CollectorClientListItem item) => item.Status.ToUpperInvariant() switch
    {
        _ when item.HasPromiseOverdue => "danger",
        _ when item.IsNotLocated => "warning",
        _ when item.IsRefused => "muted",
        "ATRASADO" => "danger",
        "CANCELADO" => "muted",
        "LIQUIDADO" => "success",
        "AL CORRIENTE" => "success",
        "PARCIAL" => "warning",
        "POR INICIAR" => "neutral",
        _ when item.HasPromise => "info",
        _ => "neutral"
    };

    string SaleIcon(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 9v4'/><path d='M12 17h.01'/><path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/></svg>",
        _ when item.HasPromise => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        _ when item.IsNotLocated => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m21 10-5.2-5.2a2 2 0 0 0-2.8 0L4 14v6h6l9-9a2 2 0 0 0 0-2.8Z'/><path d='M7 17h.01'/></svg>",
        _ when item.IsRefused => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>",
        _ when item.Status.Equals("ATRASADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        _ when item.Status.Equals("LIQUIDADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m5 13 4 4L19 7'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };

    string SaleBadge(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "Promesa vencida",
        _ when item.HasPromise => "Promesa activa",
        _ when item.IsNotLocated => "No localizado",
        _ when item.IsRefused => "Se nego",
        _ => item.Status
    };

    string StatusIcon(string icon) => icon switch
    {
        "promise" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        "followup" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M21 12a9 9 0 1 1-3-6.7'/><path d='M21 3v6h-6'/></svg>",
        "overdue" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        "recovery" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='M3 12h18'/><path d='M15 6l6 6-6 6'/></svg>",
        "current" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><path d='m5 13 4 4L19 7'/></svg>",
        "liquidated" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='m9 12 2 2 4-4'/></svg>",
        "cancelled" => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };
}
<section class="collector-desktop-flow-modern">
    <header class="collector-flow-header-modern">
        <div class="collector-flow-title-section">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            <div>
                <h1>Cobros operativos</h1>
                <p>Etapas organizadas para trabajar eficientemente desde desktop</p>
            </div>
        </div>
        <div class="collector-search-wide-modern">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input id="collectorRoleSearch" type="search" placeholder="@Model.SearchPlaceholder" autocomplete="off" />
        </div>
    </header>

    <nav class="collector-day-tabs-modern" aria-label="Días de cobro">
        @foreach (var day in Model.DayTabs)
        {
            <a class="collector-day-pill-modern @(day.IsActive ? "active" : string.Empty)" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@day.Code" asp-route-groupBy="status" asp-route-filter="all">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                </svg>
                <span>@day.ShortLabel</span>
                <small>@day.Count</small>
            </a>
        }
    </nav>

    <section class="collector-summary-strip-modern">
        @foreach (var summary in Model.HistorySummaryCards)
        {
            var targetUrl = summary.Code == "pending"
                ? Url.Action("CollectorQueue", "Cobros", new { profile = Model.Profile, day = Model.SelectedDay, groupBy = "status", filter = "all" })
                : Url.Action("CollectionHistory", "Cobros", new { profile = Model.Profile, outcome = summary.Code });
            <a class="collector-summary-card-queue @(summary.IsActive ? "active" : string.Empty)" href="@targetUrl">
                <span>@summary.Title</span>
                <strong>@summary.Count</strong>
                <small>@summary.Subtitle</small>
            </a>
        }
    </section>

    <div class="collector-ops-layout-modern" id="collectorRoleSearchList">
        <aside class="collector-panel-modern collector-status-panel-modern">
            <div class="collector-panel-header-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <path d="m9 11 3 3L22 4"/>
                </svg>
                <div>
                    <strong>Estatus</strong>
                    <span>@Model.SelectedDay</span>
                </div>
            </div>
            <div class="collector-status-stack-modern">
                @foreach (var status in Model.MobileStatusGroups)
                {
                    <a class="collector-status-card-modern @(status.Key == Model.SelectedStatus ? "active" : string.Empty) @status.Tone" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@status.Key" asp-route-groupBy="status" asp-route-filter="all" data-search="@(status.Title.ToLowerInvariant())">
                        <span class="collector-status-icon-modern @status.Tone">@Html.Raw(StatusIcon(status.Icon))</span>
                        <div class="collector-status-copy-modern">
                            <strong>@status.Title</strong>
                            <span>@status.Count cuentas</span>
                        </div>
                        <span class="collector-status-badge-modern">@status.Count</span>
                    </a>
                }
            </div>
        </aside>

        <aside class="collector-panel-modern collector-zone-panel-modern">
            <div class="collector-panel-header-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                <div>
                    <strong>Zonas</strong>
                    <span>@(string.IsNullOrWhiteSpace(Model.SelectedStatus) ? "Selecciona un estatus" : Model.SelectedStatus)</span>
                </div>
            </div>
            @if (string.IsNullOrWhiteSpace(Model.SelectedStatus))
            {
                <div class="collector-empty-hint-modern">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                        <path d="m9 11 3 3L22 4"/>
                    </svg>
                    <strong>Elige un estatus</strong>
                    <span>Después verás las zonas filtradas para ese día</span>
                </div>
            }
            else if (Model.MobileZoneGroups.Count == 0)
            {
                <div class="collector-empty-hint-modern">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                    <strong>Sin zonas en este estatus</strong>
                    <span>No hay cuentas para @Model.SelectedStatus en @Model.SelectedDay</span>
                </div>
            }
            else
            {
                <div class="collector-zone-stack-modern">
                    @foreach (var zone in Model.MobileZoneGroups)
                    {
                        <a class="collector-zone-card-modern @(string.Equals(zone.Zone, Model.SelectedZone, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@zone.Zone" asp-route-groupBy="status" asp-route-filter="all" data-search="@zone.Zone.ToLowerInvariant()">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                            </svg>
                            <div>
                                <strong>@zone.Zone</strong>
                                <span>@zone.Accounts ventas por cobrar</span>
                            </div>
                            <span class="collector-zone-badge-modern">@zone.Accounts</span>
                        </a>
                    }
                </div>
            }
        </aside>

        <section class="collector-panel-modern collector-sales-panel-modern">
            <div class="collector-panel-header-modern wide">
                <div>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <div>
                        <strong>Ventas para cobrar</strong>
                        <span>
                        @if (!string.IsNullOrWhiteSpace(Model.SelectedZone))
                        {
                            @:@Model.SelectedDay / @Model.SelectedStatus / @Model.SelectedZone
                        }
                        else if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
                        {
                            @:@Model.SelectedDay / @Model.SelectedStatus
                        }
                        else
                        {
                            @:Selecciona día, estatus y zona
                        }
                    </span>
                </div>
                @if (Model.MobileZoneClients.Count > 0)
                {
                    <div class="collector-count-badge-modern">@Model.MobileZoneClients.Count cuentas</div>
                }
            </div>

            @if (string.IsNullOrWhiteSpace(Model.SelectedZone))
            {
                <div class="collector-empty-hint-modern stage">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                    </svg>
                    <strong>Falta elegir la zona</strong>
                    <span>Con la zona seleccionada te mostramos toda la cartera operativa lista para llamar, ubicar o registrar cobro</span>
                </div>
            }
            else if (Model.MobileZoneClients.Count == 0)
            {
                <div class="collector-empty-hint-modern stage">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
                    </svg>
                    <strong>Sin ventas para esta zona</strong>
                    <span>No hay cuentas activas para el filtro actual</span>
                </div>
            }
            else
            {
                <div class="collector-sales-stack-modern">
                    @foreach (var item in Model.MobileZoneClients)
                    {
                        var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
                        var tone = SaleTone(item);
                        <article class="collector-sale-card-modern status-@tone" data-search="@(item.Name.ToLowerInvariant()) @(item.Zone.ToLowerInvariant()) @(item.ReferenceText.ToLowerInvariant()) @(item.NumVenta)">
                            <a class="collector-sale-content-modern" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone">
                                <div class="collector-sale-thumb-modern">
                                    @if (!string.IsNullOrWhiteSpace(item.Thumbnail))
                                    {
                                        <img src="~/@item.Thumbnail" alt="@item.Name" />
                                    }
                                    else
                                    {
                                        <div class="collector-thumb-placeholder">@item.Name[..1]</div>
                                    }
                                </div>
                                <div class="collector-sale-info-modern">
                                    <div class="collector-sale-header-modern">
                                        <strong>
                                            <span class="collector-icon-semantic @tone">@Html.Raw(SaleIcon(item))</span>
                                            @item.Name
                                        </strong>
                                        <span class="collector-status-pill-modern @tone">@SaleBadge(item)</span>
                                    </div>
                                    <div class="collector-sale-meta-modern">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                                        </svg>
                                        @item.Zone
                                        <span>·</span>
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                        </svg>
                                        @item.Route
                                        <span>·</span>
                                        Venta #@item.NumVenta
                                    </div>
                                    <div class="collector-sale-note-modern">@item.NextAction · @item.ReferenceText</div>
                                </div>
                            </a>
                            <div class="collector-sale-actions-modern">
                                @if (!string.IsNullOrWhiteSpace(item.Phone)) 
                                { 
                                    <a href="tel:@item.Phone" title="Llamar">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                        </svg>
                                    </a>
                                }
                                <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)" title="Ver mapa">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                                    </svg>
                                </a>
                                <a class="primary" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@Model.SelectedZone" title="Registrar cobro">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                    </svg>
                                </a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</section>
