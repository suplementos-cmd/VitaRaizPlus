@using SalesCobrosGeo.Web.Models.Collections
@model CollectorHomeViewModel
@{
    // Obtener catálogos dinámicos del ViewBag
    var collectionStatuses = ViewBag.CollectionStatuses as IReadOnlyDictionary<string, (string CssClass, string DisplayText, string? Icon)> 
        ?? new Dictionary<string, (string, string, string?)>();
}
@functions {
    string SaleTone(CollectorClientListItem item, IReadOnlyDictionary<string, (string CssClass, string DisplayText, string? Icon)> statuses)
    {
        // Condiciones especiales primero
        if (item.HasPromiseOverdue) return "danger";
        if (item.IsNotLocated) return "warning";
        if (item.IsRefused) return "muted";
        if (item.HasPromise) return "info";
        
        // Buscar en catálogos dinámicos
        var statusCode = item.Status.ToUpperInvariant();
        if (statuses.TryGetValue(statusCode, out var statusInfo))
            return statusInfo.CssClass;
        
        return "neutral";
    }

    string SaleIcon(CollectorClientListItem item, IReadOnlyDictionary<string, (string CssClass, string DisplayText, string? Icon)> statuses)
    {
        // Iconos para condiciones especiales
        if (item.HasPromiseOverdue) 
            return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 9v4'/><path d='M12 17h.01'/><path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/></svg>";
        if (item.HasPromise) 
            return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>";
        if (item.IsNotLocated) 
            return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m21 10-5.2-5.2a2 2 0 0 0-2.8 0L4 14v6h6l9-9a2 2 0 0 0 0-2.8Z'/><path d='M7 17h.01'/></svg>";
        if (item.IsRefused) 
            return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>";
        
        // Buscar icono en catálogos dinámicos
        var statusCode = item.Status.ToUpperInvariant();
        if (statuses.TryGetValue(statusCode, out var statusInfo) && !string.IsNullOrWhiteSpace(statusInfo.Icon))
            return statusInfo.Icon;
        
        // Icono por defecto
        return "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>";
    }

    string SaleBadge(CollectorClientListItem item, IReadOnlyDictionary<string, (string CssClass, string DisplayText, string? Icon)> statuses)
    {
        // Textos para condiciones especiales
        if (item.HasPromiseOverdue) return "Promesa vencida";
        if (item.HasPromise) return "Promesa activa";
        if (item.IsNotLocated) return "No localizado";
        if (item.IsRefused) return "Se nego";
        
        // Buscar texto en catálogos dinámicos
        var statusCode = item.Status.ToUpperInvariant();
        if (statuses.TryGetValue(statusCode, out var statusInfo))
            return statusInfo.DisplayText;
        
        return item.Status;
    }
}
<section class="collector-home-modern">
    <header class="collector-role-header-modern">
        <div class="collector-role-title-section">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            <div>
                <h1>Cobranza en campo</h1>
                <p>@Model.DisplayName · @Model.RouteLabel</p>
            </div>
        </div>
        <div class="collector-role-actions-modern">
            <a class="btn btn-primary btn-modern" asp-action="CollectorQueue" asp-route-profile="@Model.Profile">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
                </svg>
                Pendientes de hoy
            </a>
            <a class="btn btn-outline-primary btn-modern" asp-action="CollectorRoute" asp-route-profile="@Model.Profile">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                Mi ruta
            </a>
        </div>
    </header>

    <section class="collector-metrics-modern">
        @foreach (var card in Model.Cards)
        {
            <a class="collector-metric-card-modern @card.Accent" asp-action="@card.TargetAction" asp-route-profile="@Model.Profile" asp-route-status="@card.StatusKey" asp-route-filter="all" asp-route-groupBy="status">
                <span class="collector-metric-title">@card.Title</span>
                <strong>@card.Count</strong>
                <small>@card.Subtitle</small>
            </a>
        }
    </section>

    <section class="collector-summary-strip-home-modern">
        @foreach (var summary in Model.HistorySummaryCards)
        {
            var targetUrl = summary.Code == "pending"
                ? Url.Action("CollectorQueue", "Cobros", new { profile = Model.Profile, groupBy = "status", filter = "all" })
                : Url.Action("CollectionHistory", "Cobros", new { profile = Model.Profile, outcome = summary.Code });
            <a class="collector-summary-card-home-modern @(summary.IsActive ? "active" : string.Empty)" href="@targetUrl">
                <span>@summary.Title</span>
                <strong>@summary.Count</strong>
                <small>@summary.Subtitle</small>
            </a>
        }
    </section>

    <section class="collector-section-modern">
        <div class="collector-section-header-modern">
            <div>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                <div>
                    <strong>Clientes por visitar</strong>
                    <span>Información operativa para trabajar rápido</span>
                </div>
            </div>
            <a class="collector-section-link-modern" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-groupBy="status" asp-route-filter="all">
                Ver bandeja
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="m9 18 6-6-6-6"/>
                </svg>
            </a>
        </div>

        <div class="collector-client-stack-modern">
            @foreach (var item in Model.TodayClients)
            {
                var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
                var tone = SaleTone(item, collectionStatuses);
                <article class="collector-client-card-modern status-@tone" data-search="@(item.Name.ToLowerInvariant()) @(item.Zone.ToLowerInvariant()) @(item.ReferenceText.ToLowerInvariant()) @(item.NumVenta)">
                    <a class="collector-client-link-modern" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                        <div class="collector-client-thumb-modern">
                            <img src="@(string.IsNullOrWhiteSpace(item.Thumbnail) ? "https://placehold.co/80x80?text=C" : (item.Thumbnail!.StartsWith("/") ? item.Thumbnail : "/" + item.Thumbnail))" alt="@item.Name" loading="lazy" decoding="async" />
                        </div>
                        <div class="collector-client-content-modern">
                            <div class="collector-client-header-modern">
                                <strong>
                                    <span class="collector-icon-semantic @tone">@Html.Raw(SaleIcon(item, collectionStatuses))</span>
                                    @item.Name
                                </strong>
                                <span class="collector-priority-modern @item.Priority.ToLowerInvariant()">@item.Priority</span>
                                <span class="collector-status-pill-modern @tone">@SaleBadge(item, collectionStatuses)</span>
                            </div>
                            <div class="collector-client-meta-row-modern">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                                @item.Zone
                                <span>·</span>
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                                </svg>
                                @item.Route
                                <span>·</span>
                                Folio #@item.NumVenta
                            </div>
                            <div class="collector-client-reference-modern">@item.ReferenceText</div>
                            <div class="collector-client-action-modern">@item.NextAction</div>
                        </div>
                    </a>
                    <div class="collector-client-actions-modern">
                        @if (!string.IsNullOrWhiteSpace(item.Phone))
                        {
                            <a href="tel:@item.Phone" aria-label="Llamar">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                </svg>
                            </a>
                        }
                        <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)" aria-label="Mapa">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/>
                            </svg>
                        </a>
                        <a asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile" aria-label="Registrar visita" class="primary">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                            </svg>
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>
</section>
