@model SalesCobrosGeo.Web.Models.Sales.CollectorPortfolioViewModel
@{
    var totalRestante = Model.Sales.Sum(x => x.ImporteRestante);
    var showMobileSearch = Model.ShowAll || !string.IsNullOrWhiteSpace(Model.SelectedZone);
    bool inDay    = !string.IsNullOrWhiteSpace(Model.SelectedDay);
    bool inStatus = !string.IsNullOrWhiteSpace(Model.SelectedStatus);
    bool inZone   = !string.IsNullOrWhiteSpace(Model.SelectedZone);

    string StatusAccent(string status) => status.ToUpperInvariant() switch
    {
        "AL CORRIENTE" => "green",
        "ATRASADO"     => "red",
        "PASAR MANANA" => "orange",
        "PROXIMA SEMANA" => "pink",
        _ => string.Empty
    };
}

<div class="collector-mobile-app">
    <header class="collector-mobile-header">
        <div class="collector-mobile-overview">
            <div class="collector-mobile-metricchip">
                <span class="collector-mobile-metriclabel">Cuentas</span>
                <strong id="collectorMobileCount">@Model.Sales.Count</strong>
            </div>
            <div class="collector-mobile-metricchip money">
                <span class="collector-mobile-metriclabel">Restante</span>
                <strong>Bs&nbsp;@totalRestante.ToString("0,0.##")</strong>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.SelectedStatus))
            {
                <div class="collector-mobile-metricchip subtle @StatusAccent(Model.SelectedStatus)">
                    <span class="collector-mobile-metriclabel">Filtro activo</span>
                    <strong>@Model.SelectedStatus</strong>
                </div>
            }
        </div>

        @if (inDay)
        {
            <nav class="collector-nav-breadcrumb" aria-label="Navegación cartera">
                <a class="cnb-link" asp-action="Index" asp-route-profile="@Model.Profile">
                    <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M7.293 1.293a1 1 0 011.414 0L14 6.586V13a1 1 0 01-1 1H3a1 1 0 01-1-1V6.586l5.293-5.293z"/></svg>
                    Cartera
                </a>
                <span class="cnb-sep" aria-hidden="true">›</span>
                @if (inStatus)
                {
                    <a class="cnb-link" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay">@Model.SelectedDay</a>
                    <span class="cnb-sep" aria-hidden="true">›</span>
                    @if (inZone)
                    {
                        <a class="cnb-link" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus">@Model.SelectedStatus</a>
                        <span class="cnb-sep" aria-hidden="true">›</span>
                        <span class="cnb-current">@Model.SelectedZone</span>
                    }
                    else
                    {
                        <span class="cnb-current">@Model.SelectedStatus</span>
                    }
                }
                else
                {
                    <span class="cnb-current">@Model.SelectedDay</span>
                }
            </nav>
        }

        @if (showMobileSearch)
        {
            <div class="collector-mobile-searchbar" data-cobros-search-shell="true" hidden>
                <span class="collector-mobile-searchicon">
                    <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/></svg>
                </span>
                <input id="collectorMobileSearch" type="search" class="collector-mobile-searchinput" placeholder="Buscar cliente, zona o venta" autocomplete="off" />
            </div>
        }
    </header>

    @if (Model.ShowAll)
    {
        <partial name="_MobileSalesList" model="Model" />
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedDay))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Days)
            {
                var dayAmt = Model.Sales.Where(x => string.Equals(x.DiaCobroPrevisto, item.Day, StringComparison.OrdinalIgnoreCase)).Sum(x => x.ImporteRestante);
                <a class="collector-mobile-row day" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@item.Day">
                    <span class="collector-mobile-row-icon day">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z" clip-rule="evenodd"/></svg>
                    </span>
                    <div class="collector-mobile-row-main">
                        <span class="collector-mobile-row-label">@item.Day</span>
                        @if (dayAmt > 0) { <span class="collector-mobile-row-amount">Bs @dayAmt.ToString("0,0.##")</span> }
                    </div>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg></span>
                </a>
            }
        </div>
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedStatus))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Statuses)
            {
                var statusAmt = Model.Sales.Where(x => string.Equals(x.Estatus, item.Status, StringComparison.OrdinalIgnoreCase)).Sum(x => x.ImporteRestante);
                <a class="collector-mobile-row status @StatusAccent(item.Status)" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@item.Status">
                    <span class="collector-mobile-row-icon status">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/></svg>
                    </span>
                    <div class="collector-mobile-row-main">
                        <span class="collector-mobile-row-label">@item.Status</span>
                        @if (statusAmt > 0) { <span class="collector-mobile-row-amount">Bs @statusAmt.ToString("0,0.##")</span> }
                    </div>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg></span>
                </a>
            }
        </div>
    }
    else if (string.IsNullOrWhiteSpace(Model.SelectedZone))
    {
        <div class="collector-mobile-list">
            @foreach (var item in Model.Zones)
            {
                var zoneAmt = Model.Sales.Where(x => string.Equals(x.Zona, item.Zone, StringComparison.OrdinalIgnoreCase)).Sum(x => x.ImporteRestante);
                <a class="collector-mobile-row zone" asp-action="Index" asp-route-profile="@Model.Profile" asp-route-day="@Model.SelectedDay" asp-route-status="@Model.SelectedStatus" asp-route-zone="@item.Zone">
                    <span class="collector-mobile-row-icon zone">
                        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z" clip-rule="evenodd"/></svg>
                    </span>
                    <div class="collector-mobile-row-main">
                        <span class="collector-mobile-row-label">@item.Zone</span>
                        @if (zoneAmt > 0) { <span class="collector-mobile-row-amount">Bs @zoneAmt.ToString("0,0.##")</span> }
                    </div>
                    <span class="collector-mobile-row-count">@item.Count</span>
                    <span class="collector-mobile-row-arrow"><svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 010-1.06z" clip-rule="evenodd"/></svg></span>
                </a>
            }
        </div>
    }
    else
    {
        <partial name="_MobileSalesList" model="Model" />
    }
</div>
