@using SalesCobrosGeo.Web.Models.Collections
@model CollectorRouteViewModel
@functions {
    string SaleTone(CollectorClientListItem item) => item.Status.ToUpperInvariant() switch
    {
        _ when item.HasPromiseOverdue => "danger",
        _ when item.IsNotLocated => "warning",
        _ when item.IsRefused => "muted",
        "ATRASADO" => "danger",
        "CANCELADO" => "muted",
        "LIQUIDADO" => "success",
        "AL CORRIENTE" => "success",
        "PARCIAL" => "warning",
        "POR INICIAR" => "neutral",
        _ when item.HasPromise => "info",
        _ => "neutral"
    };

    string SaleIcon(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M12 9v4'/><path d='M12 17h.01'/><path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/></svg>",
        _ when item.HasPromise => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='M8 7h8'/><path d='M8 12h8'/><path d='M8 17h5'/><path d='M5 4h14a1 1 0 0 1 1 1v14l-4-3-4 3-4-3-4 3V5a1 1 0 0 1 1-1z'/></svg>",
        _ when item.IsNotLocated => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m21 10-5.2-5.2a2 2 0 0 0-2.8 0L4 14v6h6l9-9a2 2 0 0 0 0-2.8Z'/><path d='M7 17h.01'/></svg>",
        _ when item.IsRefused => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='m15 9-6 6'/><path d='m9 9 6 6'/></svg>",
        _ when item.Status.Equals("ATRASADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 3'/></svg>",
        _ when item.Status.Equals("LIQUIDADO", StringComparison.OrdinalIgnoreCase) => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><path d='m5 13 4 4L19 7'/></svg>",
        _ => "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'><rect x='3' y='5' width='18' height='16' rx='2'/><path d='M16 3v4'/><path d='M8 3v4'/><path d='M3 11h18'/></svg>"
    };

    string SaleBadge(CollectorClientListItem item) => item switch
    {
        _ when item.HasPromiseOverdue => "Promesa vencida",
        _ when item.HasPromise => "Promesa activa",
        _ when item.IsNotLocated => "No localizado",
        _ when item.IsRefused => "Se nego",
        _ => item.Status
    };
}
<section class="collector-route-shell">
    <header class="collector-role-header collector-role-header-compact">
        <div>
            <h1>Mi ruta</h1>
            <p>Orden sugerido por prioridad y cercania.</p>
        </div>
        <div class="collector-role-actions">
            @if (!string.IsNullOrWhiteSpace(Model.RouteUrl))
            {
                <a class="btn btn-primary" href="@Model.RouteUrl" target="_blank" rel="noopener">Abrir ruta</a>
            }
            <a class="btn btn-outline-primary" asp-action="CollectorQueue" asp-route-profile="@Model.Profile" asp-route-groupBy="route" asp-route-filter="today">Bandeja</a>
        </div>
    </header>
    <div class="collector-route-map card card-body">
        <strong>Ruta optimizada</strong>
        <span>@Model.GeoPoints puntos con coordenadas · @Model.TotalStops paradas</span>
    </div>
    <div class="collector-client-stack">
        @foreach (var item in Model.Clients)
        {
            var mapLink = string.IsNullOrWhiteSpace(item.Coordinates) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(item.Coordinates)}";
            var tone = SaleTone(item);
            <article class="collector-client-card route-card status-@tone">
                <a class="collector-client-main" asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">
                    <div class="collector-route-order">@item.OrderIndex</div>
                    <div class="collector-client-copy no-thumb">
                        <div class="collector-client-topline">
                            <strong><span class="collector-semantic-icon @tone">@Html.Raw(SaleIcon(item))</span>@item.Name</strong>
                            <span class="collector-priority @item.Priority.ToLowerInvariant()">@item.Priority</span>
                            <span class="collector-state-pill @tone">@SaleBadge(item)</span>
                        </div>
                        <div class="collector-client-meta">@item.Zone · @item.ReferenceText</div>
                        <div class="collector-next-action">@item.NextAction</div>
                    </div>
                </a>
                <div class="collector-client-actions">
                    <a href="@mapLink" target="_blank" rel="noopener" class="@(mapLink == "#" ? "disabled" : string.Empty)">MP</a>
                    <a asp-action="Register" asp-route-id="@item.IdV" asp-route-profile="@Model.Profile">RG</a>
                </div>
            </article>
        }
    </div>
</section>
