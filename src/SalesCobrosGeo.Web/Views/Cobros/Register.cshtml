@model SalesCobrosGeo.Web.Models.Sales.CollectionRegisterViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Registrar Cobro";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Registrar Cobro</h1>
    <a class="btn btn-outline-secondary" asp-controller="Cobros" asp-action="Index" asp-route-profile="@Model.Input.Usuario">Volver</a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">No se pudo registrar el cobro. Revisa los datos.</div>
}

@if (Model.PortfolioItem is not null)
{
    <div class="card mb-3">
        <div class="card-header">Venta seleccionada</div>
        <div class="card-body row g-2">
            <div class="col-md-4"><strong>Num Venta:</strong> @Model.PortfolioItem.NumVenta</div>
            <div class="col-md-4"><strong>Cliente:</strong> @Model.PortfolioItem.NombreCliente</div>
            <div class="col-md-4"><strong>Zona:</strong> @Model.PortfolioItem.Zona</div>
            <div class="col-md-4"><strong>Total:</strong> @Model.PortfolioItem.ImporteTotal.ToString("0.00")</div>
            <div class="col-md-4"><strong>Abonado:</strong> @Model.PortfolioItem.ImporteAbonado.ToString("0.00")</div>
            <div class="col-md-4"><strong>Restante:</strong> @Model.PortfolioItem.ImporteRestante.ToString("0.00")</div>
        </div>
    </div>
}

<form method="post" class="card card-body mb-4">
    @Html.AntiForgeryToken()
    <input asp-for="Input.IdV" type="hidden" />

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Input.ImporteCobro" class="form-label">Importe de cobro</label>
            <input asp-for="Input.ImporteCobro" type="number" step="0.01" min="0" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.FechaCobro" class="form-label">Fecha de cobro</label>
            <input asp-for="Input.FechaCobro" type="date" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.Usuario" class="form-label">Usuario cobrador</label>
            <select asp-for="Input.Usuario" class="form-select" asp-items="@(new SelectList(Model.CollectorProfiles, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                <option value="">Seleccione</option>
            </select>
        </div>
        <div class="col-md-6">
            <label asp-for="Input.CoordenadasCobro" class="form-label">Coordenadas cobro</label>
            <input asp-for="Input.CoordenadasCobro" class="form-control" placeholder="19.260839, -98.831437" />
        </div>
        <div class="col-md-6">
            <label asp-for="Input.ObservacionCobro" class="form-label">Observacion cobro</label>
            <input asp-for="Input.ObservacionCobro" class="form-control" />
        </div>
    </div>

    <div class="mt-3 text-end">
        <button type="submit" class="btn btn-success">Guardar cobro</button>
    </div>
</form>

<div class="card">
    <div class="card-header">Historial de la venta</div>
    <div class="card-body table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Importe</th>
                    <th>Abonado</th>
                    <th>Restante</th>
                    <th>Estatus</th>
                    <th>Usuario</th>
                    <th>Obs.</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Historial.Count == 0)
            {
                <tr><td colspan="7" class="text-center text-muted">Sin cobros previos</td></tr>
            }
            else
            {
                foreach (var item in Model.Historial)
                {
                    <tr>
                        <td>@item.FechaCobro.ToString("yyyy-MM-dd")</td>
                        <td>@item.ImporteCobro.ToString("0.00")</td>
                        <td>@item.ImporteAbonado.ToString("0.00")</td>
                        <td>@item.ImporteRestante.ToString("0.00")</td>
                        <td>@item.Estatus</td>
                        <td>@item.Usuario</td>
                        <td>@item.ObservacionCobro</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
