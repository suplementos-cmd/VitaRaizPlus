@model SalesCobrosGeo.Web.Models.Sales.CollectionRegisterViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using SalesCobrosGeo.Web.Models.Shared
@{
    ViewData["Title"] = "Registrar Cobro";
    var sale = Model.Sale;
    string ResolveImage(string? path, string fallback) =>
        string.IsNullOrWhiteSpace(path) ? fallback :
        (path.StartsWith("http", StringComparison.OrdinalIgnoreCase) || path.StartsWith("data:", StringComparison.OrdinalIgnoreCase) || path.StartsWith("/")
            ? path
            : "/" + path);
    var mainPhoto = string.IsNullOrWhiteSpace(sale?.FotoFachada)
        ? ResolveImage(sale?.FotoCliente, "https://placehold.co/900x420?text=Venta")
        : ResolveImage(sale.FotoFachada, "https://placehold.co/900x420?text=Venta");
    var clientPhoto = ResolveImage(sale?.FotoCliente, "https://placehold.co/240x180?text=Cliente");
    var cleanPhone = string.IsNullOrWhiteSpace(Model.PortfolioItem?.Celular) ? string.Empty : new string(Model.PortfolioItem.Celular.Where(char.IsDigit).ToArray());
    var mapLink = string.IsNullOrWhiteSpace(sale?.Coordenadas) ? "#" : $"https://maps.google.com/?q={Uri.EscapeDataString(sale.Coordenadas)}";

    string StatusClass(string status) => status.ToUpperInvariant() switch
    {
        "POR INICIAR" => "status-chip status-start",
        "AL CORRIENTE" => "status-chip status-current",
        "ATRASADO" => "status-chip status-late",
        "LIQUIDADO" => "status-chip status-done",
        _ => "status-chip"
    };
    ViewData["MobileContextBar"] = new MobileContextBarModel(
        "Registrar cobro",
        Model.PortfolioItem is null ? "Captura de abono" : Model.PortfolioItem.NombreCliente,
        Url.Action("Index", "Cobros", new { profile = Model.ReturnProfile, day = Model.ReturnDay, status = Model.ReturnStatus, zone = Model.ReturnZone }));
}

<div class="collector-register-page collector-register-page-tight">
    <div class="collector-register-topbar compact">
        <a class="btn btn-outline-secondary btn-sm collector-back-btn" asp-controller="Cobros" asp-action="Index" asp-route-profile="@Model.ReturnProfile" asp-route-day="@Model.ReturnDay" asp-route-status="@Model.ReturnStatus" asp-route-zone="@Model.ReturnZone">
            <span class="collector-back-icon">?</span>
            <span class="collector-back-text">Volver</span>
        </a>
        <div class="collector-register-title-wrap compact">
            <h1 class="collector-register-title">Venta para cobro</h1>
            <div class="collector-register-subtitle">El estado se actualiza automaticamente al registrar cobro o abono</div>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="app-toast-inline danger">No se pudo registrar el cobro. Revisa los datos.</div>
    }

    @if (Model.PortfolioItem is not null)
    {
        <div class="collector-register-hero mb-3 compact-hero">
            <img class="image-previewable" data-previewable="true" src="@mainPhoto" alt="Venta" loading="lazy" decoding="async" />
            <div class="collector-register-overlay">
                <div class="collector-register-badge @StatusClass(Model.PortfolioItem.Estatus)">@Model.PortfolioItem.Estatus</div>
            </div>
        </div>

        <div class="collector-quick-actions collector-quick-actions-wide mb-3 compact-actions">
            @if (!string.IsNullOrWhiteSpace(cleanPhone))
            {
                <a class="btn btn-outline-secondary" href="tel:@cleanPhone">Llamar</a>
                <a class="btn btn-outline-success" href="https://wa.me/@cleanPhone" target="_blank" rel="noopener">WhatsApp</a>
            }
            <a class="btn btn-outline-primary @(mapLink == "#" ? "disabled" : string.Empty)" href="@mapLink" target="_blank" rel="noopener">Abrir</a>
            <button type="button" class="btn btn-outline-primary" id="btnCollectorGps">GPS</button>
        </div>

        <div class="collector-register-grid mb-3">
            <div class="card card-body collector-register-client-card">
                <div class="collector-register-client-head">
                    <img class="collector-register-client-photo image-previewable" data-previewable="true" src="@clientPhoto" alt="Cliente" loading="lazy" decoding="async" />
                    <div>
                        <div class="collector-register-client">@Model.PortfolioItem.NombreCliente</div>
                        <div class="collector-register-meta">Venta #@Model.PortfolioItem.NumVenta</div>
                        <div class="collector-register-meta">@Model.PortfolioItem.Zona • @Model.PortfolioItem.DiaCobroPrevisto</div>
                    </div>
                </div>
            </div>

            <div class="card card-body collector-register-summary-card">
                <div class="collector-balance-grid">
                    <div><span>Total</span><strong>@Model.PortfolioItem.ImporteTotal.ToString("0.00")</strong></div>
                    <div><span>Abonado</span><strong>@Model.PortfolioItem.ImporteAbonado.ToString("0.00")</strong></div>
                    <div class="collector-restante"><span>Restante</span><strong>@Model.PortfolioItem.ImporteRestante.ToString("0.00")</strong></div>
                </div>
                @if (!string.IsNullOrWhiteSpace(sale?.Coordenadas))
                {
                    <div class="collector-register-coords">@sale.Coordenadas</div>
                }
            </div>
        </div>
    }

    <form method="post" class="card card-body mb-4 collector-register-form">
        @Html.AntiForgeryToken()
        <input asp-for="Input.IdV" type="hidden" />
        <input type="hidden" name="profile" value="@Model.ReturnProfile" />
        <input type="hidden" name="day" value="@Model.ReturnDay" />
        <input type="hidden" name="status" value="@Model.ReturnStatus" />
        <input type="hidden" name="zone" value="@Model.ReturnZone" />

        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Input.ImporteCobro" class="form-label">Importe de cobro</label>
                <input asp-for="Input.ImporteCobro" type="number" step="0.01" min="0" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Input.FechaCobro" class="form-label">Fecha de cobro</label>
                <input asp-for="Input.FechaCobro" type="date" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Usuario" class="form-label">Usuario cobrador</label>
                <select asp-for="Input.Usuario" class="form-select" asp-items="@(new SelectList(Model.CollectorProfiles, nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Code), nameof(SalesCobrosGeo.Web.Models.Sales.CatalogOption.Name)))">
                    <option value="">Seleccione</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.CoordenadasCobro" class="form-label">Coordenadas cobro</label>
                <div class="input-group">
                    <input asp-for="Input.CoordenadasCobro" class="form-control" id="collectorGpsCoordinates" placeholder="19.260839, -98.831437" />
                    <button type="button" class="btn btn-outline-primary" id="btnCollectorGpsInline">GPS</button>
                </div>
                <small id="collectorGpsStatus" class="text-muted">Puedes detectar GPS automatico.</small>
            </div>
            <div class="col-md-6">
                <label asp-for="Input.ObservacionCobro" class="form-label">Observacion cobro</label>
                <input asp-for="Input.ObservacionCobro" class="form-control" />
            </div>
        </div>

        @if (Model.PortfolioItem is not null)
        {
            <div class="collector-register-actionbar mt-3">
                <div>
                    <div class="collector-register-actionlabel">Restante actual</div>
                    <div class="collector-register-actionamount">@Model.PortfolioItem.ImporteRestante.ToString("0.00")</div>
                </div>
                <button type="submit" class="btn btn-success collector-register-submit">Guardar cobro</button>
            </div>
        }
        else
        {
            <div class="mt-3 d-flex justify-content-end">
                <button type="submit" class="btn btn-success">Guardar cobro</button>
            </div>
        }
    </form>

    <div class="card collector-register-history">
        <div class="card-header">Movimientos de cobro</div>
        <div class="card-body">
            @if (Model.Historial.Count == 0)
            {
                <div class="app-empty-state compact">
                    <strong>Sin cobros previos</strong>
                    <span>Cuando registres un abono empezara a verse el historial aqui.</span>
                </div>
            }
            else
            {
                <div class="collector-history-list">
                    @foreach (var item in Model.Historial)
                    {
                        <div class="collector-history-item">
                            <div>
                                <strong>@item.FechaCobro.ToString("dd/MM/yyyy")</strong>
                                <div class="collector-register-meta">@item.Usuario</div>
                            </div>
                            <div>
                                <strong>@item.ImporteCobro.ToString("0.00")</strong>
                                <div class="collector-register-meta">abono</div>
                            </div>
                            <div>
                                <strong>@item.ImporteRestante.ToString("0.00")</strong>
                                <div class="collector-register-meta">restante</div>
                            </div>
                            <div class="@StatusClass(item.Estatus)">@item.Estatus</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
(function() {
    const coords = document.getElementById('collectorGpsCoordinates');
    const status = document.getElementById('collectorGpsStatus');
    const buttons = [document.getElementById('btnCollectorGps'), document.getElementById('btnCollectorGpsInline')].filter(Boolean);

    if (!coords || !status || buttons.length === 0) {
        return;
    }

    function applyLocation(position) {
        const lat = position.coords.latitude.toFixed(6);
        const lng = position.coords.longitude.toFixed(6);
        coords.value = `${lat}, ${lng}`;
        status.textContent = 'Ubicacion detectada correctamente.';
    }

    function detect() {
        if (!navigator.geolocation) {
            status.textContent = 'GPS no disponible en este dispositivo.';
            return;
        }

        status.textContent = 'Detectando ubicacion...';
        navigator.geolocation.getCurrentPosition(
            applyLocation,
            function(err) { status.textContent = `No se pudo detectar GPS (${err.message}).`; },
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
        );
    }

    buttons.forEach((btn) => btn.addEventListener('click', detect));
})();
</script>
}


