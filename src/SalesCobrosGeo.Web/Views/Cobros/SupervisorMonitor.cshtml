@using SalesCobrosGeo.Web.Models.Collections
@using SalesCobrosGeo.Web.Models.Shared
@model SupervisorCollectionsViewModel
@{
    ViewData["Title"] = "Monitoreo de cobros";
    ViewData["MobileContextBar"] = new MobileContextBarModel("Cobros", "Monitoreo", Url.Action("SupervisorDashboard", "Cobros", new { profile = Model.SelectedCollector }));
}

<section class="supervisor-shell">
    <header class="collector-role-header collector-role-header-compact">
        <div>
            <h1>Monitoreo operativo</h1>
            <p>Agrupa por cobrador, zona, ruta o estatus y revisa incidencias.</p>
        </div>
        <div class="collector-group-switches">
            <a class="@(Model.GroupBy == "collector" ? "active" : string.Empty)" asp-action="SupervisorMonitor" asp-route-groupBy="collector">Cobrador</a>
            <a class="@(Model.GroupBy == "zone" ? "active" : string.Empty)" asp-action="SupervisorMonitor" asp-route-groupBy="zone">Zona</a>
            <a class="@(Model.GroupBy == "status" ? "active" : string.Empty)" asp-action="SupervisorMonitor" asp-route-groupBy="status">Estatus</a>
            <a class="@(Model.GroupBy == "route" ? "active" : string.Empty)" asp-action="SupervisorMonitor" asp-route-groupBy="route">Ruta</a>
        </div>
    </header>

    <section class="supervisor-metrics-grid compact-monitor">
        @foreach (var metric in Model.Metrics)
        {
            <article class="supervisor-metric-card @metric.Tone compact">
                <span>@metric.Title</span>
                <strong>@metric.Value</strong>
                <small>@metric.Subtitle</small>
            </article>
        }
    </section>

    <div class="supervisor-panel-grid monitor-grid">
        <div class="supervisor-panel card card-body">
            <div class="supervisor-monitor-list">
                @foreach (var item in Model.Collectors)
                {
                    <article class="supervisor-monitor-row detailed">
                        <div>
                            <strong>@item.Collector</strong>
                            <span>@item.Zone · @item.Status</span>
                        </div>
                        <div><strong>@item.VisitsDone</strong><span>Visitas</span></div>
                        <div><strong>@item.PendingVisits</strong><span>Pendientes</span></div>
                        <div><strong>@item.Promises</strong><span>Promesas</span></div>
                        <div><strong>@item.Overdue</strong><span>Atrasadas</span></div>
                        <div><strong>@item.LastCoordinates</strong><span>Ubicacion</span></div>
                    </article>
                }
            </div>
        </div>

        <div class="supervisor-panel card card-body">
            <div class="collector-group-list compact-supervisor">
                @foreach (var group in Model.Groups)
                {
                    <article class="collector-group-card">
                        <header class="collector-group-head">
                            <div>
                                <strong>@group.Title</strong>
                                <span>@group.Subtitle</span>
                            </div>
                            <div class="collector-group-badges">
                                <span>@group.Accounts cuentas</span>
                                <span class="priority @group.Priority.ToLowerInvariant()">@group.Priority</span>
                            </div>
                        </header>
                        <div class="collector-group-hint">@group.SuggestedAction</div>
                    </article>
                }
            </div>
        </div>
    </div>
</section>
